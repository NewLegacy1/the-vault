//@version=6
// Track B · B9 MTF PM continuation MEASURE — Deep BT only.
// Spec: strategies/strategy-dev/60-track-b/track-b-b9-mtf-pmcont-v0.md
// Event on 15m (rare AM expansion); fills on chart TF (run 0a=5m, 0b=1m).
// Nutrients from killed B7 — NOT a 5m-only moveMult retune.
// CSV: matrix/trackb-mtf-pmcont-mnq-5m.csv  (then -mnq-1m.csv)

strategy(
     title                   = "TrackB MTF PMCont measure v0",
     shorttitle              = "MTF PMCont",
     overlay                 = true,
     pyramiding              = 0,
     process_orders_on_close = true,
     calc_on_every_tick      = false,
     max_bars_back           = 5000,
     initial_capital         = 50000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     commission_type         = strategy.commission.cash_per_contract,
     commission_value        = 0.62,
     slippage                = 1,
     margin_long             = 0,
     margin_short            = 0,
     max_labels_count        = 50)

grpEvt = "Event HTF (locked — do not sweep)"
i_htf      = input.timeframe("15", "HTF for AM move", group = grpEvt)
i_moveMult = input.float(1.2, "Min |AM move| = HTF ATR ×", minval = 0.5, step = 0.1, group = grpEvt)
i_sessOpen = input.int(930, "RTH open (HHMM)", group = grpEvt)
i_amEnd    = input.int(1200, "AM window end (HHMM)", group = grpEvt)
i_entry    = input.int(1205, "Entry bar on chart (HHMM)", group = grpEvt)
i_flatTime = input.int(1555, "Flat by (HHMM)", group = grpEvt)

grpRisk = "Risk (chart TF)"
i_atrLen  = input.int(14, "Chart ATR length", minval = 5, group = grpRisk)
i_atrMult = input.float(1.0, "Stop = chart ATR ×", group = grpRisk)
i_maxStop = input.float(40.0, "Max stop (pts)", group = grpRisk)
i_rr      = input.float(1.5, "Target R", group = grpRisk)
i_riskUsd = input.float(150.0, "Risk USD", group = grpRisk)
i_maxCtr  = input.int(60, "Max contracts", group = grpRisk)
i_pvMode  = input.string("MNQ ($2/pt)", "Point value", options = ["MNQ ($2/pt)", "NQ ($20/pt)", "Auto"], group = grpRisk)

grpVis = "Visuals"
i_showMark  = input.bool(true, "Markers", group = grpVis)
i_showDebug = input.bool(true, "Funnel table", group = grpVis)

f_hhmmMinus(int hhmm, int mins) =>
    int h = int(math.floor(hhmm / 100))
    int m = hhmm % 100
    int total = h * 60 + m - mins
    if total < 0
        total += 24 * 60
    int nh = int(math.floor(total / 60))
    int nm = total % 60
    nh * 100 + nm

// Runs on HTF bars inside request.security
f_htfAmBundle() =>
    int hhmm = hour(time, "America/New_York") * 100 + minute(time, "America/New_York")
    bool newD = ta.change(time("D", "America/New_York")) != 0
    float atrH = ta.atr(14)
    var float o930 = na
    var float amMove = na
    var bool moveOk = false
    var int bias = 0
    if newD
        o930 := na
        amMove := na
        moveOk := false
        bias := 0
    if hhmm == i_sessOpen
        o930 := open
    // Last HTF bar fully inside AM (amEnd − HTF bar length ≈ 15m → 1145 when amEnd=1200)
    int amCloseHhmm = f_hhmmMinus(i_amEnd, 15)
    if hhmm == amCloseHhmm and not na(o930) and not na(atrH)
        amMove := close - o930
        moveOk := math.abs(amMove) >= i_moveMult * atrH
        bias := amMove > 0 ? 1 : amMove < 0 ? -1 : 0
    [amMove, moveOk, bias, atrH]

[amMove15, moveOk15, bias15, atr15] = request.security(syminfo.tickerid, i_htf, f_htfAmBundle(), lookahead = barmerge.lookahead_off)

int nyHhmm = hour(time, "America/New_York") * 100 + minute(time, "America/New_York")
bool newDay = ta.change(time("D", "America/New_York")) != 0
bool isEntryBar = nyHhmm == i_entry
bool flatNow = nyHhmm >= i_flatTime

float atrChart = ta.atr(i_atrLen)

var int dayTrades = 0
var int cntDays = 0
var int cntMoveOk = 0
var int cntOrders = 0
var int cntSkipStop = 0
var bool countedMoveToday = false

if newDay
    dayTrades := 0
    countedMoveToday := false
    cntDays += 1

if moveOk15 and not countedMoveToday
    cntMoveOk += 1
    countedMoveToday := true

f_pv() =>
    if i_pvMode == "MNQ ($2/pt)"
        2.0
    else if i_pvMode == "NQ ($20/pt)"
        20.0
    else
        float raw = syminfo.pointvalue
        string t = str.upper(syminfo.ticker)
        str.contains(t, "MNQ") ? 2.0 : (str.contains(t, "NQ") ? 20.0 : (raw > 0 ? raw : 2.0))

f_qty(float stopPts) =>
    float pv = f_pv()
    if stopPts <= 0 or stopPts > i_maxStop
        0
    else
        int q = int(math.floor(i_riskUsd / (stopPts * pv)))
        math.max(0, math.min(q, i_maxCtr))

if flatNow and strategy.position_size != 0
    strategy.close_all(comment = "flat 15:55")

if isEntryBar and moveOk15 and bias15 != 0 and dayTrades == 0 and strategy.position_size == 0 and not na(atrChart)
    float stopPts = i_atrMult * atrChart
    int q = f_qty(stopPts)
    if q > 0
        if bias15 == 1
            float stopL = close - stopPts
            float tpL = close + i_rr * stopPts
            strategy.entry("M_L", strategy.long, qty = q)
            strategy.exit("M_LX", from_entry = "M_L", stop = stopL, limit = tpL)
            dayTrades := 1
            cntOrders += 1
            if i_showMark
                label.new(bar_index, low, "MTF▲", style = label.style_label_up, color = color.new(#a3e635, 0), textcolor = color.black, size = size.small)
        else
            float stopS = close + stopPts
            float tpS = close - i_rr * stopPts
            strategy.entry("M_S", strategy.short, qty = q)
            strategy.exit("M_SX", from_entry = "M_S", stop = stopS, limit = tpS)
            dayTrades := 1
            cntOrders += 1
            if i_showMark
                label.new(bar_index, high, "MTF▼", style = label.style_label_down, color = color.new(#fb7185, 0), textcolor = color.black, size = size.small)
    else
        cntSkipStop += 1
        dayTrades := 1

if i_showDebug and barstate.islast
    var table t = table.new(position.top_right, 2, 7, bgcolor = color.new(#0f172a, 20))
    table.cell(t, 0, 0, "B9 MTF PMCont", text_color = color.white, text_size = size.small)
    table.cell(t, 1, 0, "15m→chart", text_color = color.gray, text_size = size.small)
    table.cell(t, 0, 1, "Chart TF", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 1, timeframe.period, text_color = color.white, text_size = size.tiny)
    table.cell(t, 0, 2, "Days", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 2, str.tostring(cntDays), text_color = color.white, text_size = size.tiny)
    table.cell(t, 0, 3, "HTF move OK", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 3, str.tostring(cntMoveOk), text_color = color.white, text_size = size.tiny)
    table.cell(t, 0, 4, "Orders", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 4, str.tostring(cntOrders), text_color = color.lime, text_size = size.tiny)
    table.cell(t, 0, 5, "Skip stop", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 5, str.tostring(cntSkipStop), text_color = color.orange, text_size = size.tiny)
    table.cell(t, 0, 6, "Last AMΔ", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 6, na(amMove15) ? "—" : str.tostring(amMove15, "#.#"), text_color = color.white, text_size = size.tiny)

alertcondition(dayTrades == 1 and dayTrades[1] == 0, title = "MTF PMCont · entry", message = "B9 MTF PMCont MEASURE — Stage-0 only · not promote.")
