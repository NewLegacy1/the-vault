//@version=6
// Track B · B8 gap CONTINUATION MEASURE — Deep BT only.
// Spec: strategies/strategy-dev/60-track-b/track-b-b8-gap-cont-v0.md
// Save CSV: vault-app/data/tv-exports/matrix/trackb-gapcont-3y.csv
// Flip of killed B6 GapFade — continue gap, rare |gap| ≥ 1.0×ATR.

strategy(
     title                   = "TrackB GapCont measure v0",
     shorttitle              = "GapCont measure",
     overlay                 = true,
     pyramiding              = 0,
     process_orders_on_close = true,
     calc_on_every_tick      = false,
     max_bars_back           = 5000,
     initial_capital         = 50000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     commission_type         = strategy.commission.cash_per_contract,
     commission_value        = 0.62,
     slippage                = 1,
     margin_long             = 0,
     margin_short            = 0,
     max_labels_count        = 50)

grpEvt = "Event (locked — do not sweep)"
i_gapMult  = input.float(1.0, "Min |gap| = ATR × (rare)", minval = 0.5, step = 0.1, group = grpEvt)
i_sessOpen = input.int(930, "RTH open (HHMM)", group = grpEvt)
i_armFrom  = input.int(935, "Arm from (HHMM)", group = grpEvt)
i_armTo    = input.int(1015, "Last entry (HHMM)", group = grpEvt)
i_flatTime = input.int(1555, "Flat by (HHMM)", group = grpEvt)

grpRisk = "Risk"
i_atrLen  = input.int(14, "ATR length", minval = 5, group = grpRisk)
i_atrMult = input.float(1.0, "Stop = ATR ×", group = grpRisk)
i_maxStop = input.float(40.0, "Max stop (pts)", group = grpRisk)
i_rr      = input.float(1.5, "Target R", group = grpRisk)
i_riskUsd = input.float(150.0, "Risk USD", group = grpRisk)
i_maxCtr  = input.int(60, "Max contracts", group = grpRisk)
i_pvMode  = input.string("MNQ ($2/pt)", "Point value", options = ["MNQ ($2/pt)", "NQ ($20/pt)", "Auto"], group = grpRisk)

grpVis = "Visuals"
i_showMark  = input.bool(true, "Markers", group = grpVis)
i_showDebug = input.bool(true, "Funnel table", group = grpVis)

int nyHhmm = hour(time, "America/New_York") * 100 + minute(time, "America/New_York")
bool newDay = ta.change(time("D", "America/New_York")) != 0
bool canArm = nyHhmm >= i_armFrom and nyHhmm < i_armTo
bool flatNow = nyHhmm >= i_flatTime
bool isOpenBar = nyHhmm == i_sessOpen

float priorClose = request.security(syminfo.tickerid, "D", close[1], lookahead = barmerge.lookahead_off)
float atr = ta.atr(i_atrLen)

var float open930 = na
var float gapPts = na
var bool gapOk = false
var int gapDir = 0
var int dayTrades = 0

var int cntDays = 0
var int cntGapOk = 0
var int cntOrders = 0

if newDay
    open930 := na
    gapPts := na
    gapOk := false
    gapDir := 0
    dayTrades := 0
    cntDays += 1

if isOpenBar
    open930 := open
    if not na(priorClose) and not na(atr)
        gapPts := open - priorClose
        gapOk := math.abs(gapPts) >= i_gapMult * atr
        // Continuation: long if gap up, short if gap down
        gapDir := gapPts > 0 ? 1 : gapPts < 0 ? -1 : 0
        if gapOk
            cntGapOk += 1

f_pv() =>
    if i_pvMode == "MNQ ($2/pt)"
        2.0
    else if i_pvMode == "NQ ($20/pt)"
        20.0
    else
        float raw = syminfo.pointvalue
        string t = str.upper(syminfo.ticker)
        str.contains(t, "MNQ") ? 2.0 : (str.contains(t, "NQ") ? 20.0 : (raw > 0 ? raw : 2.0))

f_qty(float stopPts) =>
    float pv = f_pv()
    if stopPts <= 0 or stopPts > i_maxStop
        0
    else
        int q = int(math.floor(i_riskUsd / (stopPts * pv)))
        math.max(0, math.min(q, i_maxCtr))

if flatNow and strategy.position_size != 0
    strategy.close_all(comment = "flat 15:55")

if canArm and gapOk and gapDir != 0 and dayTrades == 0 and strategy.position_size == 0 and not na(atr)
    float stopPts = i_atrMult * atr
    int q = f_qty(stopPts)
    if q > 0
        if gapDir == 1
            float stopL = close - stopPts
            float tpL = close + i_rr * stopPts
            strategy.entry("C_L", strategy.long, qty = q)
            strategy.exit("C_LX", from_entry = "C_L", stop = stopL, limit = tpL)
            dayTrades := 1
            cntOrders += 1
            if i_showMark
                label.new(bar_index, low, "GC▲", style = label.style_label_up, color = color.new(#4ade80, 0), textcolor = color.black, size = size.small)
        else
            float stopS = close + stopPts
            float tpS = close - i_rr * stopPts
            strategy.entry("C_S", strategy.short, qty = q)
            strategy.exit("C_SX", from_entry = "C_S", stop = stopS, limit = tpS)
            dayTrades := 1
            cntOrders += 1
            if i_showMark
                label.new(bar_index, high, "GC▼", style = label.style_label_down, color = color.new(#f87171, 0), textcolor = color.black, size = size.small)

if i_showDebug and barstate.islast
    var table t = table.new(position.top_right, 2, 4, bgcolor = color.new(#0f172a, 20))
    table.cell(t, 0, 0, "GapCont", text_color = color.white, text_size = size.small)
    table.cell(t, 1, 0, "cont≥1.0ATR", text_color = color.gray, text_size = size.small)
    table.cell(t, 0, 1, "Days", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 1, str.tostring(cntDays), text_color = color.white, text_size = size.tiny)
    table.cell(t, 0, 2, "Gap OK", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 2, str.tostring(cntGapOk), text_color = color.white, text_size = size.tiny)
    table.cell(t, 0, 3, "Orders", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 3, str.tostring(cntOrders), text_color = color.lime, text_size = size.tiny)

alertcondition(dayTrades == 1 and dayTrades[1] == 0, title = "GapCont measure · entry", message = "GapCont MEASURE — Stage-0 only · not promote.")
