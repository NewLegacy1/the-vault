    kLbE := na
    kLbS := na
    kLbT := na
    kBxRisk := na
    kBxRew := na
    kBxRb := na
    // Fib / status / active pool are day-scoped — clear those drawings
    if not na(pbLnFib0)
        line.delete(pbLnFib0)
    if not na(pbLnFib1)
        line.delete(pbLnFib1)
    if not na(pbLnFibLeg)
        line.delete(pbLnFibLeg)
    if not na(pbLnFib0Tick)
        line.delete(pbLnFib0Tick)
    if not na(pbLnFib1Tick)
        line.delete(pbLnFib1Tick)
    if not na(pbLbl)
        label.delete(pbLbl)
    if not na(pbLbl0)
        label.delete(pbLbl0)
    if not na(pbLbl1)
        label.delete(pbLbl1)
    if not na(pbStateLbl)
        label.delete(pbStateLbl)
    if not na(biasEyesLbl)
        label.delete(biasEyesLbl)
    pbLnFib0 := na
    pbLnFib1 := na
    pbLnFibLeg := na
    pbLnFib0Tick := na
    pbLnFib1Tick := na
    pbLbl := na
