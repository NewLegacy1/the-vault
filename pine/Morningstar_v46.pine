bool fvg5U = on5m ? fvg5cU : fvg5sU
float fvg5Top = on5m ? fvg5cTop : fvg5sTop
float fvg5Bot = on5m ? fvg5cBot : fvg5sBot

f_zoneNearKo(float zHi, float zLo, float ko, float pad) =>
    not na(zHi) and not na(zLo) and not na(ko) and zLo - pad <= ko and ko <= zHi + pad

// ─── Plan math ───────────────────────────────────────────────────────────────
f_plan(float wickStart, float ce, float extreme, bool isShort) =>
    float stopPx = isShort ? extreme + i_stopBufPts : extreme - i_stopBufPts
    float riskWs = math.abs(stopPx - wickStart)
    float riskCe = math.abs(stopPx - ce)
    // Prefer wick-start; fall back to CE; last resort CE with stop capped at max
    float entryPx = riskWs >= i_minStopPts and riskWs <= i_maxStopPts ? wickStart : riskCe >= i_minStopPts and riskCe <= i_maxStopPts ? ce : na
    float stopOut = na(entryPx) ? na : stopPx
    if na(entryPx) and riskCe > i_maxStopPts and riskCe > 0
        entryPx := ce
        stopOut := isShort ? ce + i_maxStopPts : ce - i_maxStopPts
    [entryPx, stopOut]

f_nearKo(float a, float b) =>
    not na(a) and not na(b) and math.abs(a - b) <= i_pathBAlign

// True if KO sits in/near the RB wick band (not only exact extreme touch) — leave sleeve
f_nearKoBand(float hi, float lo, float ko) =>
    not na(hi) and not na(lo) and not na(ko) and lo <= ko + i_pathBAlign and hi >= ko - i_pathBAlign

// Strict A+: 10:00 open lies inside the RB zone (Thursday stack)
f_koInRbZone(float zHi, float zLo, float ko) =>
    not na(zHi) and not na(zLo) and not na(ko) and zLo - i_powellKoTol <= ko and ko <= zHi + i_powellKoTol

// Fixed R with hard pt cap (Dual46 chart harvest: 30pt stop → uncapped 150 TP never fills).
f_fixedTp(float entry, float risk, int dir) =>
    float rew = math.min(i_rr * risk, i_powellMaxTpPts)
    dir == 1 ? entry + rew : entry - rew

// Powell TP — Dual46: Fixed R (default 1:5, ≤ Max TP pts). Structure only if in [minR, maxR] and ≤ maxPts.
// Prior bugs: minR-only gate accepted 100–150pt Origin shelves; fib 0.705 stop + R·tag double-printed RR.
f_powellTp(float entry, float stop, int dir, float intEx, float intBody, float legEx, float legBody) =>
    float risk = math.abs(entry - stop)
    float fixedTp = f_fixedTp(entry, risk, dir)
    float structTp = na
    string tag = "R"
    if i_powellTp == "Fixed R"
        structTp := na
        tag := "R"
    else if (i_powellTp == "Origin CE" or i_powellTp == "Internal CE") and not na(intEx)
        structTp := not na(intBody) ? (intEx + intBody) * 0.5 : intEx
        tag := "oCE"
    else if (i_powellTp == "Origin high" or i_powellTp == "Internal high") and not na(intEx)
        structTp := intEx
        tag := "oHI"
    else if i_powellTp == "Leg CE" and not na(legEx)
        structTp := not na(legBody) ? (legEx + legBody) * 0.5 : legEx
        tag := "CE"
    else if i_powellTp == "Leg high" and not na(legEx)
        structTp := legEx
        tag := "HI"
    float out = fixedTp
    string outTag = ""
    if not na(structTp) and i_powellTp != "Fixed R"
        float rew = dir == 1 ? structTp - entry : entry - structTp
        bool sideOk = dir == 1 ? structTp > entry : structTp < entry
        bool minOk = rew >= risk * i_powellMinTpR
        bool maxOk = rew <= risk * i_powellMaxTpR and rew <= i_powellMaxTpPts
        if sideOk and minOk and maxOk
            out := structTp
            outTag := tag
    [out, outTag]

