    kBearRbWs := na
    kBearRbEx := na
    kBearRbT := na
    kBullObTop := na
    kBullObBot := na
    kBearObTop := na
    kBearObBot := na
    // Orphan prior-day plan drawings (keep on chart). Do not f_clearPlan / delete.
    eLnE := na
