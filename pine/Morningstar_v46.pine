//@version=6
// Morningstar v46 — Manual Path B study
// DO NOT edit pine/Powell_Rejection_Block_v1.pine (locked Lab).
// Older Dual / fat snapshots: pine/archive/
//
// Dual46 — back to what the control taught (user correction):
//  LIVE geometry = 1m Rejection Block (entry = wick-start, stop = beyond RB extreme)
//  GATE = RB zone in frozen-leg OTE + KO inside RB (A+ stack)
//  Fib 0.62 / 0.705 = EYES confluence only — NOT entry/stop (0.705 stop was too wide / broke RR)
//  TP = Fixed 1:5, hard-capped at Max TP pts (default 100) so wide RB stops (~30) don't demand 150+ pts
//  Tag shows actual plan RR (1:5 when tight; ~1:3 when capped). No R·1.5 · 1:1.5 double.
// Dual44/45 keep: away-only leave · Cont/Judas · lookback origin · Auto PDH/PDL · last arm 13:00
indicator(
     title            = "Morningstar v46",
     shorttitle       = "Morningstar v46",
     overlay          = true,
     max_bars_back    = 5000,
     max_lines_count  = 500,
     max_boxes_count  = 500,
     max_labels_count = 500)

// ─── Inputs (ALL input.* must stay contiguous — no other code between them) ───
i_winEnd      = input.int(1300, "Last arm (HHMM)", minval = 0, maxval = 2359, group = "Session", tooltip = "Dual44: default 13:00 — afternoon Path B is mostly noise.")
i_flatTime    = input.int(1555, "Session end label (HHMM)", minval = 0, maxval = 2359, group = "Session")
i_oneTradeDay = input.bool(false, "Max 1 setup per day (off when studying both sleeves)", group = "Session")
i_skipMonday  = input.bool(true, "Skip Mondays (SHADOW)", group = "Session")
i_skipJulOct  = input.bool(false, "Skip July & October (SHADOW)", group = "Session")
i_biasMode    = input.string("Long & Short", "Direction filter", options = ["Long & Short", "Long only", "Short only", "Auto PDH/PDL draw"], group = "Session", tooltip = "DEFAULT Long & Short = Dual46 harvest (Auto OFF). You + checklist filter. Long/Short only = hard HTF clamp. Auto PDH/PDL = optional A/B soup filter — not the version that printed the Jul-week WINs.")
i_biasShowAuto = input.bool(false, "Always show Auto PDH/PDL tag (eyes)", group = "Session", tooltip = "OFF by default (Dual46). When ON, plots Auto vs Man on the live bar — eyes only, does not filter arms.")

grpPb = "Path B"
i_pathB = input.bool(true, "Enable Path B", group = grpPb)
// KO-leave = price LEFT the 10:00 key open, then RB@KO (NOT "skip this trade").
// KO-retest = later pullback to KO after a run (Powell-style) — any clock time.
i_pathBSleeve = input.string("KO-retest only", "Which setups to show", options = ["KO-leave + KO-retest", "KO-leave only", "KO-retest only"], group = grpPb, tooltip = "DEFAULT = Powell only (fresh 1m RB on the OTE pullback of the frozen first leg ≈11:15 control). Leave is optional — often no real RB at 10:00.")
i_pathBAlign = input.float(50.0, "RB / KO proximity (pts) — leave sleeve", minval = 2.0, step = 1.0, group = grpPb, tooltip = "Loose align for KO-leave only. Powell OTE+KO grade uses the strict 'KO in RB zone' rule below.")
i_powellKoTol = input.float(3.0, "OTE+KO: KO must sit inside RB zone (pts)", minval = 0.0, step = 0.5, group = grpPb, tooltip = "A+ only when 10:00 open is inside the RB wick band (Thursday stack). Not the loose 50pt leave pad.")
i_powellWaitDeepKo = input.bool(true, "Powell: if KO deeper than OTE, skip shallow OTE", group = grpPb, tooltip = "While KO sits below OTE, never arm an OTE RB that does not contain KO.")
i_leaveWinMin = input.int(45, "KO-leave window (min after left KO)", minval = 10, maxval = 120, group = grpPb, tooltip = "Only gates the early leave sleeve. Powell OTE+KO can arm during this window (Dual38 — 10:30 A+ was blocked by this).")
i_pathBAwayPts = input.float(25.0, "Away from KO to count as left (pts)", minval = 5.0, step = 5.0, group = grpPb, tooltip = "Leave fires when price runs this far from 10:00 after a pierce — dump days leave SHORT without waiting for a reclaim close (that reclaim is the ENTRY, not the leave).")
i_retestMinRisk = input.float(10.0, "Powell: min stop size (pts)", minval = 2.0, step = 0.5, group = grpPb)
i_leaveMinRisk = input.float(6.0, "KO-leave: min stop size (pts)", minval = 2.0, step = 0.5, group = grpPb)
i_leavePrefer5 = input.bool(true, "KO-leave: prefer 5m RB (else 1m)", group = grpPb)
i_powellRequireOte = input.bool(true, "Powell: RB zone must overlap frozen-leg OTE", group = grpPb, tooltip = "Part of the live A+ stack with KO-in-zone.")
i_powellRequireKoStack = input.bool(true, "Powell: LIVE arm only OTE+KO stack", group = grpPb, tooltip = "ON (default) = 10:00 must sit inside the RB zone AND zone in OTE. OTE-without-KO never arms live (Jul 9 junk). Thursday control.")
i_powellShowEyes = input.bool(true, "Powell: show eyes plans (OTE / deep KO)", group = grpPb, tooltip = "Draw faint ENTRY/STOP/TP when an RB is in OTE without KO (or deep KO@RB) so history is not empty. Never alerts. Live still upgrades to OTE+KO when it appears.")
i_powellAllowDeepKo = input.bool(false, "Powell: also LIVE-arm RB@KO when KO deeper than OTE", group = grpPb, tooltip = "OFF by default. ON = live arm when KO sits in RB zone below the OTE floor. Keep OFF until studied — eyes still show it when Show eyes is ON.")
i_koScan = input.bool(true, "KO confluence scanner (eyes)", group = grpPb, tooltip = "Mark 1m RB / OB / CSD / IFVG and 5m FVG when their zone tags 10:00. Inventory — also feeds the KO·LTF sleeve count.")
i_koScanPad = input.float(12.0, "KO scanner pad (pts)", minval = 2.0, step = 1.0, group = grpPb, tooltip = "How close a structure zone must sit to 10:00 to count.")
i_koStack = input.bool(false, "KO·LTF sleeve (2nd trigger)", group = grpPb, tooltip = "OFF by default (Dual39) — was spraying SHADOW LOSS plans that stole the A+ 0.62 day. Scanner tags stay on for eyes.")
i_koStackMin = input.int(3, "KO·LTF: min distinct LTF tags", minval = 2, maxval = 5, group = grpPb, tooltip = "Count unique types among 1RB · 1OB · 1CISD · 1IFVG · 5FVG that tag KO (same side as leave). Default 3 = your circled cluster.")
i_koStackMinRisk = input.float(6.0, "KO·LTF: min stop size (pts)", minval = 2.0, step = 0.5, group = grpPb)
i_koStackNeedStruct = input.bool(true, "KO·LTF: require 1m RB or OB for entry", group = grpPb, tooltip = "Need a real stop geometry (RB or OB). CISD/IFVG/FVG only count toward density.")
i_powellGeom = input.string("1m RB wick", "Powell entry / stop geometry", options = ["1m RB wick", "0.62 / 0.705 (eyes study)"], group = grpPb, tooltip = "Dual46 DEFAULT = 1m RB wick (Powell teaching / Thursday control): LIMIT @ RB wick-start · STOP beyond RB extreme. Fib 0.62/0.705 stay on chart as eyes. The 0.62/0.705 option is study-only (wide stops — not the live A+ path).")
i_powellModel = input.string("Both", "Powell model vs leave", options = ["Continuation", "Judas reverse", "Both"], group = grpPb, tooltip = "Continuation = same side as leave (Thu control). Judas = opposite (dump leave → long the dump OTE). Both = arm whichever qualifies first.")
i_powellNeedRb = input.bool(true, "Require 1m RB for LIVE arm", group = grpPb, tooltip = "Always ON for A+. Live never arms on a naked fib tap.")
i_powellShowOte = input.bool(true, "Show frozen-leg 0.62 / 0.705 (eyes)", group = grpPb, tooltip = "Golden-pocket lines for confluence — compare to FibTool. Not used as stop.")
i_powellFibMinLeg = input.float(200.0, "Fib eyes: min leg height (pts)", minval = 80.0, step = 10.0, group = grpPb, tooltip = "Leg must be this tall before OTE lines / freeze count as a valid manip.")
i_powellFibMinRisk = input.float(18.0, "Fib-study geom: min 0.62→0.705 stop (pts)", minval = 8.0, step = 1.0, group = grpPb, tooltip = "Only applies if geometry = 0.62/0.705 study mode.")
i_fibFreezePull = input.float(25.0, "Fib: freeze after pullback (pts)", minval = 5.0, step = 5.0, group = grpPb, tooltip = "Once freeze is allowed, lock HI/LO after this pullback off the peak.")
i_fibFreezeMinMin = input.int(15, "Fib: min minutes after leave before freeze", minval = 5, maxval = 90, group = grpPb, tooltip = "Dual39: 15 so a 10:00 dump can freeze before the ~10:30 0.62 tap.")
i_fibMinLegPts = input.float(80.0, "Fib: min leg height before freeze (pts)", minval = 20.0, step = 5.0, group = grpPb, tooltip = "Second gate vs tiny 10:00 spikes. Leg must be at least this tall before freeze.")
i_fibScanStart = input.int(830, "Fib: scan morning from (HHMM)", minval = 0, maxval = 1000, group = grpPb, tooltip = "Earliest clock for morning context. Origin itself uses the lookback window below.")
i_fibLegLookback = input.int(120, "Fib: origin lookback (min)", minval = 30, maxval = 300, group = grpPb, tooltip = "Dual44: origin = HI/LO of the last N minutes before leave — not the entire 08:30→leave envelope (that glued unrelated swings).")
i_fibUseOpen = input.bool(true, "Fib: bias origin vs 09:30 open", group = grpPb, tooltip = "ON: also consider 09:30 open as an origin candidate extreme.")
i_fibManipMaxDist = input.float(220.0, "Fib: max manip HI/LO distance from KO (pts)", minval = 20.0, step = 10.0, group = grpPb, tooltip = "Morning extreme may seed fib tip if within this many pts of KO. Dual38 raised default so dump-day HI (~200pts above KO) can place KO in the OTE.")
i_showDil = input.bool(true, "Show Day IL (session swing low) — eyes only", group = grpPb, tooltip = "Display only. Not a Powell trigger.")
i_dilBounce = input.float(15.0, "Day IL confirm bounce (pts)", minval = 5.0, step = 5.0, group = grpPb, tooltip = "RTH low locks as Day IL after price trades this far above it.")
i_dilPivot = input.int(2, "Day IL pivot strength", minval = 1, maxval = 5, group = grpPb, tooltip = "Confirmed pivot-low lookback.")
i_retestMinAfterLeave = input.int(15, "Powell: min minutes after leave", minval = 5, maxval = 180, group = grpPb)
i_minWick1 = input.float(4.0, "Min 1m RB zone height (pts)", minval = 1.0, step = 0.5, group = grpPb, tooltip = "Zone = candle-1 body end → block-candle wick extreme.")
i_minWick5 = input.float(6.0, "Min 5m RB zone height (pts)", minval = 2.0, step = 0.5, group = grpPb)
i_rbSweepWick = input.bool(true, "RB: block wick must sweep candle-1 wick", group = grpPb, tooltip = "Bull: block low < candle-1 low (wick surpasses wick). Mirror for bear.")
i_showRbMarks = input.bool(false, "Mark every two-candle RB (dots)", group = grpPb, tooltip = "OFF by default — diagnostic only.")
i_pathBShowFib = input.bool(true, "Show fib LO / HI anchors only", group = grpPb)
i_pathBShowState = input.bool(true, "Show Path B status tag", group = grpPb)

i_showNwog = input.bool(true, "Show NWOG (Fri→Sun 18:00)", group = "Levels")
i_nwogMinPts = input.float(5.0, "Min NWOG size (pts)", minval = 0.5, step = 0.5, group = "Levels")
i_showKeyOpens = input.bool(true, "Show key opens (18:00 · midnight · 10:00)", group = "Levels")
i_keyOpenHistDays = input.int(30, "Key opens: keep N days of history", minval = 3, maxval = 120, group = "Levels", tooltip = "Each day's exact 10:00 and midnight open stays drawn so you can scroll history and check confluence. Caps object count.")
i_showPdhPdl = input.bool(true, "Show PDH / PDL", group = "Levels")
i_showPend = input.bool(true, "Show ENTRY / STOP / TP", group = "Levels")
i_showFillKpi = input.bool(true, "Show fill / outcome KPI", group = "Levels")
i_showSig = input.bool(true, "Show armed RB box", group = "Levels")
i_rbNoFill = input.bool(true, "RB box: border only", group = "Levels")

i_maxStopPts = input.float(40.0, "Max stop (pts)", minval = 2.0, step = 1.0, group = "Risk")
i_minStopPts = input.float(3.0, "Min stop (pts)", minval = 0.0, step = 0.5, group = "Risk")
i_stopBufPts = input.float(2.0, "Stop buffer (pts)", minval = 0.0, step = 0.25, group = "Risk")
i_rr = input.float(5.0, "Fixed target (R)", minval = 1.0, step = 0.25, group = "Risk", tooltip = "Dual46 default 1:5 — Powell control RR when stop is the tight RB extreme (~10–20pts).")
i_powellTp = input.string("Fixed R", "Powell take-profit", options = ["Fixed R", "Origin CE", "Origin high", "Leg CE", "Leg high"], group = "Risk", tooltip = "Default Fixed R. Origin shelves are optional study — often too far to fill.")
i_powellMinTpR = input.float(1.0, "Structure TP: min R", minval = 0.5, step = 0.25, group = "Risk", tooltip = "If Origin/Leg reward is closer than this many R, fall back to Fixed R.")
i_powellMaxTpR = input.float(2.5, "Structure TP: max R", minval = 1.0, step = 0.25, group = "Risk", tooltip = "If Origin/Leg reward is farther than this, fall back to Fixed R.")
i_powellMaxTpPts = input.float(100.0, "Max TP distance (pts)", minval = 20.0, step = 5.0, group = "Risk", tooltip = "Hard cap on Fixed R and structure targets. A 30pt stop × 5R = 150pts — unrealistic on Mondays / quiet sessions. Cap at 100 so wide-RB plans stay reachable (actual RR drops below 5).")
i_originMinPull = input.float(40.0, "Origin TP: min pull off freeze tip (pts)", minval = 10.0, step = 5.0, group = "Risk", tooltip = "Do not latch the origin shelf until price has pulled this far from the frozen tip. Stops TP sitting on the external high.")
i_intPivot = input.int(3, "Origin shelf: unused (kept for compat)", minval = 1, maxval = 8, group = "Risk", tooltip = "Legacy pivot input — Dual36 uses running max shelf after min pull.")

c_bear = input.color(#ef4444, "Bearish", group = "Colors")
c_bull = input.color(#7dd3fc, "Bullish", group = "Colors")
c_ce = input.color(#e2e8f0, "CE", group = "Colors")
c_limit = input.color(#f8fafc, "ENTRY", group = "Colors")
c_stop = input.color(#f87171, "STOP", group = "Colors")
c_tp = input.color(#34d399, "TP", group = "Colors")
c_pdh = input.color(#22c55e, "PDH", group = "Colors")
c_pdl = input.color(#ef4444, "PDL", group = "Colors")
c_win10 = input.color(#eab308, "10:00 wash", group = "Colors")
c_ko = input.color(#fbbf24, "10:00 KO line", group = "Colors")
c_midn = input.color(#f472b6, "Midnight open", group = "Colors")
c_1800 = input.color(#4ade80, "18:00 open", group = "Colors")

// Derived flags (after ALL inputs)
bool wantLeave = i_pathBSleeve == "KO-leave + KO-retest" or i_pathBSleeve == "KO-leave only"
bool wantRetest = i_pathBSleeve == "KO-leave + KO-retest" or i_pathBSleeve == "KO-retest only"
bool wantCont = i_powellModel == "Continuation" or i_powellModel == "Both"
bool wantJudas = i_powellModel == "Judas reverse" or i_powellModel == "Both"
bool autoBiasOn = i_biasMode == "Auto PDH/PDL draw"

// ─── Time ────────────────────────────────────────────────────────────────────
int nyHhmm = hour(time, "America/New_York") * 100 + minute(time, "America/New_York")
int nyMonth = month(time, "America/New_York")
int nyDow = dayofweek(time, "America/New_York")
int nyYmd = year(time, "America/New_York") * 10000 + nyMonth * 100 + dayofmonth(time, "America/New_York")
// CME daily bars roll ~18:00 ET — do NOT wipe Path B / plans on that. Calendar midnight only.
bool newCalDay = ta.change(nyYmd) != 0
// Session day (exchange "D") — PDH/PDL / day high-low only
bool newSessDay = ta.change(time("D", "America/New_York")) != 0
bool canPlace = nyHhmm < i_winEnd
bool mondayOk = not i_skipMonday or nyDow != dayofweek.monday
bool monthOk = not i_skipJulOct or (nyMonth != 7 and nyMonth != 10)
bool dayAllowed = mondayOk and monthOk

// Lookback bars for origin (minutes → chart bars)
float _tfMin = math.max(1.0, timeframe.in_seconds() / 60.0)
int fibLbBars = math.max(5, int(math.round(i_fibLegLookback / _tfMin)))
float lookHi = ta.highest(high, fibLbBars)
float lookLo = ta.lowest(low, fibLbBars)

// ─── Levels ──────────────────────────────────────────────────────────────────
float prevDayHigh = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
float prevDayLow = request.security(syminfo.tickerid, "D", low[1], lookahead = barmerge.lookahead_on)

// Auto PDH/PDL draw (SOP §3) — always computed so eyes can A/B vs manual
var int dayDraw = 0
if newCalDay
    dayDraw := 0
if not na(prevDayHigh) and high > prevDayHigh and close < prevDayHigh
    dayDraw := -1
if not na(prevDayLow) and low < prevDayLow and close > prevDayLow
    dayDraw := 1

bool biasOkShort = i_biasMode != "Long only" and (not autoBiasOn or dayDraw <= 0)
bool biasOkLong = i_biasMode != "Short only" and (not autoBiasOn or dayDraw >= 0)

var float curDayHigh = na
var float curDayLow = na
var int curDayHighBar = na
var int curDayLowBar = na
var float pdhLvl = na
var float pdlLvl = na
var int pdhOriginBar = na
var int pdlOriginBar = na
var float ko1000 = na
var float openMidnight = na
var float open1800 = na
var int openMidnightBar = na
var int open1800Bar = na
var int ko1000Bar = na
var float nwogFriClose = na
var int nwogGapTime = na
var float nwogTop = na
var float nwogBot = na

if newSessDay
    pdhLvl := curDayHigh
    pdlLvl := curDayLow
    pdhOriginBar := curDayHighBar
    pdlOriginBar := curDayLowBar
    curDayHigh := high
    curDayLow := low
    curDayHighBar := bar_index
    curDayLowBar := bar_index
else
    if na(curDayHigh) or high >= curDayHigh
        curDayHigh := high
        curDayHighBar := bar_index
    if na(curDayLow) or low <= curDayLow
        curDayLow := low
        curDayLowBar := bar_index

// Key opens — calendar NY (10:00 / midnight wipe at calendar day; 18:00 persists into next RTH)
if newCalDay
    ko1000 := na
    ko1000Bar := na
    openMidnight := open
    openMidnightBar := bar_index
bool open1800Print = nyHhmm >= 1800 and nyHhmm[1] < 1800
if open1800Print
    open1800 := open
    open1800Bar := bar_index
bool ko1000Print = nyHhmm >= 1000 and nyHhmm[1] < 1000
bool ko1000Fallback = nyHhmm >= 1000 and na(ko1000)
if ko1000Print or ko1000Fallback
    ko1000 := open
    ko1000Bar := bar_index

bool isFri = nyDow == dayofweek.friday
bool isSun = nyDow == dayofweek.sunday
bool isMon = nyDow == dayofweek.monday
if isFri
    nwogFriClose := close
bool nwogSunOpenBar = isSun and nyHhmm >= 1800 and nyHhmm[1] < 1800
bool nwogMonFallback = isMon and nyHhmm >= 930 and nyHhmm[1] < 930

// ─── RB packs (Dual29 two-candle Powell spec) ────────────────────────────────
// BULL RB: candle A (bar[2]) BEARISH → candle B (bar[1]) BULLISH block.
//   B's lower wick sweeps A's wick low (toggle) and extends past A's body end.
//   Zone = A body end (wick-start) → B low (extreme). Height ≥ minW.
// BEAR RB: exact mirror (A bullish → B bearish block, upper wick).
// A lone long-wick candle is NEVER an RB (that was the Dual13/26 bug class).
// Tuple shape unchanged: [bear, bull, extremeHi, extremeLo, wsBear, wsBull].
f_pb1Pack(float minW) =>
    float oA = open[2]
    float cA = close[2]
    float lA = low[2]
    float hA = high[2]
    float oB = open[1]
    float hB = high[1]
    float lB = low[1]
    float cB = close[1]
    float bullWs = math.min(oA, cA)
    float bearWs = math.max(oA, cA)
    bool sweepLoOk = not i_rbSweepWick or lB < lA
    bool sweepHiOk = not i_rbSweepWick or hB > hA
    bool bull = cA < oA and cB > oB and sweepLoOk and lB < bullWs and (bullWs - lB) >= minW
    bool bear = cA > oA and cB < oB and sweepHiOk and hB > bearWs and (hB - bearWs) >= minW
    [bear, bull, hB, lB, bearWs, bullWs]

[b1s, u1s, h1s, l1s, wsB1s, wsU1s] = request.security(syminfo.tickerid, "1", f_pb1Pack(i_minWick1), barmerge.gaps_off, barmerge.lookahead_off)
[b5s, u5s, h5s, l5s, wsB5s, wsU5s] = request.security(syminfo.tickerid, "5", f_pb1Pack(i_minWick5), barmerge.gaps_off, barmerge.lookahead_off)
int t1sec = request.security(syminfo.tickerid, "1", time, barmerge.gaps_off, barmerge.lookahead_off)
int t5sec = request.security(syminfo.tickerid, "5", time, barmerge.gaps_off, barmerge.lookahead_off)
int t1Closed = request.security(syminfo.tickerid, "1", time[1], barmerge.gaps_off, barmerge.lookahead_off)
int t5Closed = request.security(syminfo.tickerid, "5", time[1], barmerge.gaps_off, barmerge.lookahead_off)
bool new1Bar = ta.change(t1sec) != 0
bool new5Bar = ta.change(t5sec) != 0

bool on1m = timeframe.period == "1"
bool on5m = timeframe.period == "5"
[b1c, u1c, h1c, l1c, wsB1c, wsU1c] = f_pb1Pack(i_minWick1)
bool b1 = on1m ? b1c : b1s
bool u1 = on1m ? u1c : u1s
float h1 = on1m ? h1c : h1s
float l1 = on1m ? l1c : l1s
float wsB1 = on1m ? wsB1c : wsB1s
float wsU1 = on1m ? wsU1c : wsU1s
int t1Rb = on1m ? time[1] : t1Closed
int t5Rb = on5m ? time[1] : t5Closed
bool trig1 = barstate.isconfirmed and (on1m or new1Bar)
bool trig5 = barstate.isconfirmed and (on5m or new5Bar)
[b5c, u5c, h5c, l5c, wsB5c, wsU5c] = f_pb1Pack(i_minWick5)
bool b5 = on5m ? b5c : b5s
bool u5 = on5m ? u5c : u5s
float h5 = on5m ? h5c : h5s
float l5 = on5m ? l5c : l5s
float wsB5 = on5m ? wsB5c : wsB5s
float wsU5 = on5m ? wsU5c : wsU5s

// LTF confluence packs (KO scanner — eyes only, never arm)
f_msLtfPack() =>
    bool prevBull = close[1] > open[1]
    bool prevBear = close[1] < open[1]
    bool cisdBear = prevBull and close < open[1]
    bool cisdBull = prevBear and close > open[1]
    bool ifvgBear = low[1] > high[3] and close < high[3]
    bool ifvgBull = high[1] < low[3] and close > low[3]
    float iTop = ifvgBear ? low[1] : ifvgBull ? low[3] : na
    float iBot = ifvgBear ? high[3] : ifvgBull ? high[1] : na
    [cisdBear, cisdBull, ifvgBear, ifvgBull, iTop, iBot]

f_obPack() =>
    bool bearOb = close[1] > open[1] and close < open and close < low[1]
    bool bullOb = close[1] < open[1] and close > open and close > high[1]
    float oTop = high[1]
    float oBot = low[1]
    [bearOb, bullOb, oTop, oBot]

f_fvgPack() =>
    float h3 = high[3]
    float l3 = low[3]
    float h1b = high[1]
    float l1b = low[1]
    bool bull = l1b > h3
    bool bear = h1b < l3
    float top = bull ? l1b : bear ? l3 : na
    float bot = bull ? h3 : bear ? h1b : na
    [bear, bull, top, bot]

[cisd1sB, cisd1sU, ifvg1sB, ifvg1sU, ifvg1sTop, ifvg1sBot] = request.security(syminfo.tickerid, "1", f_msLtfPack(), barmerge.gaps_off, barmerge.lookahead_off)
[ob1sB, ob1sU, ob1sTop, ob1sBot] = request.security(syminfo.tickerid, "1", f_obPack(), barmerge.gaps_off, barmerge.lookahead_off)
[fvg5sB, fvg5sU, fvg5sTop, fvg5sBot] = request.security(syminfo.tickerid, "5", f_fvgPack(), barmerge.gaps_off, barmerge.lookahead_off)
[cisd1cB, cisd1cU, ifvg1cB, ifvg1cU, ifvg1cTop, ifvg1cBot] = f_msLtfPack()
[ob1cB, ob1cU, ob1cTop, ob1cBot] = f_obPack()
[fvg5cB, fvg5cU, fvg5cTop, fvg5cBot] = f_fvgPack()
bool cisd1B = on1m ? cisd1cB : cisd1sB
bool cisd1U = on1m ? cisd1cU : cisd1sU
bool ifvg1B = on1m ? ifvg1cB : ifvg1sB
bool ifvg1U = on1m ? ifvg1cU : ifvg1sU
