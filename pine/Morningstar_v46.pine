    pbLbl1 := na
    pbStateLbl := na
    biasEyesLbl := na

// Day IL / Day IH — Dual13 bounce + pivot (eyes-only display; NOT a Powell trigger)
bool rthDil = nyHhmm >= 930 and nyHhmm < i_flatTime
float pivLo = ta.pivotlow(low, i_dilPivot, i_dilPivot)
float pivHi = ta.pivothigh(high, i_dilPivot, i_dilPivot)
if rthDil
    if na(dilRaw) or low < dilRaw
        dilRaw := low
        dilRawTime := time
    if na(dihRaw) or high > dihRaw
        dihRaw := high
        dihRawTime := time
    if not na(dilRaw) and high >= dilRaw + i_dilBounce
        if na(dilPx) or dilRaw < dilPx
            dilPx := dilRaw
            dilTag := "Day IL"
    if not na(dihRaw) and low <= dihRaw - i_dilBounce
        if na(dihPx) or dihRaw > dihPx
            dihPx := dihRaw
    if not na(pivLo)
        if na(dilPx) or pivLo < dilPx
            dilPx := pivLo
            dilTag := "Day IL"
    if not na(pivHi)
        if na(dihPx) or pivHi > dihPx
            dihPx := pivHi

// Morning extremes 09:30 → leave (session context)
if nyHhmm >= 930 and not pbLeft and nyHhmm < i_flatTime
    if na(amLo) or low < amLo
        amLo := low
        amLoBar := bar_index
    if na(amHi) or high > amHi
        amHi := high
        amHiBar := bar_index

// 09:30 RTH open print
if nyHhmm >= 930 and na(open930)
    open930 := open

// Dual43: scan biggest morning HI/LO from i_fibScanStart until leave (8:45 / 9:25 / open / post-10 Judas all OK)
if nyHhmm >= i_fibScanStart and not pbLeft and nyHhmm < i_flatTime
    if na(scanLo) or low < scanLo
        scanLo := low
        scanLoBar := bar_index
    if na(scanHi) or high > scanHi
        scanHi := high
        scanHiBar := bar_index

// ─── Path B ──────────────────────────────────────────────────────────────────
// Leave: two-candle RB@KO. Powell: fresh 1m two-candle RB on the OTE pullback of the FROZEN manip leg.
bool pbOn = i_pathB and not na(ko1000) and nyHhmm >= 1000 and (nyHhmm < i_winEnd or pbLeft or eArmed or oArmed)
bool hasAway = false
bool inLeaveWin = false
bool longEnoughAfterLeave = false
bool pbStopFail = false
bool pbOteNoKo = false
int leaveDir = 0
float leaveWs = na
float leaveCe = na
float leaveEx = na
int leaveRbTime = na
string leaveTf = "5RB"
if pbOn
    if na(pbHi) or high >= pbHi
        pbHi := high
        pbHiBar := bar_index
    if na(pbLo) or low <= pbLo
        pbLo := low
        pbLoBar := bar_index
    if high > ko1000
        pbPierceAbove := true
        pbManip := true
        if na(pbPierceHi) or high > pbPierceHi
            pbPierceHi := high
            pbPierceHiBar := bar_index
    if low < ko1000
        pbPierceBelow := true
        pbManip := true
        if na(pbPierceLo) or low < pbPierceLo
            pbPierceLo := low
            pbPierceLoBar := bar_index
    if pbManip and not pbLeft and barstate.isconfirmed and canPlace
        // Dual44: AWAY-only leave. Reclaim @ KO is the ENTRY, not the leave trigger.
        bool awayDown = pbPierceBelow and close < ko1000 and (ko1000 - low) >= i_pathBAwayPts
        bool awayUp = pbPierceAbove and close > ko1000 and (high - ko1000) >= i_pathBAwayPts
        if awayDown
            pbLeft := true
            pbDir := -1
            pbLeaveBar := bar_index
            pbLeaveTime := time
            pbAway := 0.0
            pbAwayPeakBar := na
            pbAwayPeakTime := na
            pbReturned := false
            pbFibInvalid := false
            // Dual44 SHORT leave: ORIGIN = lookback high (not all-morning glue). TIP = leave low.
            float seedHi = lookHi
            int seedHiBar = bar_index
            if i_fibUseOpen and not na(open930) and (na(seedHi) or open930 > seedHi)
                seedHi := open930
            if na(seedHi)
                seedHi := high
            float seedLo = low
            int seedLoBar = bar_index
            if not na(pbPierceLo) and pbPierceLo < seedLo
                seedLo := pbPierceLo
                seedLoBar := pbPierceLoBar
            pbFibHi := seedHi
            pbFibLo := seedLo
            pbFibHiBar := seedHiBar
            pbFibLoBar := seedLoBar
            pbFibHiBody := math.max(open, close)
            pbFibLoBody := math.min(open, close)
            pbIntHi := na
            pbIntHiBody := na
            pbIntLo := na
            pbIntLoBody := na
            pbFibFrozen := false
            pbOriginArmed := false
        else if awayUp
            pbLeft := true
            pbDir := 1
            pbLeaveBar := bar_index
            pbLeaveTime := time
            pbAway := 0.0
            pbAwayPeakBar := na
            pbAwayPeakTime := na
            pbReturned := false
            pbFibInvalid := false
            // Dual44 LONG leave: ORIGIN = lookback low. TIP = leave high.
            float seedLo = lookLo
            int seedLoBar = bar_index
            if i_fibUseOpen and not na(open930) and (na(seedLo) or open930 < seedLo)
                seedLo := open930
            if na(seedLo)
                seedLo := low
            float seedHi = high
            int seedHiBar = bar_index
            if not na(pbPierceHi) and pbPierceHi > seedHi
                seedHi := pbPierceHi
                seedHiBar := pbPierceHiBar
            pbFibLo := seedLo
            pbFibHi := seedHi
            pbFibLoBar := seedLoBar
            pbFibHiBar := seedHiBar
            pbFibHiBody := math.max(open, close)
            pbFibLoBody := math.min(open, close)
            pbIntHi := na
            pbIntHiBody := na
            pbIntLo := na
            pbIntLoBody := na
            pbFibFrozen := false
            pbOriginArmed := false
    if pbLeft
        // Dual44: ORIGIN never moves after leave. Only TIP extends. Break of origin voids the leg.
        bool minsOk = not na(pbLeaveTime) and (time - pbLeaveTime) >= i_fibFreezeMinMin * 60 * 1000
        float legH = not na(pbFibHi) and not na(pbFibLo) ? pbFibHi - pbFibLo : 0.0
        bool legOk = legH >= i_fibMinLegPts
        bool awayForFreeze = pbAway >= i_pathBAwayPts
        bool freezeAllowed = minsOk and legOk and awayForFreeze and not pbFibInvalid
        if pbDir == 1
            // Broke below origin → not a valid up-leg (knife-catch void)
            if not na(pbFibLo) and low < pbFibLo - syminfo.mintick
                pbFibInvalid := true
            if not pbFibFrozen and not pbFibInvalid and high >= pbFibHi
                pbFibHi := high
                pbFibHiBar := bar_index
                pbFibHiBody := math.max(open, close)
            if not pbFibFrozen and freezeAllowed and not na(pbFibHi) and pbFibHi - low >= i_fibFreezePull
                pbFibFrozen := true
        if pbDir == -1
            // Broke above origin → dump leg failed
            if not na(pbFibHi) and high > pbFibHi + syminfo.mintick
                pbFibInvalid := true
            if not pbFibFrozen and not pbFibInvalid and low <= pbFibLo
                pbFibLo := low
                pbFibLoBar := bar_index
                pbFibLoBody := math.min(open, close)
            if not pbFibFrozen and freezeAllowed and not na(pbFibLo) and high - pbFibLo >= i_fibFreezePull
                pbFibFrozen := true
        // Origin shelf: wait for a real pull off the freeze tip, THEN latch the highest bounce
        // (not the tip itself, not later micro pivots into the OTE entry).
        if pbFibFrozen and not pbFibInvalid and (not oArmed or oKpi == "eyes") and barstate.isconfirmed
            if pbDir == 1 and not na(pbFibHi)
                if not pbOriginArmed and pbFibHi - low >= i_originMinPull
                    pbOriginArmed := true
                if pbOriginArmed and high < pbFibHi - syminfo.mintick
                    if na(pbIntHi) or high > pbIntHi
                        pbIntHi := high
                        pbIntHiBody := math.max(open, close)
            if pbDir == -1 and not na(pbFibLo)
                if not pbOriginArmed and high - pbFibLo >= i_originMinPull
                    pbOriginArmed := true
                if pbOriginArmed and low > pbFibLo + syminfo.mintick
                    if na(pbIntLo) or low < pbIntLo
                        pbIntLo := low
                        pbIntLoBody := math.min(open, close)
        if not na(pbLeaveBar) and bar_index > pbLeaveBar
            float awayNow = pbDir == 1 ? high - ko1000 : pbDir == -1 ? ko1000 - low : 0.0
            if awayNow > pbAway
                pbAway := awayNow
                pbAwayPeakBar := bar_index
                pbAwayPeakTime := time
            float retPad = i_pathBAlign
            if pbAway >= i_pathBAwayPts and not na(pbAwayPeakTime) and time > pbAwayPeakTime
                if pbDir == 1 and low <= ko1000 + retPad
                    pbReturned := true
                if pbDir == -1 and high >= ko1000 - retPad
                    pbReturned := true

    hasAway := pbAway >= i_pathBAwayPts
    inLeaveWin := not na(pbLeaveTime) and (time - pbLeaveTime) <= i_leaveWinMin * 60 * 1000

    bool nearKo5B = f_nearKo(h5, ko1000) or f_nearKo(wsB5, ko1000) or f_nearKoBand(h5, wsB5, ko1000)
    bool nearKo5U = f_nearKo(l5, ko1000) or f_nearKo(wsU5, ko1000) or f_nearKoBand(wsU5, l5, ko1000)
    bool nearKo1B = f_nearKo(h1, ko1000) or f_nearKo(wsB1, ko1000) or f_nearKoBand(h1, wsB1, ko1000)
    bool nearKo1U = f_nearKo(l1, ko1000) or f_nearKo(wsU1, ko1000) or f_nearKoBand(wsU1, l1, ko1000)

    // Leave sleeve: two-candle RB @ KO only (u5/b5/u1/b1)
    if pbLeft and barstate.isconfirmed
        if pbDir == 1
            if i_leavePrefer5 and trig5 and u5 and nearKo5U
                leaveDir := 1
                leaveWs := wsU5
                leaveEx := l5
                leaveCe := (l5 + wsU5) * 0.5
                leaveRbTime := t5Rb
                leaveTf := "5RB"
            else if trig1 and u1 and nearKo1U
                leaveDir := 1
                leaveWs := wsU1
                leaveEx := l1
                leaveCe := (l1 + wsU1) * 0.5
                leaveRbTime := t1Rb
                leaveTf := "1RB"
        if pbDir == -1
            if i_leavePrefer5 and trig5 and b5 and nearKo5B
                leaveDir := -1
                leaveWs := wsB5
                leaveEx := h5
                leaveCe := (h5 + wsB5) * 0.5
                leaveRbTime := t5Rb
                leaveTf := "5RB"
            else if trig1 and b1 and nearKo1B
                leaveDir := -1
                leaveWs := wsB1
                leaveEx := h1
                leaveCe := (h1 + wsB1) * 0.5
                leaveRbTime := t1Rb
                leaveTf := "1RB"

    longEnoughAfterLeave := not na(pbLeaveTime) and (time - pbLeaveTime) >= i_retestMinAfterLeave * 60 * 1000
    // Dual38: leave window only blocks the early leave sleeve — Powell A+ can arm at ~10:30
    bool powellWindow = pbLeft and hasAway and longEnoughAfterLeave and barstate.isconfirmed

    // Powell OTE of the FROZEN leg. leaveDir (pbDir) defines the leg; tradeDir may reverse (Judas).
    // Dump leave (pbDir=-1): leg HI→LO. Cont short @ LO+0.62; Judas long @ HI−0.62.
    // Rally leave (pbDir=+1): leg LO→HI. Cont long @ HI−0.62; Judas short @ LO+0.62.
    float pbRangeF = not na(pbFibHi) and not na(pbFibLo) ? pbFibHi - pbFibLo : na
    float cont62 = na
    float cont705 = na
    float judas62 = na
    float judas705 = na
    float oteLoPx = na
    float oteHiPx = na
    float fib62Px = na
    float fib705Px = na
    if pbFibFrozen and not pbFibInvalid and not na(pbRangeF) and pbRangeF > 0
        float up62 = pbFibHi - pbRangeF * 0.62
        float up705 = pbFibHi - pbRangeF * 0.705
        float dn62 = pbFibLo + pbRangeF * 0.62
        float dn705 = pbFibLo + pbRangeF * 0.705
        if pbDir == 1
            cont62 := up62
            cont705 := up705
            judas62 := dn62
            judas705 := dn705
            oteLoPx := pbFibHi - pbRangeF * 0.79
            oteHiPx := up62
        if pbDir == -1
            cont62 := dn62
            cont705 := dn705
            judas62 := up62
            judas705 := up705
            oteLoPx := dn62
            oteHiPx := pbFibLo + pbRangeF * 0.79
        // Default plot / RB-wick path follows Continuation levels
        fib62Px := cont62
        fib705Px := cont705

    bool leaveBiasOk = (leaveDir == -1 and biasOkShort) or (leaveDir == 1 and biasOkLong)
    bool singleSlotLock = i_oneTradeDay and i_pathBSleeve != "KO-leave + KO-retest" and (eArmed or oArmed or kArmed)
    bool leaveTick = leaveTf == "5RB" ? trig5 : trig1

    // KO-leave — teaching RB@KO soon after leave (1m fallback if 5m stop too small)
    if wantLeave and not eArmed and canPlace and not singleSlotLock and leaveBiasOk and leaveDir != 0 and leaveTick and inLeaveWin
        float useWs = leaveWs
        float useCe = leaveCe
        float useEx = leaveEx
        int useDir = leaveDir
        string useTf = leaveTf
        int useRbT = leaveRbTime
        [ePlan0, sPlan0] = f_plan(useWs, useCe, useEx, useDir == -1)
        float entryPx = ePlan0
        float stopPx = sPlan0
        float riskPts0 = na(entryPx) ? na : math.abs(stopPx - entryPx)
        if (na(entryPx) or riskPts0 < i_leaveMinRisk) and trig1 and pbDir == 1 and u1 and nearKo1U
            useWs := wsU1
            useCe := (l1 + wsU1) * 0.5
            useEx := l1
            useDir := 1
            useTf := "1RB"
            useRbT := t1Rb
            [ePlan1, sPlan1] = f_plan(useWs, useCe, useEx, false)
            entryPx := ePlan1
            stopPx := sPlan1
            riskPts0 := na(entryPx) ? na : math.abs(stopPx - entryPx)
        if (na(entryPx) or riskPts0 < i_leaveMinRisk) and trig1 and pbDir == -1 and b1 and nearKo1B
            useWs := wsB1
            useCe := (h1 + wsB1) * 0.5
            useEx := h1
            useDir := -1
            useTf := "1RB"
            useRbT := t1Rb
            [ePlan2, sPlan2] = f_plan(useWs, useCe, useEx, true)
            entryPx := ePlan2
            stopPx := sPlan2
            riskPts0 := na(entryPx) ? na : math.abs(stopPx - entryPx)
        if na(entryPx) or riskPts0 < i_leaveMinRisk
            pbStopFail := true
        else
            eArmed := true
            eDir := useDir
            eTime := time
            eRbTime := not na(useRbT) ? useRbT : time
            eWs := useWs
            eCe := useCe
            eEx := useEx
            eEntry := entryPx
            eStop := stopPx
            eTp := f_fixedTp(entryPx, riskPts0, useDir)
            eTag := "leave · " + useTf
            eFill := 1
            eEndTime := na
            eKpi := "live"
            manualReady := true

    // Powell — Dual46: LIVE = 1m RB wick entry/stop. Fib 0.62/0.705 = eyes / optional study only.
    bool fibStudyMode = i_powellGeom == "0.62 / 0.705 (eyes study)"
    if wantRetest and canPlace and not singleSlotLock and powellWindow and not pbFibInvalid
        bool canUpgrade = not oArmed or oKpi == "eyes"
        // Fib-study: mark OTE taps for eyes — NEVER live-arm off 0.705 (wide stop / broken RR)
        if fibStudyMode and pbFibFrozen and canUpgrade and not oArmed and barstate.isconfirmed and i_powellShowEyes
            bool tapCont = wantCont and not na(cont62) and (pbDir == 1 ? low <= cont62 + i_powellKoTol : high >= cont62 - i_powellKoTol)
            bool tapJudas = wantJudas and not na(judas62) and (-pbDir == 1 ? low <= judas62 + i_powellKoTol : high >= judas62 - i_powellKoTol)
            if tapCont or tapJudas
                pbOteNoKo := true
        // LIVE path — always RB wick geometry (Thursday control / Powell teaching)
        if trig1
            int pDir = 0
            float pWs = na
            float pEx = na
            // Cont: RB same side as leave. Judas: opposite RB.
            if wantCont and pbDir == 1 and u1
                pDir := 1
                pWs := wsU1
                pEx := l1
            if wantCont and pbDir == -1 and b1 and pDir == 0
                pDir := -1
                pWs := wsB1
                pEx := h1
            if wantJudas and pbDir == -1 and u1 and pDir == 0
                pDir := 1
                pWs := wsU1
                pEx := l1
            if wantJudas and pbDir == 1 and b1 and pDir == 0
                pDir := -1
                pWs := wsB1
                pEx := h1
            if pDir != 0
                float pZHi = math.max(pWs, pEx)
                float pZLo = math.min(pWs, pEx)
                bool zoneInOte = not na(oteLoPx) and pZLo <= oteHiPx and pZHi >= oteLoPx
                bool koInZone = f_koInRbZone(pZHi, pZLo, ko1000)
                bool koDeeperThanOte = false
                if not na(ko1000) and not na(oteLoPx)
                    koDeeperThanOte := pDir == 1 ? ko1000 < oteLoPx - i_powellKoTol : ko1000 > oteHiPx + i_powellKoTol
                bool pBiasOk = (pDir == 1 and biasOkLong) or (pDir == -1 and biasOkShort)
                bool deferOte = i_powellWaitDeepKo and koDeeperThanOte and not koInZone
                bool oteOk = (not i_powellRequireOte or zoneInOte) and not deferOte
                bool stackOk = i_powellRequireKoStack ? (zoneInOte and koInZone) : oteOk
                bool armDeepLive = i_powellAllowDeepKo and koInZone and koDeeperThanOte
                bool armLive = stackOk or armDeepLive
                bool eyesOte = zoneInOte and not koInZone and not deferOte
                bool eyesDeep = koInZone and koDeeperThanOte and not zoneInOte
                bool eyesCand = i_powellShowEyes and (eyesOte or eyesDeep)
                bool doLive = pBiasOk and armLive and canUpgrade
                bool doEyes = pBiasOk and eyesCand and not armLive and canUpgrade
                if doLive or doEyes
                    float pCe = (pWs + pEx) * 0.5
                    [pEntry, pStop] = f_plan(pWs, pCe, pEx, pDir == -1)
                    float pRisk = na(pEntry) ? na : math.abs(pStop - pEntry)
                    if na(pEntry) or pRisk < i_retestMinRisk
                        pbStopFail := true
                    else
                        bool nwogGrade = not na(nwogTop) and not na(nwogBot) and pZLo <= nwogTop + i_pathBAlign and pZHi >= nwogBot - i_pathBAlign
                        string modelTag = pDir == pbDir ? "Cont" : "Judas"
                        string grade = zoneInOte and koInZone ? "OTE+KO" : koInZone ? "KO" : zoneInOte ? "OTE" : "—"
                        if nwogGrade
                            grade := grade + "+NWOG"
                        oArmed := true
                        oDir := pDir
                        oTime := time
                        oRbTime := t1Rb
                        oEndTime := na
                        oWs := pWs
                        oCe := pCe
                        oEx := pEx
                        oEntry := pEntry
                        oStop := pStop
                        float legEx = pDir == 1 ? pbFibHi : pbFibLo
                        float legBody = pDir == 1 ? pbFibHiBody : pbFibLoBody
                        float intEx = pDir == 1 ? pbIntHi : pbIntLo
                        float intBody = pDir == 1 ? pbIntHiBody : pbIntLoBody
                        [pTp, tpTag] = f_powellTp(pEntry, pStop, pDir, intEx, intBody, legEx, legBody)
                        oTp := pTp
                        oTag := "Powell · " + modelTag + " · 1RB · " + grade
                        if str.length(tpTag) > 0
                            oTag := oTag + " · " + tpTag
                        oFill := 1
                        oKpi := doLive ? "live" : "eyes"
                        oPlanLeft := na
                        if doLive
                            manualReady := true
                        if eyesOte and not doLive
                            pbOteNoKo := true
                else if pBiasOk and eyesOte
                    pbOteNoKo := true

    // KO·LTF — Dual37 2nd trigger (OFF by default Dual39).
    if i_koStack and pbLeft and hasAway and not na(ko1000) and barstate.isconfirmed
        float padK = i_koScanPad
        if trig1
            if u1 and f_zoneNearKo(math.max(wsU1, l1), math.min(wsU1, l1), ko1000, padK)
                kBullRb := true
                kBullRbWs := wsU1
                kBullRbEx := l1
                kBullRbT := t1Rb
            if b1 and f_zoneNearKo(math.max(wsB1, h1), math.min(wsB1, h1), ko1000, padK)
                kBearRb := true
                kBearRbWs := wsB1
                kBearRbEx := h1
                kBearRbT := t1Rb
            if ob1U and f_zoneNearKo(ob1Top, ob1Bot, ko1000, padK)
                kBullOb := true
                kBullObTop := ob1Top
                kBullObBot := ob1Bot
            if ob1B and f_zoneNearKo(ob1Top, ob1Bot, ko1000, padK)
                kBearOb := true
                kBearObTop := ob1Top
                kBearObBot := ob1Bot
            if cisd1U and math.abs(close - ko1000) <= padK
                kBullCisd := true
            if cisd1B and math.abs(close - ko1000) <= padK
                kBearCisd := true
            if ifvg1U and f_zoneNearKo(ifvg1Top, ifvg1Bot, ko1000, padK)
                kBullIfvg := true
            if ifvg1B and f_zoneNearKo(ifvg1Top, ifvg1Bot, ko1000, padK)
                kBearIfvg := true
        if trig5
            if fvg5U and f_zoneNearKo(fvg5Top, fvg5Bot, ko1000, padK)
                kBullFvg5 := true
            if fvg5B and f_zoneNearKo(fvg5Top, fvg5Bot, ko1000, padK)
                kBearFvg5 := true
        int bullN = (kBullRb ? 1 : 0) + (kBullOb ? 1 : 0) + (kBullCisd ? 1 : 0) + (kBullIfvg ? 1 : 0) + (kBullFvg5 ? 1 : 0)
        int bearN = (kBearRb ? 1 : 0) + (kBearOb ? 1 : 0) + (kBearCisd ? 1 : 0) + (kBearIfvg ? 1 : 0) + (kBearFvg5 ? 1 : 0)
        bool touchingKo = low <= ko1000 + padK and high >= ko1000 - padK
        // Spend untapped window if we left the KO band after a dense first touch without arming
        if not kArmed and touchingKo[1] and not touchingKo and (bullN >= i_koStackMin or bearN >= i_koStackMin)
            kSpent := true
        if not kArmed and not kSpent and canPlace and not singleSlotLock and touchingKo and trig1
            int kDirTry = 0
            float kWsTry = na
            float kExTry = na
            int kTTry = na
            string kStruct = "—"
            int nUse = 0
            if pbDir == 1 and bullN >= i_koStackMin and biasOkLong
                nUse := bullN
                if kBullRb and not na(kBullRbWs) and f_koInRbZone(math.max(kBullRbWs, kBullRbEx), math.min(kBullRbWs, kBullRbEx), ko1000)
                    kDirTry := 1
                    kWsTry := kBullRbWs
                    kExTry := kBullRbEx
                    kTTry := kBullRbT
                    kStruct := "1RB"
                else if kBullOb and not na(kBullObTop) and f_koInRbZone(kBullObTop, kBullObBot, ko1000)
                    kDirTry := 1
                    kWsTry := kBullObTop
                    kExTry := kBullObBot
                    kTTry := time
                    kStruct := "1OB"
            if pbDir == -1 and bearN >= i_koStackMin and biasOkShort
                nUse := bearN
                if kBearRb and not na(kBearRbWs) and f_koInRbZone(math.max(kBearRbWs, kBearRbEx), math.min(kBearRbWs, kBearRbEx), ko1000)
                    kDirTry := -1
                    kWsTry := kBearRbWs
                    kExTry := kBearRbEx
                    kTTry := kBearRbT
                    kStruct := "1RB"
                else if kBearOb and not na(kBearObTop) and f_koInRbZone(kBearObTop, kBearObBot, ko1000)
                    kDirTry := -1
                    kWsTry := kBearObBot
                    kExTry := kBearObTop
                    kTTry := time
                    kStruct := "1OB"
            if kDirTry != 0 and not na(kWsTry) and not na(kExTry)
                float kCeTry = (kWsTry + kExTry) * 0.5
                [kEnt, kStp] = f_plan(kWsTry, kCeTry, kExTry, kDirTry == -1)
                float kRisk = na(kEnt) ? na : math.abs(kStp - kEnt)
                if not na(kEnt) and kRisk >= i_koStackMinRisk
                    string bits = ""
                    if pbDir == 1
                        bits := (kBullRb ? "RB " : "") + (kBullOb ? "OB " : "") + (kBullCisd ? "CISD " : "") + (kBullIfvg ? "IFVG " : "") + (kBullFvg5 ? "5FVG" : "")
                    else
                        bits := (kBearRb ? "RB " : "") + (kBearOb ? "OB " : "") + (kBearCisd ? "CISD " : "") + (kBearIfvg ? "IFVG " : "") + (kBearFvg5 ? "5FVG" : "")
                    kArmed := true
                    kSpent := true
                    kDir := kDirTry
                    kTime := time
                    kRbTime := kTTry
                    kEndTime := na
                    kWs := kWsTry
                    kCe := kCeTry
                    kEx := kExTry
                    kEntry := kEnt
                    kStop := kStp
                    kTp := f_fixedTp(kEnt, kRisk, kDirTry)
                    kTag := "KO·LTF · " + str.tostring(nUse) + " · " + kStruct + " · " + bits
                    kFill := 1
                    kKpi := "live"
                    kPlanLeft := na
                    manualReady := true

// Status — short. Powell pipeline: leg growing → frozen (→P) → armed. K = KO·LTF.
if not i_pathB
    pbState := "off"
else if kArmed and (eArmed or oArmed)
    pbState := "K+" + (oArmed ? "P" : "L")
else if kArmed
    pbState := kKpi == "WIN" or kKpi == "LOSS" ? "K " + kKpi : "K"
else if eArmed and oArmed
    pbState := "L+P"
else if eArmed
    string eBit = eKpi == "WIN" or eKpi == "LOSS" ? "L " + eKpi : "L"
    if not wantRetest
        pbState := eBit
    else
        pbState := eBit + (pbFibFrozen ? "|→P" : "|leg")
else if oArmed
    pbState := oKpi == "eyes" ? "P eyes" : oKpi == "WIN" or oKpi == "LOSS" ? "P " + oKpi : "P"
else if nyHhmm < 1000 or na(ko1000)
    pbState := "…"
else if not pbLeft
    pbState := "…"
else if wantLeave and not eArmed and inLeaveWin
    pbState := "→L"
else if wantRetest and not oArmed
    pbState := pbFibInvalid ? "void" : pbOteNoKo ? "OTE?" : pbFibFrozen ? "→P" : "leg…"
else
    pbState := "—"

if i_pathBShowState
    if na(pbStateLbl)
        pbStateLbl := label.new(bar_index, high, pbState, style = label.style_label_down, color = color.new(#0f172a, 35), textcolor = color.white, size = size.tiny)
    else
        label.set_xy(pbStateLbl, bar_index, high)
        label.set_text(pbStateLbl, pbState)
        label.set_size(pbStateLbl, size.tiny)

// Auto PDH/PDL eyes — optional A/B vs manual filter (OFF by default — no live-bar clutter)
if i_biasShowAuto and nyHhmm >= 930 and nyHhmm < i_flatTime
    string autoTxt = dayDraw == -1 ? "Auto↓ short" : dayDraw == 1 ? "Auto↑ long" : "Auto —"
    string manTxt = i_biasMode == "Long & Short" ? "Man: both" : i_biasMode == "Long only" ? "Man: long" : i_biasMode == "Short only" ? "Man: short" : "Man: auto"
    string biasTxt = autoTxt + " | " + manTxt
    if na(biasEyesLbl)
        biasEyesLbl := label.new(bar_index, low, biasTxt, style = label.style_label_up, color = color.new(#334155, 20), textcolor = color.white, size = size.tiny)
    else
        label.set_xy(biasEyesLbl, bar_index, low)
        label.set_text(biasEyesLbl, biasTxt)
else if not na(biasEyesLbl)
    label.delete(biasEyesLbl)
    biasEyesLbl := na

// Fill KPI — freeze boxes when TP/STOP trades (even if limit never re-tapped)
f_updFill(int st, int armTime, int dir, float entry, float stop, float tp) =>
    int out = st
    if st < 3 and not na(armTime) and time > armTime
        bool hitEntry = dir == 1 ? low <= entry : high >= entry
        bool hitStop = dir == 1 ? low <= stop : high >= stop
        bool hitTp = dir == 1 ? high >= tp : low <= tp
        if st == 1 and (hitEntry or hitStop or hitTp)
            out := 2
        if out == 2 or st == 2
            if hitStop
                out := 4
            else if hitTp
                out := 3
        if out == 1 and nyHhmm >= i_flatTime
            out := 5
        if out == 2 and nyHhmm >= i_flatTime
            out := 5
    string kpi = out == 1 ? "live" : out == 2 ? "filled" : out == 3 ? "WIN" : out == 4 ? "LOSS" : out == 5 ? "no fill" : "—"
    [out, kpi]

// Simulate fills; lock end time once resolved so boxes never chase the live edge
if eArmed and barstate.isconfirmed
    int ePrev = eFill
    [eFillTmp, eKpiTmp] = f_updFill(eFill, eTime, eDir, eEntry, eStop, eTp)
    eFill := eFillTmp
    eKpi := eKpiTmp
    if eFill >= 3 and (na(eEndTime) or ePrev < 3)
        eEndTime := time
if oArmed and barstate.isconfirmed
    bool oWasEyes = oKpi == "eyes"
    int oPrev = oFill
    [oFillTmp, oKpiTmp] = f_updFill(oFill, oTime, oDir, oEntry, oStop, oTp)
    oFill := oFillTmp
    oKpi := oWasEyes and oFill == 1 ? "eyes" : oKpiTmp
    if oFill >= 3 and (na(oEndTime) or oPrev < 3)
        oEndTime := time
if kArmed and barstate.isconfirmed
    int kPrev = kFill
    [kFillTmp, kKpiTmp] = f_updFill(kFill, kTime, kDir, kEntry, kStop, kTp)
    kFill := kFillTmp
    kKpi := kKpiTmp
    if kFill >= 3 and (na(kEndTime) or kPrev < 3)
        kEndTime := time

if eArmed or oArmed or kArmed
    manualReady := true

// ─── Fib anchors only (LO + HI) — you place the fib tool ─────────────────────
bool pbFibReady = i_pathBShowFib and pbLeft and not na(pbFibHi) and not na(pbFibLo) and pbFibHi > pbFibLo
float pbFibPlotLo = pbFibReady ? pbFibLo : na
float pbFibPlotHi = pbFibReady ? pbFibHi : na
if pbFibReady
    float rng = pbFibHi - pbFibLo
    int x0 = na(pbFibLoBar) ? math.max(0, bar_index - 8) : pbFibLoBar
    int x1 = na(pbFibHiBar) ? bar_index : pbFibHiBar
    int xL = math.min(x0, x1)
    int xR = math.max(bar_index + 8, math.max(x0, x1) + 6)
    float tick = math.max(rng * 0.015, syminfo.mintick * 8)
    float midY = (pbFibHi + pbFibLo) * 0.5
    if na(pbLnFib0) or na(pbLbl0)
        if not na(pbLnFib0)
            line.delete(pbLnFib0)
        if not na(pbLnFib1)
            line.delete(pbLnFib1)
        if not na(pbLnFibLeg)
            line.delete(pbLnFibLeg)
        if not na(pbLnFib0Tick)
            line.delete(pbLnFib0Tick)
        if not na(pbLnFib1Tick)
            line.delete(pbLnFib1Tick)
        if not na(pbLbl)
            label.delete(pbLbl)
        if not na(pbLbl0)
            label.delete(pbLbl0)
        if not na(pbLbl1)
            label.delete(pbLbl1)
        pbLnFib0 := line.new(xL, pbFibLo, xR, pbFibLo, color = #f59e0b, width = 1)
        pbLnFib1 := line.new(xL, pbFibHi, xR, pbFibHi, color = #fbbf24, width = 1)
        pbLnFibLeg := line.new(x0, pbFibLo, x1, pbFibHi, color = #f59e0b, width = 1, style = line.style_dashed)
        pbLnFib0Tick := line.new(x0, pbFibLo - tick, x0, pbFibLo + tick, color = #f59e0b, width = 2)
        pbLnFib1Tick := line.new(x1, pbFibHi - tick, x1, pbFibHi + tick, color = #fbbf24, width = 2)
        pbLbl0 := label.new(x0, pbFibLo, "0", style = label.style_label_up, color = #b45309, textcolor = color.white, size = size.tiny)
        pbLbl1 := label.new(x1, pbFibHi, "1", style = label.style_label_down, color = #b45309, textcolor = color.white, size = size.tiny)
        pbLbl := label.new(xR, midY, "fib", style = label.style_label_left, color = #78350f, textcolor = #fde68a, size = size.tiny)
    else
        line.set_xy1(pbLnFib0, xL, pbFibLo)
        line.set_xy2(pbLnFib0, xR, pbFibLo)
        line.set_xy1(pbLnFib1, xL, pbFibHi)
        line.set_xy2(pbLnFib1, xR, pbFibHi)
        line.set_xy1(pbLnFibLeg, x0, pbFibLo)
        line.set_xy2(pbLnFibLeg, x1, pbFibHi)
        line.set_xy1(pbLnFib0Tick, x0, pbFibLo - tick)
        line.set_xy2(pbLnFib0Tick, x0, pbFibLo + tick)
        line.set_xy1(pbLnFib1Tick, x1, pbFibHi - tick)
        line.set_xy2(pbLnFib1Tick, x1, pbFibHi + tick)
        label.set_xy(pbLbl0, x0, pbFibLo)
        label.set_xy(pbLbl1, x1, pbFibHi)
        label.set_xy(pbLbl, xR, midY)

// ─── Dual trade plans — slim labels; STOP/TP pts only on line icons; freeze at end ─
bool isShadow = not dayAllowed
bool oEyes = oArmed and oKpi == "eyes"
int maxLiveMs = 45 * 60 * 1000

if i_showPend and eArmed and not na(eEntry) and not na(eStop) and not na(eTp) and not na(eTime)
    bool eDone = eFill == 3 or eFill == 4 or eFill == 5
    if eDone and na(eEndTime)
        eEndTime := time
    int eLiveCap = eTime + maxLiveMs
    int eXR = eDone and not na(eEndTime) ? math.max(eEndTime, eTime + 60 * 1000) : math.min(time, eLiveCap)
    color eECol = isShadow ? #fb923c : #fbbf24
    color eSCol = isShadow ? #fb923c : c_stop
    color eTCol = isShadow ? #94a3b8 : c_tp
    float eRisk = math.abs(eEntry - eStop)
    float eRew = math.abs(eTp - eEntry)
    float eRR = eRisk > 0 ? eRew / eRisk : 0.0
    // Main tag: side · sleeve · 1:R · outcome (STOP/TP pts stay on line icons)
    string eTxt = (eDir == 1 ? "LONG" : "SHORT") + " · " + eTag + " · 1:" + str.tostring(eRR, "#.#") + (isShadow ? " · SHADOW" : "") + (i_showFillKpi ? "\n" + eKpi : "")
    if na(ePlanLeft) or ePlanLeft != eTime
        ePlanLeft := eTime
        if not na(eLnE)
            line.delete(eLnE)
            line.delete(eLnS)
            line.delete(eLnT)
            label.delete(eLbE)
            label.delete(eLbS)
            label.delete(eLbT)
            box.delete(eBxRisk)
            box.delete(eBxRew)
        eLnE := line.new(eTime, eEntry, eXR, eEntry, xloc = xloc.bar_time, color = eECol, width = 2)
        eLnS := line.new(eTime, eStop, eXR, eStop, xloc = xloc.bar_time, color = eSCol, width = 2)
        eLnT := line.new(eTime, eTp, eXR, eTp, xloc = xloc.bar_time, color = eTCol, width = 2)
        eLbE := label.new(eXR, eEntry, eTxt, xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = eECol, size = size.normal)
        eLbS := label.new(eXR, eStop, "−" + str.tostring(eRisk, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = eSCol, size = size.small)
        eLbT := label.new(eXR, eTp, "+" + str.tostring(eRew, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = eTCol, size = size.small)
        eBxRisk := box.new(eTime, math.max(eEntry, eStop), eXR, math.min(eEntry, eStop), xloc = xloc.bar_time, border_color = color.new(eSCol, 70), bgcolor = color.new(eSCol, 92), border_width = 1)
        eBxRew := box.new(eTime, math.max(eEntry, eTp), eXR, math.min(eEntry, eTp), xloc = xloc.bar_time, border_color = color.new(eTCol, 70), bgcolor = color.new(eTCol, 94), border_width = 1)
    else if not eDone
        line.set_xy2(eLnE, eXR, eEntry)
        line.set_xy2(eLnS, eXR, eStop)
        line.set_xy2(eLnT, eXR, eTp)
        label.set_xy(eLbE, eXR, eEntry)
        label.set_xy(eLbS, eXR, eStop)
        label.set_xy(eLbT, eXR, eTp)
        label.set_text(eLbE, eTxt)
        box.set_right(eBxRisk, eXR)
        box.set_right(eBxRew, eXR)
    else
        // Frozen — only refresh text/color, never extend right edge
        label.set_text(eLbE, eTxt)
        if not na(eEndTime)
            line.set_xy2(eLnE, eXR, eEntry)
            line.set_xy2(eLnS, eXR, eStop)
            line.set_xy2(eLnT, eXR, eTp)
            label.set_xy(eLbE, eXR, eEntry)
            label.set_xy(eLbS, eXR, eStop)
            label.set_xy(eLbT, eXR, eTp)
            box.set_right(eBxRisk, eXR)
            box.set_right(eBxRew, eXR)
    if i_showSig and not na(eWs) and not na(eEx)
        // Box on the RB candle (not the arm bar) — leave often had no visible "block" because box sat on 10:00
        int eRbL = not na(eRbTime) ? eRbTime : eTime
        int eRbR = eDone and not na(eEndTime) ? math.max(eEndTime, eRbL + 60 * 1000) : math.min(time, eRbL + 15 * 60 * 1000)
        if na(eBxRb)
            eBxRb := box.new(eRbL, math.max(eEx, eWs), eRbR, math.min(eEx, eWs), xloc = xloc.bar_time, border_color = #f59e0b, bgcolor = color.new(#f59e0b, 94), border_width = 1)
            if not na(eCe)
                eLnCe := line.new(eRbL, eCe, eRbR, eCe, xloc = xloc.bar_time, color = c_ce, width = 1, style = line.style_dotted)
        else if not eDone
            box.set_left(eBxRb, eRbL)
            box.set_right(eBxRb, eRbR)
            if not na(eLnCe)
                line.set_xy1(eLnCe, eRbL, eCe)
                line.set_xy2(eLnCe, eRbR, eCe)

if i_showPend and oArmed and not na(oEntry) and not na(oStop) and not na(oTp) and not na(oTime)
    bool oDone = oFill == 3 or oFill == 4 or oFill == 5
    if oDone and na(oEndTime)
        oEndTime := time
    int oLiveCap = oTime + maxLiveMs
    int oXR = oDone and not na(oEndTime) ? math.max(oEndTime, oTime + 60 * 1000) : math.min(time, oLiveCap)
    color oECol = isShadow or oEyes ? #fb923c : c_limit
    color oSCol = isShadow or oEyes ? #fb923c : c_stop
    color oTCol = isShadow or oEyes ? #94a3b8 : c_tp
    float oRisk = math.abs(oEntry - oStop)
    float oRew = math.abs(oTp - oEntry)
    float oRR = oRisk > 0 ? oRew / oRisk : 0.0
    string oTxt = (oDir == 1 ? "LONG" : "SHORT") + " · " + oTag + " · 1:" + str.tostring(oRR, "#.#") + (isShadow or oEyes ? " · SHADOW" : "") + (i_showFillKpi ? "\n" + oKpi : "")
    if na(oPlanLeft) or oPlanLeft != oTime
        oPlanLeft := oTime
        if not na(oLnE)
            line.delete(oLnE)
            line.delete(oLnS)
            line.delete(oLnT)
            label.delete(oLbE)
            label.delete(oLbS)
            label.delete(oLbT)
            box.delete(oBxRisk)
            box.delete(oBxRew)
        oLnE := line.new(oTime, oEntry, oXR, oEntry, xloc = xloc.bar_time, color = oECol, width = 2)
        oLnS := line.new(oTime, oStop, oXR, oStop, xloc = xloc.bar_time, color = oSCol, width = 2)
        oLnT := line.new(oTime, oTp, oXR, oTp, xloc = xloc.bar_time, color = oTCol, width = 2)
        oLbE := label.new(oXR, oEntry, oTxt, xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = oECol, size = size.normal)
        oLbS := label.new(oXR, oStop, "−" + str.tostring(oRisk, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = oSCol, size = size.small)
        oLbT := label.new(oXR, oTp, "+" + str.tostring(oRew, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = oTCol, size = size.small)
        oBxRisk := box.new(oTime, math.max(oEntry, oStop), oXR, math.min(oEntry, oStop), xloc = xloc.bar_time, border_color = color.new(oSCol, 70), bgcolor = color.new(oSCol, 92), border_width = 1)
        oBxRew := box.new(oTime, math.max(oEntry, oTp), oXR, math.min(oEntry, oTp), xloc = xloc.bar_time, border_color = color.new(oTCol, 70), bgcolor = color.new(oTCol, 94), border_width = 1)
    else if not oDone
        line.set_xy2(oLnE, oXR, oEntry)
        line.set_xy2(oLnS, oXR, oStop)
        line.set_xy2(oLnT, oXR, oTp)
        label.set_xy(oLbE, oXR, oEntry)
        label.set_xy(oLbS, oXR, oStop)
        label.set_xy(oLbT, oXR, oTp)
        label.set_text(oLbE, oTxt)
        box.set_right(oBxRisk, oXR)
        box.set_right(oBxRew, oXR)
    else
        label.set_text(oLbE, oTxt)
        if not na(oEndTime)
            line.set_xy2(oLnE, oXR, oEntry)
            line.set_xy2(oLnS, oXR, oStop)
            line.set_xy2(oLnT, oXR, oTp)
            label.set_xy(oLbE, oXR, oEntry)
            label.set_xy(oLbS, oXR, oStop)
            label.set_xy(oLbT, oXR, oTp)
            box.set_right(oBxRisk, oXR)
            box.set_right(oBxRew, oXR)
    if i_showSig and not na(oWs) and not na(oEx)
        // Box anchored on the RB block candle (oRbTime), not the arm bar
        int oRbL = not na(oRbTime) ? oRbTime : oTime
        int oRbR = oDone and not na(oEndTime) ? math.max(oEndTime, oRbL + 60 * 1000) : math.min(time, oRbL + 15 * 60 * 1000)
        color oRbCol = oDir == 1 ? c_bull : c_bear
        if na(oBxRb)
            oBxRb := box.new(oRbL, math.max(oEx, oWs), oRbR, math.min(oEx, oWs), xloc = xloc.bar_time, border_color = oRbCol, bgcolor = color.new(oRbCol, 94), border_width = 1)
            if not na(oCe)
                oLnCe := line.new(oRbL, oCe, oRbR, oCe, xloc = xloc.bar_time, color = c_ce, width = 1, style = line.style_dotted)
        else if not oDone
            box.set_left(oBxRb, oRbL)
            box.set_right(oBxRb, oRbR)
            if not na(oLnCe)
                line.set_xy1(oLnCe, oRbL, oCe)
                line.set_xy2(oLnCe, oRbR, oCe)

if i_showPend and kArmed and not na(kEntry) and not na(kStop) and not na(kTp) and not na(kTime)
    bool kDone = kFill == 3 or kFill == 4 or kFill == 5
    if kDone and na(kEndTime)
        kEndTime := time
    int kLiveCap = kTime + maxLiveMs
    int kXR = kDone and not na(kEndTime) ? math.max(kEndTime, kTime + 60 * 1000) : math.min(time, kLiveCap)
    color kECol = isShadow ? #fb923c : #22d3ee
    color kSCol = isShadow ? #fb923c : c_stop
    color kTCol = isShadow ? #94a3b8 : c_tp
    float kRisk = math.abs(kEntry - kStop)
    float kRew = math.abs(kTp - kEntry)
    float kRR = kRisk > 0 ? kRew / kRisk : 0.0
    string kTxt = (kDir == 1 ? "LONG" : "SHORT") + " · " + kTag + " · 1:" + str.tostring(kRR, "#.#") + (isShadow ? " · SHADOW" : "") + (i_showFillKpi ? "\n" + kKpi : "")
    if na(kPlanLeft) or kPlanLeft != kTime
        kPlanLeft := kTime
        if not na(kLnE)
            line.delete(kLnE)
            line.delete(kLnS)
            line.delete(kLnT)
            label.delete(kLbE)
            label.delete(kLbS)
            label.delete(kLbT)
            box.delete(kBxRisk)
            box.delete(kBxRew)
        kLnE := line.new(kTime, kEntry, kXR, kEntry, xloc = xloc.bar_time, color = kECol, width = 2)
        kLnS := line.new(kTime, kStop, kXR, kStop, xloc = xloc.bar_time, color = kSCol, width = 2)
        kLnT := line.new(kTime, kTp, kXR, kTp, xloc = xloc.bar_time, color = kTCol, width = 2)
        kLbE := label.new(kXR, kEntry, kTxt, xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = kECol, size = size.normal)
        kLbS := label.new(kXR, kStop, "−" + str.tostring(kRisk, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = kSCol, size = size.small)
        kLbT := label.new(kXR, kTp, "+" + str.tostring(kRew, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = kTCol, size = size.small)
        kBxRisk := box.new(kTime, math.max(kEntry, kStop), kXR, math.min(kEntry, kStop), xloc = xloc.bar_time, border_color = color.new(kSCol, 70), bgcolor = color.new(kSCol, 92), border_width = 1)
        kBxRew := box.new(kTime, math.max(kEntry, kTp), kXR, math.min(kEntry, kTp), xloc = xloc.bar_time, border_color = color.new(kTCol, 70), bgcolor = color.new(kTCol, 94), border_width = 1)
    else if not kDone
        line.set_xy2(kLnE, kXR, kEntry)
        line.set_xy2(kLnS, kXR, kStop)
        line.set_xy2(kLnT, kXR, kTp)
        label.set_xy(kLbE, kXR, kEntry)
        label.set_xy(kLbS, kXR, kStop)
        label.set_xy(kLbT, kXR, kTp)
        label.set_text(kLbE, kTxt)
        box.set_right(kBxRisk, kXR)
        box.set_right(kBxRew, kXR)
    else
        label.set_text(kLbE, kTxt)
        if not na(kEndTime)
            line.set_xy2(kLnE, kXR, kEntry)
            line.set_xy2(kLnS, kXR, kStop)
            line.set_xy2(kLnT, kXR, kTp)
            label.set_xy(kLbE, kXR, kEntry)
            label.set_xy(kLbS, kXR, kStop)
            label.set_xy(kLbT, kXR, kTp)
            box.set_right(kBxRisk, kXR)
            box.set_right(kBxRew, kXR)
    if i_showSig and not na(kWs) and not na(kEx)
        int kRbL = not na(kRbTime) ? kRbTime : kTime
        int kRbR = kDone and not na(kEndTime) ? math.max(kEndTime, kRbL + 60 * 1000) : math.min(time, kRbL + 15 * 60 * 1000)
        if na(kBxRb)
            kBxRb := box.new(kRbL, math.max(kEx, kWs), kRbR, math.min(kEx, kWs), xloc = xloc.bar_time, border_color = #22d3ee, bgcolor = color.new(#22d3ee, 94), border_width = 1)
            if not na(kCe)
                kLnCe := line.new(kRbL, kCe, kRbR, kCe, xloc = xloc.bar_time, color = c_ce, width = 1, style = line.style_dotted)
        else if not kDone
            box.set_left(kBxRb, kRbL)
            box.set_right(kBxRb, kRbR)
            if not na(kLnCe)
                line.set_xy1(kLnCe, kRbL, kCe)
                line.set_xy2(kLnCe, kRbR, kCe)

// ─── PDH / PDL ───────────────────────────────────────────────────────────────
float usePdh = not na(pdhLvl) ? pdhLvl : prevDayHigh
float usePdl = not na(pdlLvl) ? pdlLvl : prevDayLow
if i_showPdhPdl and newSessDay
    if not na(lnPdh)
        line.delete(lnPdh)
        label.delete(lblPdh)
    if not na(lnPdl)
        line.delete(lnPdl)
        label.delete(lblPdl)
    lnPdh := na
    lnPdl := na
    lblPdh := na
    lblPdl := na
    if not na(pdhOriginBar) and not na(usePdh)
        lnPdh := line.new(pdhOriginBar, usePdh, bar_index, usePdh, color = c_pdh, width = 2)
        lblPdh := label.new(bar_index, usePdh, "PDH", style = label.style_label_left, color = c_pdh, textcolor = color.white, size = size.small)
    if not na(pdlOriginBar) and not na(usePdl)
        lnPdl := line.new(pdlOriginBar, usePdl, bar_index, usePdl, color = c_pdl, width = 2)
        lblPdl := label.new(bar_index, usePdl, "PDL", style = label.style_label_left, color = c_pdl, textcolor = color.white, size = size.small)
if i_showPdhPdl and nyHhmm < i_flatTime
    if not na(lnPdh)
        line.set_x2(lnPdh, bar_index)
        label.set_xy(lblPdh, bar_index, usePdh)
    if not na(lnPdl)
        line.set_x2(lnPdl, bar_index)
        label.set_xy(lblPdl, bar_index, usePdl)

// ─── NWOG (current week only) ────────────────────────────────────────────────
f_nwogClearAll() =>
    while array.size(nwogBoxA) > 0
        box.delete(array.shift(nwogBoxA))
        line.delete(array.shift(nwogCeA))
        label.delete(array.shift(nwogLblA))
        array.shift(nwogTopA)
        array.shift(nwogBotA)
        array.shift(nwogHitHiA)
        array.shift(nwogHitLoA)
        array.shift(nwogFilledA)

f_nwogPush(float top, float bot, string tag) =>
    f_nwogClearAll()
    float hi = math.max(top, bot)
    float lo = math.min(top, bot)
    float ce = (hi + lo) * 0.5
    array.push(nwogBoxA, box.new(bar_index, hi, bar_index + 4, lo, border_color = #a78bfa, bgcolor = color.new(#a78bfa, 88), border_width = 2))
    array.push(nwogCeA, line.new(bar_index, ce, bar_index + 4, ce, color = #c4b5fd, width = 1, style = line.style_dotted))
    array.push(nwogLblA, label.new(bar_index + 1, hi, tag, style = label.style_label_left, color = #5b21b6, textcolor = color.white, size = size.small))
    array.push(nwogTopA, hi)
    array.push(nwogBotA, lo)
    array.push(nwogHitHiA, false)
    array.push(nwogHitLoA, false)
    array.push(nwogFilledA, false)

if i_showNwog and nwogSunOpenBar and barstate.isconfirmed
    nwogGapTime := na
    nwogTop := na
    nwogBot := na
    f_nwogClearAll()
bool nwogGapOk = i_showNwog and barstate.isconfirmed and not na(nwogFriClose) and math.abs(open - nwogFriClose) >= i_nwogMinPts
if nwogGapOk and nwogSunOpenBar
    nwogGapTime := time
    nwogTop := math.max(open, nwogFriClose)
    nwogBot := math.min(open, nwogFriClose)
    f_nwogPush(open, nwogFriClose, "NWOG · CE · Sun 18:00")
else if nwogGapOk and nwogMonFallback and na(nwogGapTime)
    nwogGapTime := time
    nwogTop := math.max(open, nwogFriClose)
    nwogBot := math.min(open, nwogFriClose)
    f_nwogPush(open, nwogFriClose, "NWOG · CE · Mon open")

if i_showNwog and array.size(nwogBoxA) > 0
    for i = 0 to array.size(nwogBoxA) - 1
        float hi = array.get(nwogTopA, i)
        float lo = array.get(nwogBotA, i)
        bool hitHi = array.get(nwogHitHiA, i) or high >= hi
        bool hitLo = array.get(nwogHitLoA, i) or low <= lo
        array.set(nwogHitHiA, i, hitHi)
        array.set(nwogHitLoA, i, hitLo)
        bool filled = hitHi and hitLo
        array.set(nwogFilledA, i, filled)
        box bx = array.get(nwogBoxA, i)
        line ln = array.get(nwogCeA, i)
        label lb = array.get(nwogLblA, i)
        float ce = (hi + lo) * 0.5
        box.set_right(bx, bar_index + 2)
        line.set_x2(ln, bar_index + 2)
        line.set_y1(ln, ce)
        line.set_y2(ln, ce)
        label.set_xy(lb, bar_index + 1, hi)
        if filled
            box.set_border_color(bx, #64748b)
            box.set_bgcolor(bx, color.new(#64748b, 92))
            label.set_text(lb, "NWOG filled")
            label.set_color(lb, #475569)
        else
            label.set_color(lb, #5b21b6)

// Key opens — per-day history for 10:00 + midnight (scroll past days); 18:00 stays live-only
f_keyOpenTrim(array<line> lns, array<label> lbs, array<int> ymds, array<float> pxs, int maxN) =>
    while array.size(lns) > maxN
        line.delete(array.shift(lns))
        label.delete(array.shift(lbs))
        array.shift(ymds)
        array.shift(pxs)

f_keyOpenPush(array<line> lns, array<label> lbs, array<int> ymds, array<float> pxs, float px, string tag, color col) =>
    // Avoid duplicate push if same ymd already stored (replay / fallback)
    bool dup = array.size(ymds) > 0 and array.get(ymds, array.size(ymds) - 1) == nyYmd
    if not dup and not na(px)
        array.push(lns, line.new(bar_index, px, bar_index, px, color = col, width = 1, style = line.style_dashed))
        array.push(lbs, label.new(bar_index, px, tag + " " + str.tostring(px, "#.##"), style = label.style_label_left, color = color.new(#0f172a, 35), textcolor = col, size = size.tiny))
        array.push(ymds, nyYmd)
        array.push(pxs, px)
        f_keyOpenTrim(lns, lbs, ymds, pxs, i_keyOpenHistDays)

f_keyOpenExtendToday(array<line> lns, array<label> lbs, array<int> ymds, array<float> pxs) =>
    int n = array.size(lns)
    if n > 0 and array.get(ymds, n - 1) == nyYmd
        line ln = array.get(lns, n - 1)
        label lb = array.get(lbs, n - 1)
        float px = array.get(pxs, n - 1)
        line.set_x2(ln, bar_index)
        label.set_xy(lb, bar_index, px)

f_updKeyOpen(line ln, label lb, float px, int originBar, string tag, color col) =>
    line lnOut = ln
    label lbOut = lb
    if not na(px)
        int x0 = not na(originBar) ? originBar : math.max(0, bar_index - 20)
        if na(lnOut)
            lnOut := line.new(x0, px, bar_index, px, color = col, width = 1, style = line.style_dashed)
            lbOut := label.new(bar_index, px, tag + " " + str.tostring(px, "#.##"), style = label.style_label_left, color = color.new(#0f172a, 30), textcolor = col, size = size.tiny)
        else
            line.set_xy1(lnOut, x0, px)
            line.set_xy2(lnOut, bar_index, px)
            label.set_xy(lbOut, bar_index, px)
            label.set_text(lbOut, tag + " " + str.tostring(px, "#.##"))
    [lnOut, lbOut]

// Push once when each day prints (history survives; not wiped at flat)
if i_showKeyOpens and newCalDay and barstate.isconfirmed
    f_keyOpenPush(midHistLn, midHistLb, midHistYmd, midHistPx, open, "00:00", c_midn)
if i_showKeyOpens and ko1000Print and barstate.isconfirmed
    f_keyOpenPush(koHistLn, koHistLb, koHistYmd, koHistPx, open, "10:00", c_ko)

if i_showKeyOpens
    f_keyOpenExtendToday(midHistLn, midHistLb, midHistYmd, midHistPx)
    f_keyOpenExtendToday(koHistLn, koHistLb, koHistYmd, koHistPx)
    // 18:00 remains a single live line (weekly session open)
    if nyHhmm < i_flatTime or not na(open1800)
        [ln1800Tmp, lbl1800Tmp] = f_updKeyOpen(ln1800, lbl1800, open1800, open1800Bar, "18:00", c_1800)
        ln1800 := ln1800Tmp
        lbl1800 := lbl1800Tmp

// Yellow 10:00 wash
bgcolor(nyHhmm == 1000 ? color.new(c_win10, 88) : na, title = "10:00")

// KO confluence scanner — eyes inventory at 10:00 (never arms)
f_koScanPush(string tag, color col, float y) =>
    array.push(koScanLb, label.new(bar_index, y, tag, style = label.style_label_down, color = color.new(#0f172a, 55), textcolor = col, size = size.tiny))
    while array.size(koScanLb) > 48
        label.delete(array.shift(koScanLb))

if i_koScan and not na(ko1000) and nyHhmm >= 1000 and nyHhmm < i_flatTime and barstate.isconfirmed
    float pad = i_koScanPad
    if trig1
        if u1 and f_zoneNearKo(math.max(wsU1, l1), math.min(wsU1, l1), ko1000, pad)
            f_koScanPush("1RB↑@KO", c_bull, l1)
        if b1 and f_zoneNearKo(math.max(wsB1, h1), math.min(wsB1, h1), ko1000, pad)
            f_koScanPush("1RB↓@KO", c_bear, h1)
        if ob1U and f_zoneNearKo(ob1Top, ob1Bot, ko1000, pad)
            f_koScanPush("1OB↑@KO", color.new(c_bull, 20), ob1Bot)
        if ob1B and f_zoneNearKo(ob1Top, ob1Bot, ko1000, pad)
            f_koScanPush("1OB↓@KO", color.new(c_bear, 20), ob1Top)
        if cisd1U and math.abs(close - ko1000) <= pad
            f_koScanPush("1CSD↑@KO", #86efac, low)
        if cisd1B and math.abs(close - ko1000) <= pad
            f_koScanPush("1CSD↓@KO", #fca5a5, high)
        if ifvg1U and f_zoneNearKo(ifvg1Top, ifvg1Bot, ko1000, pad)
            f_koScanPush("1IFVG↑@KO", #a5b4fc, ifvg1Bot)
        if ifvg1B and f_zoneNearKo(ifvg1Top, ifvg1Bot, ko1000, pad)
            f_koScanPush("1IFVG↓@KO", #f9a8d4, ifvg1Top)
    if trig5
        if fvg5U and f_zoneNearKo(fvg5Top, fvg5Bot, ko1000, pad)
            f_koScanPush("5FVG↑@KO", #67e8f9, fvg5Bot)
        if fvg5B and f_zoneNearKo(fvg5Top, fvg5Bot, ko1000, pad)
            f_koScanPush("5FVG↓@KO", #fda4af, fvg5Top)

plot(pbFibPlotLo, "FIB LO (0)", color.new(#f59e0b, 0), linewidth = 1, style = plot.style_linebr)
plot(pbFibPlotHi, "FIB HI (1)", color.new(#fbbf24, 0), linewidth = 1, style = plot.style_linebr)
float _rngOte = pbFibFrozen and not pbFibInvalid and not na(pbFibHi) and not na(pbFibLo) ? pbFibHi - pbFibLo : na
float _fib62 = na
float _fib705 = na
float _fib62j = na
float _fib705j = na
if pbFibFrozen and not pbFibInvalid and not na(_rngOte) and _rngOte > 0
    // Continuation (solid) — same side as leave
    _fib62 := pbDir == 1 ? pbFibHi - _rngOte * 0.62 : pbFibLo + _rngOte * 0.62
    _fib705 := pbDir == 1 ? pbFibHi - _rngOte * 0.705 : pbFibLo + _rngOte * 0.705
    // Judas reverse (dotted)
    _fib62j := pbDir == 1 ? pbFibLo + _rngOte * 0.62 : pbFibHi - _rngOte * 0.62
    _fib705j := pbDir == 1 ? pbFibLo + _rngOte * 0.705 : pbFibHi - _rngOte * 0.705
plot(i_powellShowOte ? _fib62 : na, "Cont 0.62", color.new(#fb923c, 0), linewidth = 1, style = plot.style_linebr)
plot(i_powellShowOte ? _fib705 : na, "Cont 0.705", color.new(#eab308, 0), linewidth = 1, style = plot.style_linebr)
plot(i_powellShowOte and wantJudas ? _fib62j : na, "Judas 0.62", color.new(#22d3ee, 30), linewidth = 1, style = plot.style_steplinebr)
plot(i_powellShowOte and wantJudas ? _fib705j : na, "Judas 0.705", color.new(#67e8f9, 40), linewidth = 1, style = plot.style_steplinebr)
plot(i_showDil and not na(dilPx) ? dilPx : na, "Day IL", color.new(#c084fc, 0), linewidth = 2, style = plot.style_linebr)

// Diagnostic: teaching RB dots so a blank chart is not silent failure
plotshape(i_showRbMarks and trig5 and u5, title = "5m bull RB", style = shape.circle, location = location.belowbar, color = c_bull, size = size.tiny)
plotshape(i_showRbMarks and trig5 and b5, title = "5m bear RB", style = shape.circle, location = location.abovebar, color = c_bear, size = size.tiny)
plotshape(i_showRbMarks and trig1 and u1, title = "1m bull RB", style = shape.diamond, location = location.belowbar, color = c_bull, size = size.tiny)
plotshape(i_showRbMarks and trig1 and b1, title = "1m bear RB", style = shape.diamond, location = location.abovebar, color = c_bear, size = size.tiny)

if barstate.islast
    if not na(dilLbl)
        label.delete(dilLbl)
        dilLbl := na
    if i_showDil and not na(dilPx)
        dilLbl := label.new(bar_index + 2, dilPx, dilTag + "  " + str.tostring(dilPx, "#.#"), xloc = xloc.bar_index, style = label.style_label_left, color = #6b21a8, textcolor = color.white, size = size.normal)

alertcondition(manualReady and dayAllowed, title = "Morningstar ARMED", message = "Morningstar ARMED — {{ticker}} {{interval}}\nleave and/or Powell plan on chart")
