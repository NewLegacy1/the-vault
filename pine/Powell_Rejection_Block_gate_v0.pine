    pbFibHiBar := na
    pbAway := 0.0
    pbLeaveBar := na
    pbLeaveTime := na
    pbAwayPeakBar := na
    pbAwayPeakTime := na
    pbFibLoTime := na
    pbFibHiTime := na
    pbReturned := false
    pbState := "—"
    eArmed := false
