//@version=6
// Morningstar lean — Manual study (Path B + optional Path A 15m)
// DO NOT edit pine/Powell_Rejection_Block_v1.pine (locked Lab).
// Fat pre-lean archive: pine/_archive_Powell_Rejection_Block_gate_v0_fat_2026-07-16.pine
//
// KEEP: Path B (10:00→leave→fib→LTF RB) · optional Path A 15m · NWOG · PDH/PDL ·
//       10:00 · ENTRY/STOP/TP · Manual click only.
// CUT: ghosts · funnel tables · give-back/trail · CISD · 30/60/240 · IFVG/OB/FVG
//      museum · Deep BT auto-orders · eval caps · rolling/AM opens.
strategy(
     title                   = "Morningstar (PRB gate_v0)",
     shorttitle              = "Morningstar",
     overlay                 = true,
     pyramiding              = 0,
     process_orders_on_close = true,
     calc_on_every_tick      = false,
     max_bars_back           = 5000,
     initial_capital         = 50000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     commission_type         = strategy.commission.cash_per_contract,
     commission_value        = 0.62,
     slippage                = 1,
     margin_long             = 0,
     margin_short            = 0,
     max_lines_count         = 120,
     max_boxes_count         = 80,
     max_labels_count        = 80)

// ─── Inputs (lean) ───────────────────────────────────────────────────────────
i_winStart = input.int(1000, "Entries from (HHMM)", minval = 0, maxval = 2359, group = "Session")
i_winEnd   = input.int(1300, "Last order (HHMM)", minval = 0, maxval = 2359, group = "Session")
i_flatTime = input.int(1555, "Flat by (HHMM)", minval = 0, maxval = 2359, group = "Session")
i_oneTradeDay = input.bool(true, "Max 1 setup per day", group = "Session")
i_skipMonday  = input.bool(true, "Skip Mondays (SHADOW)", group = "Session")
i_skipJulOct  = input.bool(false, "Skip July & October (SHADOW)", group = "Session")
i_biasMode    = input.string("Both", "Direction filter", options = ["Both", "Long only", "Short only"], group = "Session")

i_pathA = input.bool(false, "Enable Path A (15m RB leave-retest)", group = "Paths", tooltip = "OFF by default — Path A was stealing the day and blocking Path B. Path B is primary.")
i_pathB = input.bool(true, "Enable Path B (10:00 + fib + LTF RB)", group = "Paths")
i_pathBAlign = input.float(15.0, "RB / KO proximity (pts)", minval = 2.0, step = 1.0, group = "Paths")
i_pathBReqOte = input.bool(false, "Path B: require KO in fib OTE", group = "Paths")
i_pathBUse15 = input.bool(true, "Path B: 15m RB trigger", group = "Paths")
i_pathBUse5 = input.bool(true, "Path B: 5m RB trigger", group = "Paths")
i_pathBUse1 = input.bool(true, "Path B: 1m RB trigger", group = "Paths")
i_minWick1 = input.float(4.0, "Min 1m RB wick (pts)", minval = 1.0, step = 0.5, group = "Paths")
i_minWick5 = input.float(6.0, "Min 5m RB wick (pts)", minval = 2.0, step = 0.5, group = "Paths")
i_minWick15 = input.float(12.0, "Min 15m RB wick (pts)", minval = 4.0, step = 1.0, group = "Paths")
i_localLen = input.int(12, "RB extreme lookback (bars)", minval = 4, maxval = 50, group = "Paths")
i_confClose = input.bool(true, "RB needs confirming close", group = "Paths")
i_leaveR = input.float(1.0, "Path A: leave N×risk before arm (0=now)", minval = 0.0, step = 0.25, group = "Paths")
i_tapTimeout = input.int(36, "Setup / latch expires (chart bars)", minval = 4, maxval = 120, group = "Paths")

i_showNwog = input.bool(true, "Show NWOG (Fri close → Sun 18:00 ET)", group = "Levels", tooltip = "Current week only. CME week open = Sunday 18:00. Falls back to Monday open if Sunday bars are missing.")
i_nwogMinPts = input.float(5.0, "Min NWOG size (pts)", minval = 0.5, step = 0.5, group = "Levels")
i_showPdhPdl = input.bool(true, "Show PDH / PDL (this session)", group = "Levels")
i_pathBShowFib = input.bool(true, "Show Path B fib leg + OTE", group = "Levels")
i_pathBShowState = input.bool(true, "Show Path B status tag", group = "Levels", tooltip = "ON so you can see wait manip / leave / latch / ARMED while debugging.")
i_showPend = input.bool(true, "Show ENTRY / STOP / TP", group = "Levels")
i_showSig = input.bool(true, "Show armed RB box", group = "Levels")
i_rbExtend = input.int(24, "RB box extend (bars)", minval = 4, maxval = 80, group = "Levels")
i_rbNoFill = input.bool(true, "RB box: border only", group = "Levels")

i_maxStopPts = input.float(20.0, "Max stop (pts)", minval = 2.0, step = 1.0, group = "Risk")
i_minStopPts = input.float(5.0, "Min stop (pts)", minval = 0.0, step = 0.5, group = "Risk")
i_stopBufPts = input.float(2.0, "Stop buffer (pts)", minval = 0.0, step = 0.25, group = "Risk")
i_rr = input.float(5.0, "Target (R)", minval = 1.0, step = 0.25, group = "Risk")

c_bear = input.color(#ef4444, "Bearish", group = "Colors")
c_bull = input.color(#7dd3fc, "Bullish", group = "Colors")
c_ce = input.color(#e2e8f0, "CE", group = "Colors")
c_limit = input.color(#f8fafc, "ENTRY", group = "Colors")
c_stop = input.color(#f87171, "STOP", group = "Colors")
c_tp = input.color(#34d399, "TP", group = "Colors")
c_pdh = input.color(#22c55e, "PDH", group = "Colors")
c_pdl = input.color(#ef4444, "PDL", group = "Colors")
c_win10 = input.color(#eab308, "10:00 wash", group = "Colors")

// ─── Time ────────────────────────────────────────────────────────────────────
int nyHhmm = hour(time, "America/New_York") * 100 + minute(time, "America/New_York")
int nyMonth = month(time, "America/New_York")
int nyDow = dayofweek(time, "America/New_York")
bool newDay = ta.change(time("D", "America/New_York")) != 0
bool canPlace = nyHhmm < i_winEnd
bool mondayOk = not i_skipMonday or nyDow != dayofweek.monday
bool monthOk = not i_skipJulOct or (nyMonth != 7 and nyMonth != 10)
bool dayAllowed = mondayOk and monthOk
bool biasOkShort = i_biasMode != "Long only"
bool biasOkLong = i_biasMode != "Short only"

// ─── Levels ──────────────────────────────────────────────────────────────────
float prevDayHigh = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
float prevDayLow = request.security(syminfo.tickerid, "D", low[1], lookahead = barmerge.lookahead_on)

var float curDayHigh = na
var float curDayLow = na
var int curDayHighBar = na
var int curDayLowBar = na
var float pdhLvl = na
var float pdlLvl = na
var int pdhOriginBar = na
var int pdlOriginBar = na
var float ko1000 = na
var float nwogFriClose = na
var int nwogGapTime = na  // time of bar that created this week's NWOG (na = none yet)

if newDay
    pdhLvl := curDayHigh
    pdlLvl := curDayLow
    pdhOriginBar := curDayHighBar
    pdlOriginBar := curDayLowBar
    curDayHigh := high
    curDayLow := low
    curDayHighBar := bar_index
    curDayLowBar := bar_index
else
    if na(curDayHigh) or high >= curDayHigh
        curDayHigh := high
        curDayHighBar := bar_index
    if na(curDayLow) or low <= curDayLow
        curDayLow := low
        curDayLowBar := bar_index

if nyHhmm >= 1000 and nyHhmm[1] < 1000
    ko1000 := open

bool isFri = nyDow == dayofweek.friday
bool isSun = nyDow == dayofweek.sunday
bool isMon = nyDow == dayofweek.monday
if isFri
    nwogFriClose := close
// CME week open = first bar at/after Sunday 18:00 ET. Monday 09:30 only if Sunday never printed a gap.
bool nwogSunOpenBar = isSun and nyHhmm >= 1800 and nyHhmm[1] < 1800
bool nwogMonFallback = isMon and nyHhmm >= 930 and nyHhmm[1] < 930

// ─── RB packs (1 / 5 / 15 only) ───────────────────────────────────────────────
f_htfPack(float minW) =>
    float o1 = open[1]
    float h1 = high[1]
    float l1 = low[1]
    float c1 = close[1]
    float uw = h1 - math.max(o1, c1)
    float lw = math.min(o1, c1) - l1
    bool locH = h1 >= ta.highest(high, i_localLen)[1]
    bool locL = l1 <= ta.lowest(low, i_localLen)[1]
    bool bear = locH and uw >= minW and (not i_confClose or c1 < o1)
    bool bull = locL and lw >= minW and (not i_confClose or c1 > o1)
    [bear, bull, h1, l1, math.max(o1, c1), math.min(o1, c1)]

[b1, u1, h1, l1, wsB1, wsU1] = request.security(syminfo.tickerid, "1", f_htfPack(i_minWick1), barmerge.gaps_off, barmerge.lookahead_off)
[b5, u5, h5, l5, wsB5, wsU5] = request.security(syminfo.tickerid, "5", f_htfPack(i_minWick5), barmerge.gaps_off, barmerge.lookahead_off)
[b15, u15, h15, l15, wsB15, wsU15] = request.security(syminfo.tickerid, "15", f_htfPack(i_minWick15), barmerge.gaps_off, barmerge.lookahead_off)
int t1sec = request.security(syminfo.tickerid, "1", time, barmerge.gaps_off, barmerge.lookahead_off)
int t5sec = request.security(syminfo.tickerid, "5", time, barmerge.gaps_off, barmerge.lookahead_off)
int t15sec = request.security(syminfo.tickerid, "15", time, barmerge.gaps_off, barmerge.lookahead_off)
bool new1Bar = ta.change(t1sec) != 0
bool new5Bar = ta.change(t5sec) != 0
bool new15Bar = ta.change(t15sec) != 0

bool rb15Bear = b15 and new15Bar and biasOkShort
bool rb15Bull = u15 and new15Bar and biasOkLong

// ─── Plan math ───────────────────────────────────────────────────────────────
f_plan(float wickStart, float ce, float extreme, bool isShort) =>
    float stopPx = isShort ? extreme + i_stopBufPts : extreme - i_stopBufPts
    float entryWs = wickStart
    float riskWs = math.abs(stopPx - entryWs)
    float entryCe = ce
    float riskCe = math.abs(stopPx - entryCe)
    float entryPx = riskWs >= i_minStopPts and riskWs <= i_maxStopPts ? entryWs : riskCe >= i_minStopPts and riskCe <= i_maxStopPts ? entryCe : na
    float stopOut = na(entryPx) ? na : stopPx
    [entryPx, stopOut]

f_shadowArmLabel() =>
    not monthOk ? "SHADOW Jul/Oct" : not mondayOk ? "SHADOW Mon" : "ARMED — you click"

f_nearKo(float a, float b) =>
    not na(a) and not na(b) and math.abs(a - b) <= i_pathBAlign

// ─── Setup state ─────────────────────────────────────────────────────────────
var int suDir = 0
var int suBar = na
var float suEntry = na
var float suStop = na
var float suWickStart = na
var float suCe = na
var float suExtreme = na
var float pendStop = na
var float pendTp = na
var bool suLeft = false
var float suLeavePx = na
var bool manualReady = false
var string manualState = "—"
var string suSweepTag = "—"
var bool suPathB = false
var bool pbArmedToday = false

var int pbDir = 0
var bool pbManip = false
var bool pbLeft = false
var bool pbPierceAbove = false
var bool pbPierceBelow = false
var float pbHi = na
var float pbLo = na
var float pbFibHi = na
var float pbFibLo = na
var int pbFibLoBar = na
var int pbFibHiBar = na
var bool pbOteLatched = false
var float pbLatchWs = na
var float pbLatchCe = na
var float pbLatchEx = na
var int pbLatchDir = 0
var int pbLatchBar = na
var string pbLatchTag = "—"
var string pbState = "—"

var line pbLn62 = na
var line pbLn705 = na
var line pbLn79 = na
var line pbLnFib0 = na
var line pbLnFib1 = na
var line pbLnFibLeg = na
var label pbLbl = na
var label pbLbl0 = na
var label pbLbl1 = na
var label pbStateLbl = na

var line planLnE = na
var line planLnS = na
var line planLnT = na
var label planLbE = na
var label planLbS = na
var label planLbT = na
var box planBxRisk = na
var box planBxRew = na
var int planLeft = na

var box bxRb = na
var line lnRbCe = na
var label lblRbMark = na
var int rbLeft = na

var line lnPdh = na
var line lnPdl = na
var label lblPdh = na
var label lblPdl = na

var array<box> nwogBoxA = array.new_box()
var array<line> nwogCeA = array.new_line()
var array<label> nwogLblA = array.new_label()
var array<float> nwogTopA = array.new_float()
var array<float> nwogBotA = array.new_float()
var array<bool> nwogHitHiA = array.new_bool()
var array<bool> nwogHitLoA = array.new_bool()
var array<bool> nwogFilledA = array.new_bool()

f_clearFib() =>
    if not na(pbLn62)
        line.delete(pbLn62)
    if not na(pbLn705)
        line.delete(pbLn705)
    if not na(pbLn79)
        line.delete(pbLn79)
    if not na(pbLnFib0)
        line.delete(pbLnFib0)
    if not na(pbLnFib1)
        line.delete(pbLnFib1)
    if not na(pbLnFibLeg)
        line.delete(pbLnFibLeg)
    if not na(pbLbl)
        label.delete(pbLbl)
    if not na(pbLbl0)
        label.delete(pbLbl0)
    if not na(pbLbl1)
        label.delete(pbLbl1)
    if not na(pbStateLbl)
        label.delete(pbStateLbl)

if newDay
    suDir := 0
    suBar := na
    suEntry := na
    suStop := na
    pendStop := na
    pendTp := na
    suLeft := false
    suLeavePx := na
    manualReady := false
    manualState := "—"
    suSweepTag := "—"
    suPathB := false
    pbArmedToday := false
    pbDir := 0
    pbManip := false
    pbLeft := false
    pbPierceAbove := false
    pbPierceBelow := false
    pbHi := na
    pbLo := na
    pbFibHi := na
    pbFibLo := na
    pbFibLoBar := na
    pbFibHiBar := na
    pbOteLatched := false
    pbLatchWs := na
    pbLatchCe := na
    pbLatchEx := na
    pbLatchDir := 0
    pbLatchBar := na
    pbLatchTag := "—"
    pbState := "—"
    f_clearFib()
    pbLn62 := na
    pbLn705 := na
    pbLn79 := na
    pbLnFib0 := na
    pbLnFib1 := na
    pbLnFibLeg := na
    pbLbl := na
    pbLbl0 := na
    pbLbl1 := na
    pbStateLbl := na
    if not na(bxRb)
        box.delete(bxRb)
    if not na(lnRbCe)
        line.delete(lnRbCe)
    if not na(lblRbMark)
        label.delete(lblRbMark)
    bxRb := na
    lnRbCe := na
    lblRbMark := na
    rbLeft := na

// Path B can replace Path A (even if Path A already armed). Once Path B armed today, don't re-arm.
bool canArm = canPlace and suDir == 0
bool canArmPb = canPlace and (not i_oneTradeDay or not pbArmedToday) and (suDir == 0 or not suPathB)

// ─── Path B FIRST (primary) ──────────────────────────────────────────────────
// Stay alive after leave so fib keeps updating past 13:00; arming still gated by canPlace.
bool pbOn = i_pathB and not na(ko1000) and nyHhmm >= 1000 and (nyHhmm < i_winEnd or pbLeft)
float pbOteLo = na
float pbOteHi = na
float pbOteMid = na
bool koInOte = false

if pbOn
    pbHi := na(pbHi) ? high : math.max(pbHi, high)
    pbLo := na(pbLo) ? low : math.min(pbLo, low)
    if high > ko1000
        pbPierceAbove := true
        pbManip := true
    if low < ko1000
        pbPierceBelow := true
        pbManip := true
    if pbManip and not pbLeft and barstate.isconfirmed and nyHhmm < i_winEnd
        if pbPierceAbove and close < ko1000
            pbLeft := true
            pbDir := -1
            pbFibHi := pbHi
            pbFibLo := pbLo
            pbFibLoBar := bar_index
            pbFibHiBar := bar_index
        else if pbPierceBelow and close > ko1000
            pbLeft := true
            pbDir := 1
            pbFibHi := pbHi
            pbFibLo := pbLo
            pbFibLoBar := bar_index
            pbFibHiBar := bar_index
        // Path B leave steals the day from Path A
        if pbLeft and not suPathB and suDir != 0
            suDir := 0
            suBar := na
            suEntry := na
            suStop := na
            pendStop := na
            pendTp := na
            suLeft := false
            suLeavePx := na
            manualReady := false
            manualState := "—"
            suSweepTag := "—"
    if pbLeft
        if pbDir == 1 and high >= pbFibHi
            pbFibHi := high
            pbFibHiBar := bar_index
        if pbDir == -1 and low <= pbFibLo
            pbFibLo := low
            pbFibLoBar := bar_index
    float pbRange = not na(pbFibHi) and not na(pbFibLo) ? pbFibHi - pbFibLo : na
    if pbLeft
        if not na(pbRange) and pbRange > 0
            if pbDir == -1
                pbOteLo := pbFibLo + pbRange * 0.62
                pbOteHi := pbFibLo + pbRange * 0.79
                pbOteMid := pbFibLo + pbRange * 0.705
            else
                pbOteLo := pbFibHi - pbRange * 0.79
                pbOteHi := pbFibHi - pbRange * 0.62
                pbOteMid := pbFibHi - pbRange * 0.705
            bool koInBand = ko1000 >= pbOteLo - i_pathBAlign and ko1000 <= pbOteHi + i_pathBAlign
            if koInBand
                pbOteLatched := true
            koInOte := not i_pathBReqOte or koInBand or pbOteLatched
        else
            koInOte := not i_pathBReqOte

    bool nearKo15B = f_nearKo(h15, ko1000) or f_nearKo(wsB15, ko1000) or (not na(h15) and not na(wsB15) and f_nearKo((h15 + wsB15) * 0.5, ko1000))
    bool nearKo15U = f_nearKo(l15, ko1000) or f_nearKo(wsU15, ko1000) or (not na(l15) and not na(wsU15) and f_nearKo((l15 + wsU15) * 0.5, ko1000))
    bool nearKo5B = f_nearKo(h5, ko1000) or f_nearKo(wsB5, ko1000) or (not na(h5) and not na(wsB5) and f_nearKo((h5 + wsB5) * 0.5, ko1000))
    bool nearKo5U = f_nearKo(l5, ko1000) or f_nearKo(wsU5, ko1000) or (not na(l5) and not na(wsU5) and f_nearKo((l5 + wsU5) * 0.5, ko1000))
    bool nearKo1B = f_nearKo(h1, ko1000) or f_nearKo(wsB1, ko1000) or (not na(h1) and not na(wsB1) and f_nearKo((h1 + wsB1) * 0.5, ko1000))
    bool nearKo1U = f_nearKo(l1, ko1000) or f_nearKo(wsU1, ko1000) or (not na(l1) and not na(wsU1) and f_nearKo((l1 + wsU1) * 0.5, ko1000))

    if pbLeft and koInOte and barstate.isconfirmed
        if i_pathBUse1 and new1Bar and b1 and nearKo1B
            pbLatchWs := wsB1
            pbLatchEx := h1
            pbLatchCe := (h1 + wsB1) * 0.5
            pbLatchDir := -1
            pbLatchBar := bar_index
            pbLatchTag := "PathB · 10:00 · 1RB"
        if i_pathBUse1 and new1Bar and u1 and nearKo1U
            pbLatchWs := wsU1
            pbLatchEx := l1
            pbLatchCe := (l1 + wsU1) * 0.5
            pbLatchDir := 1
            pbLatchBar := bar_index
            pbLatchTag := "PathB · 10:00 · 1RB"
        if i_pathBUse5 and new5Bar and b5 and nearKo5B
            pbLatchWs := wsB5
            pbLatchEx := h5
            pbLatchCe := (h5 + wsB5) * 0.5
            pbLatchDir := -1
            pbLatchBar := bar_index
            pbLatchTag := "PathB · 10:00 · 5RB"
        if i_pathBUse5 and new5Bar and u5 and nearKo5U
            pbLatchWs := wsU5
            pbLatchEx := l5
            pbLatchCe := (l5 + wsU5) * 0.5
            pbLatchDir := 1
            pbLatchBar := bar_index
            pbLatchTag := "PathB · 10:00 · 5RB"
        if i_pathBUse15 and new15Bar and b15 and nearKo15B
            pbLatchWs := wsB15
            pbLatchEx := h15
            pbLatchCe := (h15 + wsB15) * 0.5
            pbLatchDir := -1
            pbLatchBar := bar_index
            pbLatchTag := "PathB · 10:00 · 15RB"
        if i_pathBUse15 and new15Bar and u15 and nearKo15U
            pbLatchWs := wsU15
            pbLatchEx := l15
            pbLatchCe := (l15 + wsU15) * 0.5
            pbLatchDir := 1
            pbLatchBar := bar_index
            pbLatchTag := "PathB · 10:00 · 15RB"

    if not na(pbLatchBar) and bar_index - pbLatchBar > i_tapTimeout
        pbLatchWs := na
        pbLatchCe := na
        pbLatchEx := na
        pbLatchDir := 0
        pbLatchBar := na
        pbLatchTag := "—"

    if canArmPb and koInOte and pbDir == -1 and biasOkShort and barstate.isconfirmed and pbLatchDir == -1 and not na(pbLatchWs)
        [entryPx, stopPx] = f_plan(pbLatchWs, pbLatchCe, pbLatchEx, true)
        if not na(entryPx)
            float riskPts0 = math.abs(stopPx - entryPx)
            suDir := -1
            suWickStart := pbLatchWs
            suCe := pbLatchCe
            suExtreme := pbLatchEx
            suEntry := entryPx
            suStop := stopPx
            pendStop := stopPx
            pendTp := entryPx - i_rr * riskPts0
            suBar := bar_index
            suLeft := true
            suLeavePx := pbFibLo
            suPathB := true
            suSweepTag := pbLatchTag
            manualReady := true
            manualState := f_shadowArmLabel()
            pbArmedToday := true
            pbLatchDir := 0
            pbState := "ARMED short"

    if canArmPb and koInOte and pbDir == 1 and biasOkLong and (suDir == 0 or not suPathB) and barstate.isconfirmed and pbLatchDir == 1 and not na(pbLatchWs)
        [entryPx, stopPx] = f_plan(pbLatchWs, pbLatchCe, pbLatchEx, false)
        if not na(entryPx)
            float riskPts0 = math.abs(stopPx - entryPx)
            suDir := 1
            suWickStart := pbLatchWs
            suCe := pbLatchCe
            suExtreme := pbLatchEx
            suEntry := entryPx
            suStop := stopPx
            pendStop := stopPx
            pendTp := entryPx + i_rr * riskPts0
            suBar := bar_index
            suLeft := true
            suLeavePx := pbFibHi
            suPathB := true
            suSweepTag := pbLatchTag
            manualReady := true
            manualState := f_shadowArmLabel()
            pbArmedToday := true
            pbLatchDir := 0
            pbState := "ARMED long"

    if suPathB and manualReady
        pbState := suDir == -1 ? "ARMED short" : "ARMED long"
    else if not pbManip
        pbState := "B wait manip"
    else if not pbLeft
        pbState := "B wait leave"
    else if i_pathBReqOte and not koInOte
        pbState := "B KO outside OTE"
    else if not canArmPb
        pbState := "B blocked"
    else if pbLatchDir != 0
        pbState := "B latch ready"
    else
        pbState := pbDir == -1 ? "B wait bear RB@KO" : "B wait bull RB@KO"

    if i_pathBShowState
        if na(pbStateLbl)
            pbStateLbl := label.new(bar_index, high, pbState, style = label.style_label_down, color = color.new(#0f172a, 20), textcolor = color.white, size = size.small)
        else
            label.set_xy(pbStateLbl, bar_index, high)
            label.set_text(pbStateLbl, pbState)
else if i_pathBShowState and not na(pbStateLbl)
    if suPathB and suDir != 0
        label.set_text(pbStateLbl, suDir == -1 ? "ARMED short" : "ARMED long")
        label.set_xy(pbStateLbl, bar_index, high)
    else
        label.set_text(pbStateLbl, nyHhmm < 1000 ? "B before 10:00" : "B window closed")
        label.set_xy(pbStateLbl, bar_index, high)

// Path B fib (after leave — stays up)
if i_pathBShowFib and pbLeft and not na(pbFibHi) and not na(pbFibLo) and pbFibHi > pbFibLo
    float rng = pbFibHi - pbFibLo
    if pbDir == -1
        pbOteLo := pbFibLo + rng * 0.62
        pbOteHi := pbFibLo + rng * 0.79
        pbOteMid := pbFibLo + rng * 0.705
    else
        pbOteLo := pbFibHi - rng * 0.79
        pbOteHi := pbFibHi - rng * 0.62
        pbOteMid := pbFibHi - rng * 0.705
    int x0 = na(pbFibLoBar) ? bar_index - 8 : pbFibLoBar
    int x1 = na(pbFibHiBar) ? bar_index : pbFibHiBar
    int xL = math.min(x0, x1)
    int xR = math.max(bar_index + 6, math.max(x0, x1) + 4)
    color fibCol = pbDir == -1 ? c_bear : c_bull
    string howTo = pbDir == -1 ? "FIB LO→HI · sell 0.62–0.79" : "FIB LO→HI · buy 0.62–0.79"
    float midY = (pbFibHi + pbFibLo) * 0.5
    if na(pbLnFib0)
        pbLnFib0 := line.new(xL, pbFibLo, xR, pbFibLo, color = fibCol, width = 2)
        pbLnFib1 := line.new(xL, pbFibHi, xR, pbFibHi, color = fibCol, width = 2)
        pbLnFibLeg := line.new(x0, pbFibLo, x1, pbFibHi, color = color.new(fibCol, 20), width = 2, style = line.style_dashed)
        pbLbl0 := label.new(xR, pbFibLo, "FIB LO (0)", style = label.style_label_left, color = color.new(fibCol, 0), textcolor = color.white, size = size.small)
        pbLbl1 := label.new(xR, pbFibHi, "FIB HI (1)", style = label.style_label_left, color = color.new(fibCol, 0), textcolor = color.white, size = size.small)
        pbLbl := label.new(xR, midY, howTo, style = label.style_label_left, color = color.new(#854d0e, 0), textcolor = #facc15, size = size.small)
        pbLn62 := line.new(xL, pbOteLo, xR, pbOteLo, color = #e2e8f0, width = 1, style = line.style_dotted)
        pbLn705 := line.new(xL, pbOteMid, xR, pbOteMid, color = #facc15, width = 2, style = line.style_dotted)
        pbLn79 := line.new(xL, pbOteHi, xR, pbOteHi, color = #e2e8f0, width = 1, style = line.style_dotted)
    else
        line.set_xy1(pbLnFib0, xL, pbFibLo)
        line.set_xy2(pbLnFib0, xR, pbFibLo)
        line.set_xy1(pbLnFib1, xL, pbFibHi)
        line.set_xy2(pbLnFib1, xR, pbFibHi)
        line.set_xy1(pbLnFibLeg, x0, pbFibLo)
        line.set_xy2(pbLnFibLeg, x1, pbFibHi)
        label.set_xy(pbLbl0, xR, pbFibLo)
        label.set_xy(pbLbl1, xR, pbFibHi)
        label.set_xy(pbLbl, xR, midY)
        label.set_text(pbLbl, howTo)
        line.set_xy1(pbLn62, xL, pbOteLo)
        line.set_xy2(pbLn62, xR, pbOteLo)
        line.set_xy1(pbLn705, xL, pbOteMid)
        line.set_xy2(pbLn705, xR, pbOteMid)
        line.set_xy1(pbLn79, xL, pbOteHi)
        line.set_xy2(pbLn79, xR, pbOteHi)

// Keep Path B plan on chart until new day (do NOT wipe after 13:00 — that hid the morning trade)
// Soft invalidate only if stop is clearly blown while still in the entry window
if suPathB and suDir != 0 and canPlace and barstate.isconfirmed
    bool blown = (suDir == -1 and close > suStop) or (suDir == 1 and close < suStop)
    if blown and bar_index - suBar > 2
        // keep levels visible; just mark state
        manualState := "STOP side traded — review"
        manualReady := false

// ─── Path A (optional, only if Path B never left) ────────────────────────────
if i_pathA and not pbLeft and not pbArmedToday and canArm and barstate.isconfirmed and nyHhmm >= i_winStart and nyHhmm < i_winEnd
    if rb15Bear
        float tws = wsB15
        float tex = h15
        float tce = (h15 + wsB15) * 0.5
        [entryPx, stopPx] = f_plan(tws, tce, tex, true)
        if not na(entryPx)
            float riskPts0 = math.abs(stopPx - entryPx)
            suDir := -1
            suWickStart := tws
            suCe := tce
            suExtreme := tex
            suEntry := entryPx
            suStop := stopPx
            pendStop := stopPx
            pendTp := entryPx - i_rr * riskPts0
            suBar := bar_index
            suLeft := i_leaveR == 0
            suPathB := false
            suSweepTag := "PathA · 15RB"
            manualReady := suLeft
            manualState := suLeft ? f_shadowArmLabel() : "WAIT leave"
    else if rb15Bull and suDir == 0
        float tws = wsU15
        float tex = l15
        float tce = (l15 + wsU15) * 0.5
        [entryPx, stopPx] = f_plan(tws, tce, tex, false)
        if not na(entryPx)
            float riskPts0 = math.abs(stopPx - entryPx)
            suDir := 1
            suWickStart := tws
            suCe := tce
            suExtreme := tex
            suEntry := entryPx
            suStop := stopPx
            pendStop := stopPx
            pendTp := entryPx + i_rr * riskPts0
            suBar := bar_index
            suLeft := i_leaveR == 0
            suPathB := false
            suSweepTag := "PathA · 15RB"
            manualReady := suLeft
            manualState := suLeft ? f_shadowArmLabel() : "WAIT leave"

if i_pathA and not suPathB and not pbArmedToday and suDir != 0 and not na(suEntry)
    float riskPts = math.abs(suStop - suEntry)
    bool invalidated = (suDir == -1 and close > suStop) or (suDir == 1 and close < suStop)
    if invalidated or (canPlace and bar_index - suBar > i_tapTimeout)
        suDir := 0
        manualReady := false
        manualState := "—"
    else if not suLeft
        if suDir == -1 and low <= suEntry - i_leaveR * riskPts
            suLeft := true
            suLeavePx := low
        if suDir == 1 and high >= suEntry + i_leaveR * riskPts
            suLeft := true
            suLeavePx := high
        manualReady := false
        manualState := "WAIT leave"
    else
        manualReady := true
        manualState := f_shadowArmLabel()

// ─── Armed RB box ────────────────────────────────────────────────────────────
if i_showSig and suDir != 0 and not na(suBar) and not na(suExtreme) and not na(suWickStart)
    color col = suDir == -1 ? c_bear : c_bull
    float top = math.max(suExtreme, suWickStart)
    float bot = math.min(suExtreme, suWickStart)
    color fillC = i_rbNoFill ? color.new(col, 100) : color.new(col, 90)
    if na(bxRb) or rbLeft != suBar
        if not na(bxRb)
            box.delete(bxRb)
        if not na(lnRbCe)
            line.delete(lnRbCe)
        if not na(lblRbMark)
            label.delete(lblRbMark)
        rbLeft := suBar
        bxRb := box.new(suBar, top, suBar + i_rbExtend, bot, border_color = col, bgcolor = fillC, border_width = 2)
        lnRbCe := line.new(suBar, suCe, suBar + i_rbExtend, suCe, color = c_ce, width = 1, style = line.style_dotted)
        lblRbMark := label.new(suBar, top, suSweepTag, style = label.style_none, color = color.new(color.black, 100), textcolor = col, size = size.small)
    else
        box.set_right(bxRb, math.max(bar_index, suBar + 4))
        line.set_x2(lnRbCe, math.max(bar_index, suBar + 4))
else if suDir == 0 and not na(bxRb)
    box.delete(bxRb)
    line.delete(lnRbCe)
    label.delete(lblRbMark)
    bxRb := na
    lnRbCe := na
    lblRbMark := na
    rbLeft := na

// ─── Trade plan ──────────────────────────────────────────────────────────────
bool planLive = i_showPend and suDir != 0 and not na(suEntry) and not na(pendStop) and not na(pendTp)
bool isShadow = not dayAllowed
if planLive
    int xR = math.max(bar_index + 4, suBar + 16)
    color eCol = isShadow ? color.new(#fb923c, 0) : c_limit
    color sCol = isShadow ? color.new(#fb923c, 15) : c_stop
    color tCol = isShadow ? color.new(#94a3b8, 0) : c_tp
    string eTxt = "ENTRY · " + suSweepTag
    if na(planLeft) or planLeft != suBar
        planLeft := suBar
        if not na(planLnE)
            line.delete(planLnE)
        if not na(planLnS)
            line.delete(planLnS)
        if not na(planLnT)
            line.delete(planLnT)
        if not na(planLbE)
            label.delete(planLbE)
        if not na(planLbS)
            label.delete(planLbS)
        if not na(planLbT)
            label.delete(planLbT)
        if not na(planBxRisk)
            box.delete(planBxRisk)
        if not na(planBxRew)
            box.delete(planBxRew)
        planLnE := line.new(suBar, suEntry, xR, suEntry, color = eCol, width = 2)
        planLnS := line.new(suBar, pendStop, xR, pendStop, color = sCol, width = 2)
        planLnT := line.new(suBar, pendTp, xR, pendTp, color = tCol, width = 2)
        planLbE := label.new(xR, suEntry, eTxt, style = label.style_label_left, color = color.new(#0f172a, 0), textcolor = eCol, size = size.small)
        planLbS := label.new(xR, pendStop, "STOP", style = label.style_label_left, color = color.new(#0f172a, 0), textcolor = sCol, size = size.small)
        planLbT := label.new(xR, pendTp, "TP", style = label.style_label_left, color = color.new(#0f172a, 0), textcolor = tCol, size = size.small)
        planBxRisk := box.new(suBar, math.max(suEntry, pendStop), xR, math.min(suEntry, pendStop), border_color = color.new(sCol, 70), bgcolor = color.new(sCol, 92), border_width = 1)
        planBxRew := box.new(suBar, math.max(suEntry, pendTp), xR, math.min(suEntry, pendTp), border_color = color.new(tCol, 70), bgcolor = color.new(tCol, 94), border_width = 1)
    else
        line.set_x2(planLnE, xR)
        line.set_x2(planLnS, xR)
        line.set_x2(planLnT, xR)
        line.set_y1(planLnE, suEntry)
        line.set_y2(planLnE, suEntry)
        line.set_y1(planLnS, pendStop)
        line.set_y2(planLnS, pendStop)
        line.set_y1(planLnT, pendTp)
        line.set_y2(planLnT, pendTp)
        box.set_right(planBxRisk, xR)
        box.set_right(planBxRew, xR)
        label.set_xy(planLbE, xR, suEntry)
        label.set_xy(planLbS, xR, pendStop)
        label.set_xy(planLbT, xR, pendTp)
        label.set_text(planLbE, eTxt)
else if suDir == 0 and not na(planLnE)
    line.delete(planLnE)
    line.delete(planLnS)
    line.delete(planLnT)
    label.delete(planLbE)
    label.delete(planLbS)
    label.delete(planLbT)
    box.delete(planBxRisk)
    box.delete(planBxRew)
    planLnE := na
    planLnS := na
    planLnT := na
    planLbE := na
    planLbS := na
    planLbT := na
    planBxRisk := na
    planBxRew := na
    planLeft := na

// ─── PDH / PDL ───────────────────────────────────────────────────────────────
float usePdh = not na(pdhLvl) ? pdhLvl : prevDayHigh
float usePdl = not na(pdlLvl) ? pdlLvl : prevDayLow
if i_showPdhPdl and newDay
    if not na(lnPdh)
        line.delete(lnPdh)
    if not na(lnPdl)
        line.delete(lnPdl)
    if not na(lblPdh)
        label.delete(lblPdh)
    if not na(lblPdl)
        label.delete(lblPdl)
    lnPdh := na
    lnPdl := na
    lblPdh := na
    lblPdl := na
    if not na(pdhOriginBar) and not na(usePdh)
        lnPdh := line.new(pdhOriginBar, usePdh, bar_index, usePdh, color = c_pdh, width = 2)
        lblPdh := label.new(bar_index, usePdh, "PDH", style = label.style_label_left, color = color.new(c_pdh, 0), textcolor = color.white, size = size.small)
    if not na(pdlOriginBar) and not na(usePdl)
        lnPdl := line.new(pdlOriginBar, usePdl, bar_index, usePdl, color = c_pdl, width = 2)
        lblPdl := label.new(bar_index, usePdl, "PDL", style = label.style_label_left, color = color.new(c_pdl, 0), textcolor = color.white, size = size.small)
if i_showPdhPdl and nyHhmm < i_flatTime
    if not na(lnPdh)
        line.set_x2(lnPdh, bar_index)
        label.set_xy(lblPdh, bar_index, usePdh)
    if not na(lnPdl)
        line.set_x2(lnPdl, bar_index)
        label.set_xy(lblPdl, bar_index, usePdl)

// ─── NWOG (current week only · Fri close → Sun 18:00 ET) ─────────────────────
f_nwogClearAll() =>
    while array.size(nwogBoxA) > 0
        box.delete(array.shift(nwogBoxA))
        line.delete(array.shift(nwogCeA))
        label.delete(array.shift(nwogLblA))
        array.shift(nwogTopA)
        array.shift(nwogBotA)
        array.shift(nwogHitHiA)
        array.shift(nwogHitLoA)
        array.shift(nwogFilledA)

f_nwogPush(float top, float bot, string tag) =>
    f_nwogClearAll()
    float hi = math.max(top, bot)
    float lo = math.min(top, bot)
    float ce = (hi + lo) * 0.5
    color col = #a78bfa
    array.push(nwogBoxA, box.new(bar_index, hi, bar_index + 4, lo, border_color = col, bgcolor = color.new(col, 88), border_width = 2))
    array.push(nwogCeA, line.new(bar_index, ce, bar_index + 4, ce, color = #c4b5fd, width = 1, style = line.style_dotted))
    array.push(nwogLblA, label.new(bar_index + 1, hi, tag, style = label.style_label_left, color = #5b21b6, textcolor = color.white, size = size.small))
    array.push(nwogTopA, hi)
    array.push(nwogBotA, lo)
    array.push(nwogHitHiA, false)
    array.push(nwogHitLoA, false)
    array.push(nwogFilledA, false)

// One gap per CME week: Sun 18:00 primary; Mon 09:30 only if Sunday never created one.
// At each new Sunday open, wipe last week's box so only the current week remains.
if i_showNwog and nwogSunOpenBar and barstate.isconfirmed
    nwogGapTime := na
    f_nwogClearAll()
bool nwogGapOk = i_showNwog and barstate.isconfirmed and not na(nwogFriClose) and math.abs(open - nwogFriClose) >= i_nwogMinPts
if nwogGapOk and nwogSunOpenBar
    nwogGapTime := time
    f_nwogPush(open, nwogFriClose, "NWOG · CE · Sun 18:00")
else if nwogGapOk and nwogMonFallback and na(nwogGapTime)
    nwogGapTime := time
    f_nwogPush(open, nwogFriClose, "NWOG · CE · Mon open")

if i_showNwog and array.size(nwogBoxA) > 0
    for i = 0 to array.size(nwogBoxA) - 1
        float hi = array.get(nwogTopA, i)
        float lo = array.get(nwogBotA, i)
        bool hitHi = array.get(nwogHitHiA, i) or high >= hi
        bool hitLo = array.get(nwogHitLoA, i) or low <= lo
        array.set(nwogHitHiA, i, hitHi)
        array.set(nwogHitLoA, i, hitLo)
        bool filled = hitHi and hitLo
        array.set(nwogFilledA, i, filled)
        box bx = array.get(nwogBoxA, i)
        line ln = array.get(nwogCeA, i)
        label lb = array.get(nwogLblA, i)
        float ce = (hi + lo) * 0.5
        box.set_right(bx, bar_index + 2)
        line.set_x2(ln, bar_index + 2)
        line.set_y1(ln, ce)
        line.set_y2(ln, ce)
        label.set_xy(lb, bar_index + 1, hi)
        if filled
            box.set_border_color(bx, #64748b)
            box.set_bgcolor(bx, color.new(#64748b, 92))
            label.set_text(lb, "NWOG filled")
            label.set_color(lb, #475569)
        else
            label.set_color(lb, #5b21b6)

bgcolor(nyHhmm == 1000 ? color.new(c_win10, 88) : na, title = "10:00")
plot(ko1000, "10:00 open", color.new(#d946ef, 35), style = plot.style_linebr)

alertcondition(manualReady and dayAllowed, title = "Morningstar ARMED", message = "Morningstar ARMED — {{ticker}} {{interval}}\nCheck bias checklist · click ENTRY/STOP/TP")
