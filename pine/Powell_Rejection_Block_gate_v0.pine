var array<bool> nwogFilledA = array.new_bool()

f_clearPlan(line lnE, line lnS, line lnT, line lnCe, label lbE, label lbS, label lbT, box bxR, box bxW, label fl, box bxRb, label lbRb) =>
    if not na(lnE)
        line.delete(lnE)
    if not na(lnS)
        line.delete(lnS)
    if not na(lnT)
        line.delete(lnT)
    if not na(lnCe)
        line.delete(lnCe)
    if not na(lbE)
        label.delete(lbE)
    if not na(lbS)
        label.delete(lbS)
    if not na(lbT)
        label.delete(lbT)
    if not na(bxR)
        box.delete(bxR)
    if not na(bxW)
        box.delete(bxW)
    if not na(fl)
        label.delete(fl)
    if not na(bxRb)
        box.delete(bxRb)
    if not na(lbRb)
        label.delete(lbRb)

// Wipe setups on calendar midnight only — 18:00 CME roll must NOT kill ENTRY/STOP/TP
if newCalDay
    suDir := 0
    suBar := na
    suEntry := na
    suStop := na
    pendStop := na
    pendTp := na
    suLeft := false
    manualReady := false
    manualState := "—"
    suSweepTag := "—"
    suPathB := false
    pbDir := 0
    pbManip := false
    pbLeft := false
    pbPierceAbove := false
    pbPierceBelow := false
    pbHi := na
    pbLo := na
    pbHiBar := na
    pbLoBar := na
    pbFibHi := na
    pbFibLo := na
    pbFibLoBar := na
    pbFibHiBar := na
    pbAway := 0.0
    pbLeaveBar := na
    pbLeaveTime := na
    pbAwayPeakBar := na
    pbAwayPeakTime := na
    pbFibLoTime := na
    pbFibHiTime := na
    pbReturned := false
    pbState := "—"
    eArmed := false
    eDir := 0
    eBar := na
    eTime := na
    eEndBar := na
    eEndTime := na
    eEntry := na
    eStop := na
    eTp := na
    eWs := na
    eCe := na
    eEx := na
    eTag := "—"
    eFill := 0
    eKpi := "—"
    ePlanLeft := na
    oArmed := false
    oDir := 0
    oBar := na
    oTime := na
    oEndBar := na
    oEndTime := na
    oEntry := na
    oStop := na
    oTp := na
    oWs := na
    oCe := na
    oEx := na
    oTag := "—"
    oFill := 0
    oKpi := "—"
    oPlanLeft := na
    f_clearPlan(eLnE, eLnS, eLnT, eLnCe, eLbE, eLbS, eLbT, eBxRisk, eBxRew, eFillLbl, eBxRb, eLblRb)
    f_clearPlan(oLnE, oLnS, oLnT, oLnCe, oLbE, oLbS, oLbT, oBxRisk, oBxRew, oFillLbl, oBxRb, oLblRb)
    if not na(eLbCe)
        label.delete(eLbCe)
    if not na(oLbCe)
        label.delete(oLbCe)
    eLbCe := na
    oLbCe := na
    eLnE := na
    eLnS := na
    eLnT := na
    eLnCe := na
    eLbE := na
    eLbS := na
    eLbT := na
    eBxRisk := na
    eBxRew := na
    eFillLbl := na
    eBxRb := na
    eLblRb := na
    oLnE := na
    oLnS := na
    oLnT := na
    oLnCe := na
    oLbE := na
    oLbS := na
    oLbT := na
    oBxRisk := na
    oBxRew := na
    oFillLbl := na
    oBxRb := na
    oLblRb := na
    if not na(pbLn62)
        line.delete(pbLn62)
    if not na(pbLn705)
        line.delete(pbLn705)
    if not na(pbLn79)
        line.delete(pbLn79)
    if not na(pbLnFib0)
        line.delete(pbLnFib0)
    if not na(pbLnFib1)
        line.delete(pbLnFib1)
    if not na(pbLnFibLeg)
