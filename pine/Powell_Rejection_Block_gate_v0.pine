f_clearPlan(line lnE, line lnS, line lnT, line lnCe, label lbE, label lbS, label lbT, box bxR, box bxW, label fl, box bxRb, label lbRb) =>
    if not na(lnE)
        line.delete(lnE)
    if not na(lnS)
        line.delete(lnS)
    if not na(lnT)
        line.delete(lnT)
    if not na(lnCe)
        line.delete(lnCe)
    if not na(lbE)
        label.delete(lbE)
    if not na(lbS)
        label.delete(lbS)
    if not na(lbT)
        label.delete(lbT)
    if not na(bxR)
        box.delete(bxR)
    if not na(bxW)
        box.delete(bxW)
    if not na(fl)
        label.delete(fl)
    if not na(bxRb)
        box.delete(bxRb)
    if not na(lbRb)
        label.delete(lbRb)

