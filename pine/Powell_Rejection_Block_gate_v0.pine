    if not na(eLbCe)
        label.delete(eLbCe)
    if not na(oLbCe)
        label.delete(oLbCe)
    eLbCe := na
    oLbCe := na
    eLnE := na
    eLnS := na
    eLnT := na
    eLnCe := na
    eLbE := na
    eLbS := na
    eLbT := na
    eBxRisk := na
    eBxRew := na
    eFillLbl := na
    eBxRb := na
    eLblRb := na
