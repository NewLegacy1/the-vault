    suBar := na
    suEntry := na
    suStop := na
    pendStop := na
    pendTp := na
    suLeft := false
    manualReady := false
    manualState := "—"
    suSweepTag := "—"
    suPathB := false
    pbDir := 0
    pbManip := false
    pbLeft := false
    pbPierceAbove := false
    pbPierceBelow := false
    pbHi := na
    pbLo := na
    pbHiBar := na
    pbLoBar := na
    pbFibHi := na
    pbFibLo := na
