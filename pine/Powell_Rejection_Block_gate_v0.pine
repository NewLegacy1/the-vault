//@version=6
// Powell Rejection Block · gate_v0 — copy of locked PRB v1 + regime-gate-v0
// DO NOT edit pine/Powell_Rejection_Block_v1.pine (locked live).
//
// EXTRA vs locked v1:
//   · Skip July & October (regime-gate-v0) — default OFF for Manual discretion
//     Lab PASS 2026-07-14 · STAND_DOWN calendar months 7 and 10 when ON
//   · Live UX: Manual ON still draws SHADOW boxes in Jul/Oct (and Mon skip) so
//     process / journal practice stays visible; strategy orders stay blocked.
//     Pair with PRB_Gate_LiveCoach_v0 for risk HUD (Coach does not find RBs).
//   · HTF structure TF (15/30/60/240) via request.security — Manual Auto = 15m;
//     Lab Auto = Chart (preserves Deep BT control). Draw-POI gate on Manual.
//   · Morningstar: Manual-only confluence grade (POI·4H·1m CISD·1m/5m IFVG) —
//     eyes only; never arms / blocks / sizes.
//
// CODED FROM THE SOP:
//   · Formal RB (T03): HTF candle sweeps / tags draw POI + rejection wick;
//     RB level = wick start; alt entry = wick CE (50% of wick); chart TF = timing
//   · Key opens (T02): 18:00 / midnight / 10:00 opens tracked as liquidity —
//     souping a key open counts as a sweep; optional proximity confluence
//   · Sweep pool: premarket H/L, prior-day H/L, key opens, rolling 20-bar swing
//   · Entry modes (T05): limit wick start (fills) / limit wick CE (risk) /
//     Auto (CE when wick-start stop > max) / CISD trigger (1m confirmation:
//     tap into RB zone, then close through prior opposing candle's open)
//   · Stop tiers (T03/T09): beyond wick extreme; skip if > max (default 20,
//     "25+ = hateful"); min-stop floor protects vs commission drag on 1m
//   · Targets 1:5 default (1:3 floor per fib rules if you lower it) · BE at +1R
//   · v1.3: Auto PDH/PDL draw bias (SOP §3 mechanical rule)
//   · v1.4: Give-back regime note — one-click trail toggle (2.0/1.5) + rolling
//     give-back counter in funnel table (real fills + ghost scratches)
//   · v1.9: Auto MNQ/NQ ticker anchor for bar-replay pointvalue misreads
//   · v1.10: BE +1R retest audit — missed 5R if orig stop held after BE scratch
//
// NOT CODEABLE (trade these manually — see PINE_GUIDE):
//   4H/1H narrative · open-proximity discretion · Forex Factory read ·
//   data H/L quality · equal highs/lows · NDOG/NWOG · MM model · daily SMT ·
//   fib anchoring · A+/B/C grading (Auto PDH/PDL covers §3 mechanical draw only)
strategy(
     title                   = "Morningstar (PRB gate_v0)",
     shorttitle              = "Morningstar",
     overlay                 = true,
     pyramiding              = 0,
     process_orders_on_close = true,
     calc_on_every_tick      = false,
     max_bars_back           = 5000,
     initial_capital         = 50000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     commission_type         = strategy.commission.cash_per_contract,
     commission_value        = 0.62,
     slippage                = 1,
     margin_long             = 0,
     margin_short            = 0,
     max_lines_count         = 300,
     max_boxes_count         = 300,
     max_labels_count        = 500)

// ─── Inputs ──────────────────────────────────────────────────────────────────
i_winStart  = input.int(1000, "Entries from (HHMM) — SOP: wait for 10:00", minval = 0, maxval = 2359, group = "Session (NY time)")
i_winEnd    = input.int(1130, "Last order (HHMM)", minval = 0, maxval = 2359, group = "Session (NY time)")
i_flatTime  = input.int(1555, "Flat by (HHMM)", minval = 0, maxval = 2359, group = "Session (NY time)")
i_oneTradeDay = input.bool(true, "Max 1 trade per day", group = "Session (NY time)")
i_skipMonday  = input.bool(true, "Skip Mondays (SOP: lower expectancy)", group = "Session (NY time)")
i_skipJulOct  = input.bool(false, "Skip July & October (regime-gate-v0)", group = "Session (NY time)", tooltip = "Lab used ON (2026-07-14). Default OFF for Manual / bar-replay discretion — you take Jul/Oct if your checklist says so. Flip ON only for Lab-faithful Deep BT.")
i_biasMode    = input.string("Both", "Direction filter", options = ["Both", "Long only", "Short only", "Auto PDH/PDL draw"], group = "Session (NY time)", tooltip = "Manual practice: leave Both — bias is your discretionary checklist. Auto PDH/PDL = SOP §3 liquidity sweep draw (not turtle soup).")

grpRb = "Rejection block (formal, T03)"
i_structTf = input.string("Auto (Manual→15 · Lab→chart)", "RB structure TF", options = ["Auto (Manual→15 · Lab→chart)", "Chart", "15", "30", "60", "240"], group = grpRb, tooltip = "SOP: wick CEs live on 15m/30m/1H/4H — not micro 5m locals. Manual Auto = 15m structure on a 5m chart. Lab Auto = Chart (preserves Deep BT control).")
i_minWickPts = input.float(5.0, "Min chart-TF wick (pts) — Lab/Chart mode", minval = 0.0, step = 0.5, group = grpRb)
i_minWick15 = input.float(12.0, "Min 15m structure wick (pts)", minval = 4.0, step = 1.0, group = grpRb)
i_minWick30 = input.float(15.0, "Min 30m structure wick (pts)", minval = 6.0, step = 1.0, group = grpRb)
i_minWick60 = input.float(20.0, "Min 1H structure wick (pts)", minval = 8.0, step = 1.0, group = grpRb)
i_minWick240 = input.float(30.0, "Min 4H structure wick (pts)", minval = 10.0, step = 1.0, group = grpRb)
i_localLen   = input.int(12, "RB must be extreme of last N bars (structure TF)", minval = 4, maxval = 50, group = grpRb)
i_reqSweep   = input.bool(true, "Require liquidity sweep on RB candle", group = grpRb, tooltip = "Structure candle must wick through a liquidity level and close back.")
i_reqDrawPoi = input.bool(true, "Require draw POI at HTF RB (Manual)", group = grpRb, tooltip = "Manual only: RB extreme must tag unfinished PDH/PDL · PM H/L · key open. Kills mid-trend micro reversals with no nearby draw. Lab (Manual OFF) ignores this.")
i_poiPts     = input.float(12.0, "Draw POI proximity (pts)", minval = 2.0, step = 1.0, group = grpRb)
i_blockCounterDraw = input.bool(true, "Block RB against unfinished PD draw", group = grpRb, tooltip = "If PDH was swept (draw→lows), block longs; if PDL swept (draw→highs), block shorts — even when Direction=Both.")
i_confClose  = input.bool(true, "Require confirming close (bear RB closes down)", group = grpRb)
i_leaveR     = input.float(1.0, "Price must leave by N×risk before limit arms (0 = arm at once)", minval = 0.0, step = 0.25, group = grpRb, tooltip = "SOP: 'wait for price to leave, then retest the RB'. Kills same-bar blow-through fills.")
i_strictLeave = input.bool(false, "Strict retest: leave must happen AFTER the RB candle", group = grpRb, tooltip = "Big-bodied RB candles satisfy the leave distance by themselves, arming the limit instantly. Strict mode requires the departure on a later bar.")
i_maxApproachR = input.float(0.0, "Approach guard: pause limit unless close is within N×risk (0 = off)", minval = 0.0, step = 0.5, group = grpRb)
i_tapTimeout = input.int(24, "Setup expires after N chart bars", minval = 4, maxval = 120, group = grpRb)

i_useRollSweep = input.bool(false, "Rolling 20-bar swing counts as sweep liquidity (noisy)", group = "Key opens (T02)")
i_useKoSweep = input.bool(true, "Key opens count as sweep liquidity", group = "Key opens (T02)")
i_useAmOpens = input.bool(false, "8:30 / 9:00 / 9:30 opens count as sweep liquidity", group = "Key opens (T02)", tooltip = "SOP T13/T14: morning opens matter mainly on news days (CPI/PPI/NFP at 8:30) — the script can't read the calendar, so these add noise on quiet days. A/B before locking on.")
i_koConfl    = input.bool(false, "Require RB within N pts of a key open", group = "Key opens (T02)")
i_koConflPts = input.float(15.0, "Key-open proximity (pts)", minval = 1.0, step = 1.0, group = "Key opens (T02)")

i_useH4Wick    = input.bool(true, "Require developing 4H manipulation wick", group = "Context (T01)")
i_minH4WickPts = input.float(8.0, "Min 4H wick (pts) — 15 good / 8 grey / 2 bad", minval = 0.0, step = 0.5, group = "Context (T01)")

i_entryMode = input.string("Auto (CE if stop too big)", "Entry mode", options = ["Limit at wick start", "Limit at wick CE", "Auto (CE if stop too big)", "CISD trigger (for 1m)"], group = "Entry (T05)")

i_instrMode = input.string("Auto (chart symbol)", "Sizing mode", options = ["Auto (chart symbol)", "MNQ micro ($2/pt)", "NQ mini ($20/pt)"], group = "Instrument / contract size", tooltip = "Best practice: load MNQ1! or NQ1! on the chart and leave Auto. MNQ ≈ $2/point (micro), NQ ≈ $20/point (mini, 10×). NQ auto-caps at 6 contracts (TPT = 60 micros). Override only for what-if sizing on the same chart.")

i_maxStopPts = input.float(20.0, "Max stop (pts) — SOP: 25+ = skip/refine", minval = 2.0, step = 1.0, group = "Risk (TPT $50K engine)")
i_minStopPts = input.float(5.0, "Min stop (pts) — commission floor for 1m", minval = 0.0, step = 0.5, group = "Risk (TPT $50K engine)")
i_stopBufPts = input.float(2.0, "Stop buffer beyond wick (pts)", minval = 0.0, step = 0.25, group = "Risk (TPT $50K engine)")
i_rr         = input.float(5.0, "Target (R multiple) — SOP 1:5–1:7, floor 1:3", minval = 1.0, step = 0.25, group = "Risk (TPT $50K engine)")
i_evalMaxWinUsd = input.float(0.0, "Eval max win cap (USD, 0 = off)", minval = 0.0, step = 50.0, group = "Risk (TPT $50K engine)", tooltip = "Hard-caps TP so a full winner ≤ this USD. TPT eval: 1490 keeps best day under 50% while building toward $4k pass. Does not replace daily profit lock (that only blocks re-entry). After PRO pass, set 0 and use full Target R (e.g. 6R).")
i_beAtR      = input.float(1.0, "Breakeven at +N R (0 = off)", minval = 0.0, step = 0.25, group = "Risk (TPT $50K engine)")
i_trailStartR = input.float(0.0, "Trail: activate at +N R (0 = off, BE only)", minval = 0.0, step = 0.25, group = "Risk (TPT $50K engine)", tooltip = "FAILED A/B across 8 months (Dec–Jul): demoted winners (Jan 2/8, Feb 10, May 22, Jun 5 all reached full 5R after the trail would have cut them) cost ~$3,860 vs ~$2,820 recovered from scratches — net ≈ −$1,040. Leave at 0 (BE-only). May 22 hit the 5R target 10 min after the 2.0/1.5 trail exit.")
i_trailGapR   = input.float(1.5, "Trail: distance behind peak (R)", minval = 0.25, step = 0.25, group = "Risk (TPT $50K engine)", tooltip = "Smaller gap = locks more profit but cuts winners on normal pullbacks. 1.5R gap means a trade peaking at +3R exits no worse than +1.5R.")
i_riskUsd    = input.float(400.0, "Risk per trade (USD)", minval = 50.0, step = 50.0, group = "Risk (TPT $50K engine)")

i_trailRegime = input.bool(false, "Give-back regime: trail ON (2.0 / 1.5)", group = "Give-back regime (manual toggle)", tooltip = "One-click toggle for pop-and-fade months (e.g. Mar 2026). When ON, overrides trail to activate at +2R with 1.5R gap regardless of the Risk inputs above. Default OFF — 8-month A/B favours BE-only. Turn ON when the give-back counter below hits the threshold.")
i_regimeGiveBackR = input.float(2.0, "Give-back: min peak (R) to count", minval = 1.0, step = 0.25, group = "Give-back regime (manual toggle)", tooltip = "Trade peaked at least this many R but gave back almost all of it (scratch / sub-1R exit).")
i_regimeLookback = input.int(10, "Give-back lookback (sessions)", minval = 3, maxval = 30, group = "Give-back regime (manual toggle)")
i_regimeThreshold = input.int(2, "Suggest trail when give-backs ≥", minval = 1, maxval = 8, group = "Give-back regime (manual toggle)", tooltip = "Funnel table turns orange when rolling give-backs reach this count while trail is OFF.")
i_maxContracts = input.int(60, "Max contracts (60 micros / 6 minis)", minval = 1, maxval = 60, group = "Risk (TPT $50K engine)", tooltip = "TPT $50K cap = 60 MNQ or 6 NQ. On NQ chart or NQ sizing mode, effective max is min(this, 6).")
i_dailyLossStop   = input.float(800.0, "Daily loss stop (USD)", minval = 0.0, step = 50.0, group = "Risk (TPT $50K engine)")
i_dailyProfitLock = input.float(1400.0, "Daily profit lock (USD)", minval = 0.0, step = 50.0, group = "Risk (TPT $50K engine)")

i_ghost     = input.bool(true, "Track near-miss setups (ghost trades)", group = "Missed-trade autopsy", tooltip = "Every RB candle that failed EXACTLY ONE filter is simulated as a ghost trade (same leave-retest, BE and 5R rules). The bottom-right table tallies wins/losses per rejection reason — it shows which filter is blocking profitable trades and which are earning their keep. Ghost fills are slightly conservative: same-bar stop+target resolves as a loss.")
i_showGhost = input.bool(false, "Mark ghosts on chart (G + reason #)", group = "Missed-trade autopsy", tooltip = "Off by default to keep the live chart clean — the bottom-right autopsy table still tallies every ghost.")

i_showSig   = input.bool(true, "Show RB wick zone (rejection block)", group = "Visuals")
i_rbExtend  = input.int(24, "RB zone extend (bars)", minval = 4, maxval = 80, group = "Visuals", tooltip = "How far the rejection-block box + CE line run forward from the RB candle.")
i_showCe    = input.bool(true, "Show CE dotted line in RB", group = "Visuals")
i_showTriggers = input.bool(true, "Show entry triggers (leave / retest / sweep / 4H)", group = "Visuals", tooltip = "Non-bias cues: which level was swept · 4H wick pts · LEAVE done · GO when leave-retest arms. Bias stays yours.")
i_showSoup  = input.bool(false, "Show sweep triangles", group = "Visuals")
i_showPdhPdl = input.bool(true, "Show PDH / PDL from wick origin", group = "Visuals", tooltip = "Line starts at the candle that printed prior-day high/low, then extends right. Green = PDH · Red = PDL.")
i_showLvls  = input.bool(false, "Show classic full-width PDH/PDL plots", group = "Visuals")
i_liveClean = input.bool(true, "Clean chart (no tables / bias marks)", group = "Visuals", tooltip = "ON: on-chart RB + ENTRY/STOP/TP · no funnel/MISSED tables · no bias labels.")
i_extraLvls = input.bool(false, "Show extra liquidity lines", group = "Visuals")
i_showPos   = input.bool(true, "Show open position boxes", group = "Visuals")
i_showPend  = input.bool(true, "Show trade plan on chart (LIMIT/STOP/TP)", group = "Visuals", tooltip = "Horizontal lines + labels at entry, stop, target — anchored on the setup bar.")
i_freezeTrades = input.bool(true, "Freeze closed trades on chart", group = "Visuals", tooltip = "Deep BT / Manual OFF: keep ENTRY/STOP/TP after each fill exits. Bar replay with Manual ON uses live plan only.")
i_showTable = input.bool(false, "Show diagnostic tables (Lab)", group = "Visuals")

grpCol = "Colors"
c_rbShortBd = input.color(#ef4444, "RB short border", group = grpCol)
c_rbShortBg = input.color(#ef4444, "RB short fill", group = grpCol)
c_rbLongBd  = input.color(#f97316, "RB long border", group = grpCol)
c_rbLongBg  = input.color(#f97316, "RB long fill", group = grpCol)
i_rbFillTrans = input.int(84, "RB fill transparency", minval = 50, maxval = 95, group = grpCol)
i_rbMarkTrans = input.int(60, "RB watermark text transparency", minval = 40, maxval = 90, group = grpCol)
c_ce     = input.color(#ffffff, "CE dotted", group = grpCol)
c_wickSt = input.color(#22d3ee, "Wick-start dashed", group = grpCol)
c_limit  = input.color(#ffffff, "LIMIT", group = grpCol)
c_stop   = input.color(#f87171, "STOP", group = grpCol)
c_tp     = input.color(#2dd4bf, "TP", group = grpCol)
c_pdh    = input.color(#22c55e, "PDH (prior high)", group = grpCol)
c_pdl    = input.color(#ef4444, "PDL (prior low)", group = grpCol)
c_leave  = input.color(#facc15, "LEAVE marker", group = grpCol)
c_go     = input.color(#a3e635, "GO marker", group = grpCol)
c_win10  = input.color(#eab308, "10:00 wash", group = grpCol)
c_winSess = input.color(#64748b, "Entry window wash", group = grpCol)

i_manualOnly = input.bool(false, "Manual levels only — NO orders (you click)", group = "Manual / discretionary replay", tooltip = "LIVE / bar replay: ON. Draws LIMIT/STOP/TP on chart — you decide bias and click. OFF = Deep BT CSV only.")
i_showBlockedBias = input.bool(false, "Mark bias-blocked RBs (journal)", group = "Manual / discretionary replay", tooltip = "Off by default — bias is your discretion, not chart clutter.")
i_manualAlerts = input.bool(false, "Alert when limit level arms", group = "Manual / discretionary replay", tooltip = "Fires only on live ARMED (not Jul/Oct or Monday SHADOW).")

grpMs = "Morningstar grade (Manual · eyes only)"
i_msGrade = input.bool(true, "Show Morningstar confluence grade", group = grpMs, tooltip = "Manual ON only. Labels POI · 4H · 1m CISD · 1m/5m IFVG and score n/5. NEVER arms, cancels, or blocks LIMIT/GO — you decide.")
i_msMarks = input.bool(true, "Mark each confluence when it hits", group = grpMs)
i_msBuf = input.float(8.0, "Confluence near RB zone (pts)", minval = 2.0, step = 1.0, group = grpMs)

float effTrailStartR = i_trailRegime ? 2.0 : i_trailStartR
float effTrailGapR = i_trailRegime ? 1.5 : i_trailGapR

// ─── Time ────────────────────────────────────────────────────────────────────
int nyHhmm  = hour(time, "America/New_York") * 100 + minute(time, "America/New_York")
int nyMonth = month(time, "America/New_York")
bool newDay = ta.change(time("D", "America/New_York")) != 0
bool inWindow = nyHhmm >= i_winStart and nyHhmm < i_winEnd
bool canPlace = nyHhmm < i_winEnd
bool mondayOk = not i_skipMonday or dayofweek(time, "America/New_York") != dayofweek.monday
bool monthOk  = not i_skipJulOct or (nyMonth != 7 and nyMonth != 10)
bool dayAllowed = mondayOk and monthOk

// ─── Liquidity references ────────────────────────────────────────────────────
float prevDayHigh = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
float prevDayLow  = request.security(syminfo.tickerid, "D", low[1],  lookahead = barmerge.lookahead_on)

// Track which chart bar printed today's H/L so PDH/PDL lines can start at that wick
var float curDayHigh = na
var float curDayLow = na
var int curDayHighBar = na
var int curDayLowBar = na
var float pdhLvl = na
var float pdlLvl = na
var int pdhOriginBar = na
var int pdlOriginBar = na

if newDay
    pdhLvl := curDayHigh
    pdlLvl := curDayLow
    pdhOriginBar := curDayHighBar
    pdlOriginBar := curDayLowBar
    curDayHigh := high
    curDayLow := low
    curDayHighBar := bar_index
    curDayLowBar := bar_index
else
    if na(curDayHigh) or high >= curDayHigh
        curDayHigh := high
        curDayHighBar := bar_index
    if na(curDayLow) or low <= curDayLow
        curDayLow := low
        curDayLowBar := bar_index

var float pmHigh = na
var float pmLow  = na
if newDay
    pmHigh := na
    pmLow := na
if nyHhmm < 930
    pmHigh := na(pmHigh) ? high : math.max(pmHigh, high)
    pmLow  := na(pmLow)  ? low  : math.min(pmLow, low)

// Key opens: 18:00 (best) / midnight / 10:00 (T02 trio)
// + optional 8:30 / 9:00 / 9:30 morning opens (T13/T14 — news days)
var float ko1800 = na
var float ko0000 = na
var float ko1000 = na
var float ko0830 = na
var float ko0900 = na
var float ko0930 = na
if nyHhmm >= 1800 and nyHhmm[1] < 1800
    ko1800 := open
if newDay
    ko0000 := open
if nyHhmm >= 1000 and nyHhmm[1] < 1000
    ko1000 := open
if nyHhmm >= 830 and nyHhmm[1] < 830
    ko0830 := open
if nyHhmm >= 900 and nyHhmm[1] < 900
    ko0900 := open
if nyHhmm >= 930 and nyHhmm[1] < 930
    ko0930 := open

float roll20High = ta.highest(high, 20)[1]
float roll20Low  = ta.lowest(low, 20)[1]

// Sweep = liquidity take: wick through a level, close back on the origin side.
// This is NOT "turtle soup" (external HL/LH + next-bar displacement). PRB Lab
// only requires this wick-through-close-back for the sweep filter and Auto bias.
f_soupAbove(float lvl) => not na(lvl) and high > lvl and close < lvl
f_soupBelow(float lvl) => not na(lvl) and low < lvl and close > lvl

// First matching liquidity tag for checklist HUD (priority: PD → PM → KO → roll)
f_sweepAboveTag() =>
    f_soupAbove(prevDayHigh) ? "PDH" : f_soupAbove(pmHigh) ? "PMH" : i_useKoSweep and f_soupAbove(ko1000) ? "10:00" : i_useKoSweep and f_soupAbove(ko0000) ? "00:00" : i_useKoSweep and f_soupAbove(ko1800) ? "18:00" : i_useAmOpens and f_soupAbove(ko0930) ? "9:30" : i_useAmOpens and f_soupAbove(ko0900) ? "9:00" : i_useAmOpens and f_soupAbove(ko0830) ? "8:30" : i_useRollSweep and f_soupAbove(roll20High) ? "Roll20H" : "—"

f_sweepBelowTag() =>
    f_soupBelow(prevDayLow) ? "PDL" : f_soupBelow(pmLow) ? "PML" : i_useKoSweep and f_soupBelow(ko1000) ? "10:00" : i_useKoSweep and f_soupBelow(ko0000) ? "00:00" : i_useKoSweep and f_soupBelow(ko1800) ? "18:00" : i_useAmOpens and f_soupBelow(ko0930) ? "9:30" : i_useAmOpens and f_soupBelow(ko0900) ? "9:00" : i_useAmOpens and f_soupBelow(ko0830) ? "8:30" : i_useRollSweep and f_soupBelow(roll20Low) ? "Roll20L" : "—"

bool sweptAbove = f_soupAbove(pmHigh) or f_soupAbove(prevDayHigh) or (i_useRollSweep and f_soupAbove(roll20High)) or (i_useKoSweep and (f_soupAbove(ko1800) or f_soupAbove(ko0000) or f_soupAbove(ko1000))) or (i_useAmOpens and (f_soupAbove(ko0830) or f_soupAbove(ko0900) or f_soupAbove(ko0930)))
bool sweptBelow = f_soupBelow(pmLow) or f_soupBelow(prevDayLow) or (i_useRollSweep and f_soupBelow(roll20Low)) or (i_useKoSweep and (f_soupBelow(ko1800) or f_soupBelow(ko0000) or f_soupBelow(ko1000))) or (i_useAmOpens and (f_soupBelow(ko0830) or f_soupBelow(ko0900) or f_soupBelow(ko0930)))

// Auto PDH/PDL draw (SOP §3): soup + close back within → opposing side is the draw
var int dayDraw = 0
if newDay
    dayDraw := 0
if f_soupAbove(prevDayHigh)
    dayDraw := -1
if f_soupBelow(prevDayLow)
    dayDraw := 1

bool biasOkShort = i_biasMode != "Long only" and (i_biasMode != "Auto PDH/PDL draw" or dayDraw <= 0)
bool biasOkLong  = i_biasMode != "Short only" and (i_biasMode != "Auto PDH/PDL draw" or dayDraw >= 0)
bool autoBiasOn  = i_biasMode == "Auto PDH/PDL draw"

// Key-open proximity (optional confluence)
f_nearKo(float px) =>
    (not na(ko1800) and math.abs(px - ko1800) <= i_koConflPts) or (not na(ko0000) and math.abs(px - ko0000) <= i_koConflPts) or (not na(ko1000) and math.abs(px - ko1000) <= i_koConflPts)

// ─── Developing 4H manipulation wick (T01) ───────────────────────────────────
var float h4Open = na
var float h4High = na
var float h4Low  = na
if ta.change(time("240")) != 0
    h4Open := open
    h4High := high
    h4Low := low
else
    h4High := math.max(nz(h4High, high), high)
    h4Low := math.min(nz(h4Low, low), low)
float h4UpperWick = nz(h4High, high) - math.max(nz(h4Open, open), close)
float h4LowerWick = math.min(nz(h4Open, open), close) - nz(h4Low, low)
bool h4OkBear = not i_useH4Wick or h4UpperWick >= i_minH4WickPts
bool h4OkBull = not i_useH4Wick or h4LowerWick >= i_minH4WickPts

// ─── Formal rejection block (T03) — chart OR HTF structure ───────────────────
// SOP: wick CE hunt on 15m/30m/1H/4H; chart TF only for leave-retest / fills.
// Manual Auto → 15m. Lab (Manual OFF) Auto → Chart (Deep BT control preserved).
f_effStruct() =>
    i_structTf == "Auto (Manual→15 · Lab→chart)" ? (i_manualOnly ? "15" : "Chart") : i_structTf

string structTf = f_effStruct()
bool useChartRb = structTf == "Chart"
string structLabel = useChartRb ? "Chart" : structTf == "15" ? "15m" : structTf == "30" ? "30m" : structTf == "60" ? "1H" : "4H"

// Closed HTF candle pack (lookahead_off · [1] = last completed structure bar).
// Always request 15/30/60/240 — Pine forbids dynamic TF strings in request.security.
f_htfPack(float minW) =>
    float o1 = open[1]
    float h1 = high[1]
    float l1 = low[1]
    float c1 = close[1]
    float uw = h1 - math.max(o1, c1)
    float lw = math.min(o1, c1) - l1
    bool locH = h1 >= ta.highest(high, i_localLen)[1]
    bool locL = l1 <= ta.lowest(low, i_localLen)[1]
    bool bear = locH and uw >= minW and (not i_confClose or c1 < o1)
    bool bull = locL and lw >= minW and (not i_confClose or c1 > o1)
    [bear, bull, h1, l1, math.max(o1, c1), math.min(o1, c1), uw, lw]

[b15, u15, h15, l15, wsB15, wsU15, uw15, lw15] = request.security(syminfo.tickerid, "15", f_htfPack(i_minWick15), barmerge.gaps_off, barmerge.lookahead_off)
[b30, u30, h30, l30, wsB30, wsU30, uw30, lw30] = request.security(syminfo.tickerid, "30", f_htfPack(i_minWick30), barmerge.gaps_off, barmerge.lookahead_off)
[b60, u60, h60, l60, wsB60, wsU60, uw60, lw60] = request.security(syminfo.tickerid, "60", f_htfPack(i_minWick60), barmerge.gaps_off, barmerge.lookahead_off)
[b240, u240, h240, l240, wsB240, wsU240, uw240, lw240] = request.security(syminfo.tickerid, "240", f_htfPack(i_minWick240), barmerge.gaps_off, barmerge.lookahead_off)

// Morningstar LTF tells (eyes only — never gate arming)
f_msLtfPack() =>
    bool prevBull = close[1] > open[1]
    bool prevBear = close[1] < open[1]
    bool cisdBear = prevBull and close < open[1]
    bool cisdBull = prevBear and close > open[1]
    // IFVG: close through a fresh 3-candle FVG (bullish FVG inverted → bearish IFVG)
    bool ifvgBear = low[1] > high[3] and close < high[3]
    bool ifvgBull = high[1] < low[3] and close > low[3]
    [cisdBear, cisdBull, ifvgBear, ifvgBull, close]

f_msIfvgOnly() =>
    bool ifvgBear = low[1] > high[3] and close < high[3]
    bool ifvgBull = high[1] < low[3] and close > low[3]
    [ifvgBear, ifvgBull, close]

[ms1CisdBear, ms1CisdBull, ms1IfvgBear, ms1IfvgBull, ms1Close] = request.security(syminfo.tickerid, "1", f_msLtfPack(), barmerge.gaps_off, barmerge.lookahead_off)
[ms5IfvgBear, ms5IfvgBull, ms5Close] = request.security(syminfo.tickerid, "5", f_msIfvgOnly(), barmerge.gaps_off, barmerge.lookahead_off)

float cUpperWick = high - math.max(open, close)
float cLowerWick = math.min(open, close) - low
bool cLocalHigh = high >= ta.highest(high, i_localLen)
bool cLocalLow  = low <= ta.lowest(low, i_localLen)
bool cBearRaw = inWindow and cLocalHigh and cUpperWick >= i_minWickPts and (not i_confClose or close < open)
bool cBullRaw = inWindow and cLocalLow and cLowerWick >= i_minWickPts and (not i_confClose or close > open)

// Aliases for ghost autopsy (chart-TF micro RBs)
bool localHigh = cLocalHigh
bool localLow = cLocalLow
float upperWick = cUpperWick
float lowerWick = cLowerWick

string htfKey = structTf == "Chart" ? "15" : structTf
bool htfBarClosed = not useChartRb and ta.change(time(htfKey, "America/New_York")) != 0
bool hBear = htfKey == "15" ? b15 : htfKey == "30" ? b30 : htfKey == "60" ? b60 : b240
bool hBull = htfKey == "15" ? u15 : htfKey == "30" ? u30 : htfKey == "60" ? u60 : u240
float hExtHi = htfKey == "15" ? h15 : htfKey == "30" ? h30 : htfKey == "60" ? h60 : h240
float hExtLo = htfKey == "15" ? l15 : htfKey == "30" ? l30 : htfKey == "60" ? l60 : l240
float hWsBear = htfKey == "15" ? wsB15 : htfKey == "30" ? wsB30 : htfKey == "60" ? wsB60 : wsB240
float hWsBull = htfKey == "15" ? wsU15 : htfKey == "30" ? wsU30 : htfKey == "60" ? wsU60 : wsU240
float hUw = htfKey == "15" ? uw15 : htfKey == "30" ? uw30 : htfKey == "60" ? uw60 : uw240
float hLw = htfKey == "15" ? lw15 : htfKey == "30" ? lw30 : htfKey == "60" ? lw60 : lw240

bool rbBearRaw = useChartRb ? cBearRaw : (htfBarClosed and inWindow and hBear)
bool rbBullRaw = useChartRb ? cBullRaw : (htfBarClosed and inWindow and hBull)

// Structure wick geometry used for entry/stop (HTF when not Chart)
float rbExtBear = useChartRb ? high : hExtHi
float rbExtBull = useChartRb ? low : hExtLo
float rbWsBear = useChartRb ? math.max(open, close) : hWsBear
float rbWsBull = useChartRb ? math.min(open, close) : hWsBull
float rbUw = useChartRb ? cUpperWick : hUw
float rbLw = useChartRb ? cLowerWick : hLw
float rbCeBear = (rbExtBear + rbWsBear) * 0.5
float rbCeBull = (rbExtBull + rbWsBull) * 0.5

// Draw POI ranking — sell-side for shorts · buy-side for longs (Manual gate)
f_nearLvl(float px, float lvl) =>
    not na(px) and not na(lvl) and math.abs(px - lvl) <= i_poiPts

f_poiTagShort(float extreme) =>
    f_nearLvl(extreme, prevDayHigh) ? "PDH" : f_nearLvl(extreme, pmHigh) ? "PMH" : i_useKoSweep and f_nearLvl(extreme, ko1000) ? "10:00" : i_useKoSweep and f_nearLvl(extreme, ko0000) ? "00:00" : i_useKoSweep and f_nearLvl(extreme, ko1800) ? "18:00" : i_useAmOpens and f_nearLvl(extreme, ko0930) ? "9:30" : i_useRollSweep and f_nearLvl(extreme, roll20High) ? "Roll20H" : "—"

f_poiTagLong(float extreme) =>
    f_nearLvl(extreme, prevDayLow) ? "PDL" : f_nearLvl(extreme, pmLow) ? "PML" : i_useKoSweep and f_nearLvl(extreme, ko1000) ? "10:00" : i_useKoSweep and f_nearLvl(extreme, ko0000) ? "00:00" : i_useKoSweep and f_nearLvl(extreme, ko1800) ? "18:00" : i_useAmOpens and f_nearLvl(extreme, ko0930) ? "9:30" : i_useRollSweep and f_nearLvl(extreme, roll20Low) ? "Roll20L" : "—"

// Proximity POI first; chart-bar soup tag as fallback (Lab/Chart mode)
string poiShortRaw = f_poiTagShort(rbExtBear)
string poiLongRaw = f_poiTagLong(rbExtBull)
string poiShort = poiShortRaw != "—" ? poiShortRaw : (sweptAbove ? f_sweepAboveTag() : "—")
string poiLong = poiLongRaw != "—" ? poiLongRaw : (sweptBelow ? f_sweepBelowTag() : "—")

bool effReqDraw = i_manualOnly and i_reqDrawPoi and not useChartRb
bool poiOkShort = not effReqDraw or poiShort != "—"
bool poiOkLong = not effReqDraw or poiLong != "—"

// Block orphans against unfinished PD draw (even when Direction=Both)
// dayDraw -1 = PDH swept → draw to lows → block longs; +1 = PDL swept → draw to highs → block shorts
bool counterOkShort = not i_blockCounterDraw or dayDraw != 1
bool counterOkLong = not i_blockCounterDraw or dayDraw != -1

bool sweepOkShort = not i_reqSweep or sweptAbove or (not useChartRb and poiShort != "—")
bool sweepOkLong = not i_reqSweep or sweptBelow or (not useChartRb and poiLong != "—")

bool rbBear = rbBearRaw and h4OkBear and sweepOkShort and (not i_koConfl or f_nearKo(rbExtBear)) and biasOkShort and poiOkShort and counterOkShort
bool rbBull = rbBullRaw and h4OkBull and sweepOkLong and (not i_koConfl or f_nearKo(rbExtBull)) and biasOkLong and poiOkLong and counterOkLong

f_rbMetaTag(string poi) =>
    string base = structLabel
    poi != "—" ? base + " · " + poi : base

// ─── Trade accounting / TPT risk engine ──────────────────────────────────────
int totalTrades = strategy.opentrades + strategy.closedtrades
var int tradesAtDayStart = 0
var float dayStartEquity = na
if newDay
    tradesAtDayStart := totalTrades
    dayStartEquity := strategy.equity
float dayPnl = na(dayStartEquity) ? 0.0 : strategy.equity - dayStartEquity
bool dayOk = (i_dailyLossStop == 0 or dayPnl > -i_dailyLossStop) and (i_dailyProfitLock == 0 or dayPnl < i_dailyProfitLock)
bool roomToday = not i_oneTradeDay or totalTrades == tradesAtDayStart
bool flat = i_manualOnly or strategy.position_size == 0

// MNQ1! continuous contracts sometimes report syminfo.pointvalue as 20 (mini) in bar replay.
// Anchor Auto mode on ticker/root before trusting pointvalue alone.
f_tickerUpper() =>
    str.upper(syminfo.ticker)

f_rootUpper() =>
    str.upper(syminfo.root)

f_chartIsMnq() =>
    string t = f_tickerUpper()
    string r = f_rootUpper()
    str.contains(t, "MNQ") or str.contains(r, "MNQ")

f_chartIsNqMini() =>
    not f_chartIsMnq() and (str.contains(f_tickerUpper(), "NQ") or str.contains(f_rootUpper(), "NQ"))

f_autoPointVal() =>
    if f_chartIsMnq()
        2.0
    else if f_chartIsNqMini()
        20.0
    else
        float pv = syminfo.pointvalue
        pv >= 10.0 ? 20.0 : pv > 0 ? pv : 2.0

f_pointVal() =>
    switch i_instrMode
        "MNQ micro ($2/pt)" => 2.0
        "NQ mini ($20/pt)" => 20.0
        => f_autoPointVal()

f_isNqMini() =>
    i_instrMode == "NQ mini ($20/pt)" or (i_instrMode == "Auto (chart symbol)" and (f_chartIsNqMini() or (not f_chartIsMnq() and syminfo.pointvalue >= 10.0)))

f_instrTag() =>
    f_isNqMini() ? "NQ" : "MNQ"

f_effMaxContracts() =>
    f_isNqMini() ? math.min(i_maxContracts, 6) : i_maxContracts

f_qty(float stopPts) =>
    if stopPts < i_minStopPts or stopPts > i_maxStopPts
        0
    else
        float pv = f_pointVal()
        int q = math.floor(i_riskUsd / (stopPts * pv))
        math.min(q, f_effMaxContracts())

// Cap TP distance for eval consistency (TPT: best day < 50% of total at pass request)
f_effRr() =>
    float rrCap = i_evalMaxWinUsd > 0 and i_riskUsd > 0 ? i_evalMaxWinUsd / i_riskUsd : i_rr
    math.min(i_rr, rrCap)

// ─── Funnel counters ─────────────────────────────────────────────────────────
var int cntDays = 0
var int cntRbRaw = 0
var int cntRbCtx = 0
var int cntSkipStop = 0
var int cntOrders = 0
var int cntGuard = 0
var int cntBiasBlk = 0
if newDay
    cntDays += 1
if rbBearRaw or rbBullRaw
    cntRbRaw += 1
if rbBear or rbBull
    cntRbCtx += 1
if rbBearRaw and h4OkBear and sweepOkShort and (not i_koConfl or f_nearKo(rbExtBear)) and not biasOkShort
    cntBiasBlk += 1
if rbBullRaw and h4OkBull and sweepOkLong and (not i_koConfl or f_nearKo(rbExtBull)) and not biasOkLong
    cntBiasBlk += 1

// ─── Setup state ─────────────────────────────────────────────────────────────
// dir: 0 none · -1 short setup · +1 long setup
var int   suDir = 0
var float suWickStart = na
var float suCe = na
var float suExtreme = na
var float suEntry = na
var float suStop = na
var bool  suLeft = false
var int   suBar = na
var bool  suOrd = false
var bool  suTapped = false
var float openRiskPts = na
var float peakR = na
var float lockR = na
var float rtEntry = na
var float rtOrigStop = na
var float rtTp = na
var int rtDir = 0
var bool rtBeArmed = false
var bool rtBeRetest = false
var float pendStop = na
var float pendTp = na
var bool  manualReady = false
var string manualState = "—"
var string suSweepTag = "—"
var float suH4Pts = na

// Morningstar confluence latches (Manual grade only — never used in canArm / rb*)
var bool msPoi = false
var bool msH4 = false
var bool msCisd = false
var bool msIfvg1 = false
var bool msIfvg5 = false
var bool msMarkedCisd = false
var bool msMarkedIfvg1 = false
var bool msMarkedIfvg5 = false
var label lblMsGrade = na

bool isTrigger = i_entryMode == "CISD trigger (for 1m)"

if newDay
    suDir := 0
    suOrd := false
    manualReady := false
    manualState := "—"
    suSweepTag := "—"
    suH4Pts := na
    msPoi := false
    msH4 := false
    msCisd := false
    msIfvg1 := false
    msIfvg5 := false
    msMarkedCisd := false
    msMarkedIfvg1 := false
    msMarkedIfvg5 := false
    lblMsGrade := na
    if not i_manualOnly
        strategy.cancel_all()

// Manual ON: allow setup → SHADOW boxes when Jul/Oct or Monday would block live arms.
// Manual OFF (Deep BT): calendar gate still hard-blocks canArm (Lab-faithful).
bool canArm = flat and roomToday and canPlace and dayOk and suDir == 0 and not suOrd and (dayAllowed or i_manualOnly)

f_shadowArmLabel() =>
    not monthOk ? "SHADOW Jul/Oct — journal only" : not mondayOk ? "SHADOW Mon — journal only" : "ARMED — you click"

f_isLiveArm() =>
    dayAllowed

// Pick entry level per mode; returns [entryPx, stopPx] or na to skip
f_plan(float wickStart, float ce, float extreme, bool isShort) =>
    float stopPx = isShort ? extreme + i_stopBufPts : extreme - i_stopBufPts
    float eWick = wickStart
    float eCe = ce
    float riskWick = math.abs(eWick - stopPx)
    float riskCe = math.abs(eCe - stopPx)
    float entryPx = na
    if i_entryMode == "Limit at wick start"
        entryPx := riskWick >= i_minStopPts and riskWick <= i_maxStopPts ? eWick : na
    else if i_entryMode == "Limit at wick CE"
        entryPx := riskCe >= i_minStopPts and riskCe <= i_maxStopPts ? eCe : na
    else
        // Auto: prefer wick start (fills); fall back to CE when stop too big
        entryPx := riskWick <= i_maxStopPts and riskWick >= i_minStopPts ? eWick : (riskCe <= i_maxStopPts and riskCe >= i_minStopPts ? eCe : na)
    [entryPx, stopPx]

// ─── Give-back regime tracker ────────────────────────────────────────────────
var int sessionGiveBacks = 0
var array<int> gbHistory = array.new_int(0)

f_isGiveBack(float pk, float exitR) =>
    pk >= i_regimeGiveBackR and exitR > -0.5 and exitR < 1.0

f_gbRolling() =>
    int s = 0
    for i = 0 to array.size(gbHistory) - 1
        s += array.get(gbHistory, i)
    s

if newDay
    array.unshift(gbHistory, sessionGiveBacks)
    while array.size(gbHistory) > i_regimeLookback
        array.pop(gbHistory)
    sessionGiveBacks := 0

// ─── Ghost trades: near-miss setups that failed exactly one filter ───────────
// Reasons: 1 before window (9:30→start) · 2 Monday · 3 slot used (1/day or in
// pos) · 4 4H wick · 5 no sweep · 6 no confirming close · 7 stop bounds ·
// 8 daily lock · 9 key-open proximity · 10 bias filter · 11 after window (end→15:00)
// · 12 July/October stand-down (regime-gate-v0)
var array<int>   ghDir    = array.new<int>()
var array<float> ghEntry  = array.new<float>()
var array<float> ghStop   = array.new<float>()
var array<float> ghTp     = array.new<float>()
var array<float> ghRisk   = array.new<float>()
var array<int>   ghState  = array.new<int>()   // 0 wait-leave · 1 wait-fill · 2 in-pos
var array<int>   ghBarIx  = array.new<int>()
var array<int>   ghReason = array.new<int>()
var array<bool>  ghBe     = array.new<bool>()
var array<float> ghOrigStop = array.new<float>()
var array<bool>  ghBeRetest = array.new<bool>()
var array<float> ghPeakR  = array.new<float>()
var array<int>   ghCount  = array.new<int>(13, 0)
var array<int>   ghWins   = array.new<int>(13, 0)
var array<int>   ghLoss   = array.new<int>(13, 0)
var array<int>   ghScr    = array.new<int>(13, 0)
var array<float> ghNetR   = array.new<float>(13, 0.0)

// BE +1R retest audit: scratch at entry vs counterfactual 5R with original stop
var array<int>   beaCfDir    = array.new<int>()
var array<float> beaCfEntry  = array.new<float>()
var array<float> beaCfStop   = array.new<float>()
var array<float> beaCfTarget = array.new<float>()
var array<float> beaCfRisk   = array.new<float>()
var array<bool>  beaCfGhost  = array.new<bool>()
var int beScratchGh = 0
var int beMissedGh  = 0
var int beRetestWinGh = 0
var int beScratchRt = 0
var int beMissedRt  = 0
var int beRetestWinRt = 0

f_cfSpawn(int d, float e, float s, float t, float r, bool fromGhost) =>
    array.push(beaCfDir, d)
    array.push(beaCfEntry, e)
    array.push(beaCfStop, s)
    array.push(beaCfTarget, t)
    array.push(beaCfRisk, r)
    array.push(beaCfGhost, fromGhost)

f_isBeScratchExit(float pk, float exitR) =>
    i_beAtR > 0 and pk >= i_beAtR and exitR > -0.35 and exitR < 0.35

f_ghSpawn(int dir, float wickStart, float ce, float extreme, int reason) =>
    [entryPx, stopPx] = f_plan(wickStart, ce, extreme, dir == -1)
    float e = na(entryPx) ? wickStart : entryPx
    float s = na(entryPx) ? (dir == -1 ? extreme + i_stopBufPts : extreme - i_stopBufPts) : stopPx
    float r = math.abs(s - e)
    if r > 0
        array.push(ghDir, dir)
        array.push(ghEntry, e)
        array.push(ghStop, s)
        array.push(ghTp, dir == -1 ? e - f_effRr() * r : e + f_effRr() * r)
        array.push(ghRisk, r)
        array.push(ghState, 0)
        array.push(ghBarIx, bar_index)
        array.push(ghReason, reason)
        array.push(ghBe, false)
        array.push(ghOrigStop, s)
        array.push(ghBeRetest, false)
        array.push(ghPeakR, 0.0)
        array.set(ghCount, reason, array.get(ghCount, reason) + 1)
        if i_showGhost
            label.new(bar_index, dir == -1 ? high : low, "G" + str.tostring(reason), style = dir == -1 ? label.style_label_down : label.style_label_up, color = color.new(color.gray, 55), textcolor = color.white, size = size.tiny)

bool inRth = nyHhmm >= 930 and nyHhmm < 1500
var int lastGhBear = -999
var int lastGhBull = -999

if i_ghost and inRth and localHigh and upperWick >= i_minWickPts and array.size(ghDir) < 40 and bar_index - lastGhBear >= i_localLen
    int fails = 0
    int reason = 0
    if i_confClose and not (close < open)
        fails += 1
        reason := 6
    if not inWindow
        fails += 1
        reason := nyHhmm < i_winStart ? 1 : 11
    if not mondayOk
        fails += 1
        reason := 2
    if not monthOk
        fails += 1
        reason := 12
    if not h4OkBear
        fails += 1
        reason := 4
    if i_reqSweep and not sweptAbove
        fails += 1
        reason := 5
    if i_koConfl and not f_nearKo(high)
        fails += 1
        reason := 9
    if i_biasMode == "Long only" or (autoBiasOn and dayDraw == 1)
        fails += 1
        reason := 10
    if not dayOk
        fails += 1
        reason := 8
    if not (flat and roomToday and suDir == 0 and not suOrd)
        fails += 1
        reason := 3
    float gws = math.max(open, close)
    float gce = (high + gws) / 2.0
    [gpe, gps] = f_plan(gws, gce, high, true)
    if na(gpe)
        fails += 1
        reason := 7
    if fails == 1
        f_ghSpawn(-1, gws, gce, high, reason)
        lastGhBear := bar_index

if i_ghost and inRth and localLow and lowerWick >= i_minWickPts and array.size(ghDir) < 40 and bar_index - lastGhBull >= i_localLen
    int fails = 0
    int reason = 0
    if i_confClose and not (close > open)
        fails += 1
        reason := 6
    if not inWindow
        fails += 1
        reason := nyHhmm < i_winStart ? 1 : 11
    if not mondayOk
        fails += 1
        reason := 2
    if not monthOk
        fails += 1
        reason := 12
    if not h4OkBull
        fails += 1
        reason := 4
    if i_reqSweep and not sweptBelow
        fails += 1
        reason := 5
    if i_koConfl and not f_nearKo(low)
        fails += 1
        reason := 9
    if i_biasMode == "Short only" or (autoBiasOn and dayDraw == -1)
        fails += 1
        reason := 10
    if not dayOk
        fails += 1
        reason := 8
    if not (flat and roomToday and suDir == 0 and not suOrd)
        fails += 1
        reason := 3
    float gws = math.min(open, close)
    float gce = (low + gws) / 2.0
    [gpe, gps] = f_plan(gws, gce, low, false)
    if na(gpe)
        fails += 1
        reason := 7
    if fails == 1
        f_ghSpawn(1, gws, gce, low, reason)
        lastGhBull := bar_index

// Ghost life cycle — mirrors the real leave→retest→fill→manage sequence
if i_ghost and array.size(ghDir) > 0
    for gi = array.size(ghDir) - 1 to 0
        int d = array.get(ghDir, gi)
        float e = array.get(ghEntry, gi)
        float s = array.get(ghStop, gi)
        float t = array.get(ghTp, gi)
        float r = array.get(ghRisk, gi)
        int st = array.get(ghState, gi)
        int rs = array.get(ghReason, gi)
        bool sessionEnd = nyHhmm >= i_flatTime
        bool done = false
        bool ghGiveBack = false
        if st == 0
            bool inval = d == -1 ? close > s : close < s
            if bar_index - array.get(ghBarIx, gi) > i_tapTimeout or inval or sessionEnd
                done := true
            else if (d == -1 ? low <= e - i_leaveR * r : high >= e + i_leaveR * r)
                array.set(ghState, gi, 1)
        else if st == 1
            if bar_index - array.get(ghBarIx, gi) > i_tapTimeout or sessionEnd
                done := true
            else if (d == -1 ? high >= e : low <= e)
                if (d == -1 ? high >= s : low <= s)
                    array.set(ghLoss, rs, array.get(ghLoss, rs) + 1)
                    array.set(ghNetR, rs, array.get(ghNetR, rs) - 1.0)
                    done := true
                else
                    array.set(ghState, gi, 2)
            else if (d == -1 ? close > s : close < s)
                done := true
        else
            float favGhR = d == -1 ? (e - low) / r : (high - e) / r
            array.set(ghPeakR, gi, math.max(array.get(ghPeakR, gi), favGhR))
            if i_beAtR > 0 and not array.get(ghBe, gi) and (d == -1 ? low <= e - i_beAtR * r : high >= e + i_beAtR * r)
                array.set(ghBe, gi, true)
                array.set(ghStop, gi, e)
            if array.get(ghBe, gi) and not array.get(ghBeRetest, gi) and (d == -1 ? high >= e : low <= e)
                array.set(ghBeRetest, gi, true)
            float curStop = array.get(ghStop, gi)
            bool tpHit = d == -1 ? low <= t : high >= t
            bool stopHit = d == -1 ? high >= curStop : low <= curStop
            if tpHit
                if array.get(ghBeRetest, gi)
                    beRetestWinGh += 1
                array.set(ghWins, rs, array.get(ghWins, rs) + 1)
                array.set(ghNetR, rs, array.get(ghNetR, rs) + f_effRr())
                done := true
            else if stopHit
                if array.get(ghBe, gi)
                    array.set(ghScr, rs, array.get(ghScr, rs) + 1)
                    ghGiveBack := array.get(ghPeakR, gi) >= i_regimeGiveBackR
                    beScratchGh += 1
                    f_cfSpawn(d, e, array.get(ghOrigStop, gi), t, r, true)
                else
                    array.set(ghLoss, rs, array.get(ghLoss, rs) + 1)
                    array.set(ghNetR, rs, array.get(ghNetR, rs) - 1.0)
                done := true
            else if sessionEnd
                float mkR = d == -1 ? (e - close) / r : (close - e) / r
                array.set(ghScr, rs, array.get(ghScr, rs) + 1)
                array.set(ghNetR, rs, array.get(ghNetR, rs) + mkR)
                ghGiveBack := f_isGiveBack(array.get(ghPeakR, gi), mkR)
                done := true
        if done
            if ghGiveBack
                sessionGiveBacks += 1
            array.remove(ghDir, gi)
            array.remove(ghEntry, gi)
            array.remove(ghStop, gi)
            array.remove(ghTp, gi)
            array.remove(ghRisk, gi)
            array.remove(ghState, gi)
            array.remove(ghBarIx, gi)
            array.remove(ghReason, gi)
            array.remove(ghBe, gi)
            array.remove(ghOrigStop, gi)
            array.remove(ghBeRetest, gi)
            array.remove(ghPeakR, gi)

// Counterfactual holds: after BE scratch, would orig stop have reached 5R?
if array.size(beaCfDir) > 0
    for ci = array.size(beaCfDir) - 1 to 0
        int cfDirVal = array.get(beaCfDir, ci)
        float cfEntryPx = array.get(beaCfEntry, ci)
        float cfStopPx = array.get(beaCfStop, ci)
        float cfTargetPx = array.get(beaCfTarget, ci)
        bool cfFromGhost = array.get(beaCfGhost, ci)
        bool cfDone = false
        bool cfOrigStopHit = cfDirVal == -1 ? high >= cfStopPx : low <= cfStopPx
        bool cfTargetHit = cfDirVal == -1 ? low <= cfTargetPx : high >= cfTargetPx
        if cfTargetHit
            if cfFromGhost
                beMissedGh += 1
            else
                beMissedRt += 1
            cfDone := true
        else if cfOrigStopHit or nyHhmm >= i_flatTime
            cfDone := true
        if cfDone
            array.remove(beaCfDir, ci)
            array.remove(beaCfEntry, ci)
            array.remove(beaCfStop, ci)
            array.remove(beaCfTarget, ci)
            array.remove(beaCfRisk, ci)
            array.remove(beaCfGhost, ci)

// ── Arm on RB (LIMIT/STOP/CE from structure wick; leave-retest timing on chart) ──
if rbBear and canArm
    float wickStart = rbWsBear
    float ce = rbCeBear
    float extreme = rbExtBear
    suSweepTag := f_rbMetaTag(poiShort)
    suH4Pts := h4UpperWick
    if isTrigger
        suDir := -1
        suWickStart := wickStart
        suCe := ce
        suExtreme := extreme
        suBar := bar_index
        suTapped := false
        manualState := "CISD tap CE"
    else
        [entryPx, stopPx] = f_plan(wickStart, ce, extreme, true)
        if na(entryPx)
            cntSkipStop += 1
        else
            float riskPts0 = math.abs(stopPx - entryPx)
            suDir := -1
            suWickStart := wickStart
            suCe := ce
            suExtreme := extreme
            suEntry := entryPx
            suStop := stopPx
            pendStop := stopPx
            pendTp := entryPx - f_effRr() * riskPts0
            suBar := bar_index
            suLeft := i_leaveR == 0
            manualReady := false
            manualState := suLeft ? "WAIT approach" : "WAIT leave"

if rbBull and canArm and suDir == 0
    float wickStart = rbWsBull
    float ce = rbCeBull
    float extreme = rbExtBull
    suSweepTag := f_rbMetaTag(poiLong)
    suH4Pts := h4LowerWick
    if isTrigger
        suDir := 1
        suWickStart := wickStart
        suCe := ce
        suExtreme := extreme
        suBar := bar_index
        suTapped := false
        manualState := "CISD tap CE"
    else
        [entryPx, stopPx] = f_plan(wickStart, ce, extreme, false)
        if na(entryPx)
            cntSkipStop += 1
        else
            float riskPts0 = math.abs(stopPx - entryPx)
            suDir := 1
            suWickStart := wickStart
            suCe := ce
            suExtreme := extreme
            suEntry := entryPx
            suStop := stopPx
            pendStop := stopPx
            pendTp := entryPx + f_effRr() * riskPts0
            suBar := bar_index
            suLeft := i_leaveR == 0
            manualReady := false
            manualState := suLeft ? "WAIT approach" : "WAIT leave"

// ── Leave-then-retest arming (SOP T03: wait for price to LEAVE, then retest) ──
// The order is re-evaluated every bar while the setup is live: it only stays
// working while the prior close is within i_maxApproachR × risk of the entry
// (approach guard), so violent bars ripping in from far away find no order.
if not isTrigger and suDir != 0 and flat
    float riskPts = math.abs(suStop - suEntry)
    bool invalidated = (suDir == -1 and close > suStop) or (suDir == 1 and close < suStop)
    if bar_index - suBar > i_tapTimeout or not canPlace or invalidated
        if suOrd and not i_manualOnly
            strategy.cancel("Short")
            strategy.cancel("Long")
        suOrd := false
        suDir := 0
        manualReady := false
        manualState := "—"
    else
        if not suLeft and (not i_strictLeave or bar_index > suBar)
            if suDir == -1 and low <= suEntry - i_leaveR * riskPts
                suLeft := true
            if suDir == 1 and high >= suEntry + i_leaveR * riskPts
                suLeft := true
        bool nearOk = i_maxApproachR == 0 or math.abs(close - suEntry) <= i_maxApproachR * riskPts
        string armLbl = f_shadowArmLabel()
        manualState := not suLeft ? "WAIT leave" : not nearOk ? "WAIT approach" : not roomToday ? "1/day used" : not dayOk ? "Daily lock" : armLbl
        if suLeft and roomToday and dayOk
            if nearOk
                float tpPx = suDir == -1 ? suEntry - f_effRr() * riskPts : suEntry + f_effRr() * riskPts
                pendStop := suStop
                pendTp := tpPx
                int qty = f_qty(riskPts)
                if qty > 0
                    manualReady := true
                    manualState := armLbl
                    if not i_manualOnly and f_isLiveArm()
                        if suDir == -1
                            strategy.entry("Short", strategy.short, qty = qty, limit = suEntry)
                            strategy.exit("S-X", from_entry = "Short", stop = suStop, limit = tpPx)
                        else
                            strategy.entry("Long", strategy.long, qty = qty, limit = suEntry)
                            strategy.exit("L-X", from_entry = "Long", stop = suStop, limit = tpPx)
                        if not suOrd
                            cntOrders += 1
                        suOrd := true
                        openRiskPts := riskPts
                    else
                        suOrd := false
                else
                    cntSkipStop += 1
                    suDir := 0
                    manualReady := false
                    manualState := "Stop bounds"
            else
                manualReady := false
                if suOrd and not i_manualOnly
                    strategy.cancel("Short")
                    strategy.cancel("Long")
                    suOrd := false
                    cntGuard += 1
        else
            manualReady := false
            if suLeft
                manualState := not roomToday ? "1/day used" : "Daily lock"

// ── CISD trigger mode: tap the RB zone, then confirm (T05 1m package) ────────
bool prevBull = close[1] > open[1]
bool prevBear = close[1] < open[1]
bool cisdBear = prevBull and close < open[1]
bool cisdBull = prevBear and close > open[1]

if isTrigger and suDir == -1 and flat and bar_index > suBar
    manualState := suTapped ? "CISD watch" : "CISD tap CE"
    if bar_index - suBar > i_tapTimeout or high > suExtreme + i_stopBufPts or not canPlace
        suDir := 0
        manualReady := false
        manualState := "—"
    else
        if high >= suCe
            suTapped := true
        if suTapped and cisdBear and roomToday and dayOk
            float stopPx = math.max(high, high[1]) + i_stopBufPts
            float riskPts = stopPx - close
            int qty = f_qty(riskPts)
            if qty > 0
                pendStop := stopPx
                pendTp := close - f_effRr() * riskPts
                suEntry := close
                manualReady := i_manualOnly
                manualState := i_manualOnly ? (f_isLiveArm() ? "CISD GO — you click" : f_shadowArmLabel()) : "CISD fill"
                if not i_manualOnly and f_isLiveArm()
                    strategy.entry("Short", strategy.short, qty = qty)
                    strategy.exit("S-X", from_entry = "Short", stop = stopPx, limit = pendTp)
                    openRiskPts := riskPts
                    cntOrders += 1
            else
                cntSkipStop += 1
            if not i_manualOnly
                suDir := 0

if isTrigger and suDir == 1 and flat and bar_index > suBar
    manualState := suTapped ? "CISD watch" : "CISD tap CE"
    if bar_index - suBar > i_tapTimeout or low < suExtreme - i_stopBufPts or not canPlace
        suDir := 0
        manualReady := false
        manualState := "—"
    else
        if low <= suCe
            suTapped := true
        if suTapped and cisdBull and roomToday and dayOk
            float stopPx = math.min(low, low[1]) - i_stopBufPts
            float riskPts = close - stopPx
            int qty = f_qty(riskPts)
            if qty > 0
                pendStop := stopPx
                pendTp := close + f_effRr() * riskPts
                suEntry := close
                manualReady := i_manualOnly
                manualState := i_manualOnly ? (f_isLiveArm() ? "CISD GO — you click" : f_shadowArmLabel()) : "CISD fill"
                if not i_manualOnly and f_isLiveArm()
                    strategy.entry("Long", strategy.long, qty = qty)
                    strategy.exit("L-X", from_entry = "Long", stop = stopPx, limit = pendTp)
                    openRiskPts := riskPts
                    cntOrders += 1
            else
                cntSkipStop += 1
            if not i_manualOnly
                suDir := 0

// Fill housekeeping + stop ratchet: BE at +beAtR, then trail (peak − gap)
// once peak favorable excursion ≥ trailStartR. The stop only ever moves up.
if not flat
    suOrd := false
    suDir := 0
    if strategy.position_size[1] == 0
        peakR := 0.0
        lockR := na
        rtEntry := strategy.position_avg_price
        rtOrigStop := pendStop
        rtTp := pendTp
        rtDir := strategy.position_size > 0 ? 1 : -1
        rtBeArmed := false
        rtBeRetest := false
    if not na(openRiskPts)
        float avg = strategy.position_avg_price
        bool isLongPos = strategy.position_size > 0
        float favR = isLongPos ? (high - avg) / openRiskPts : (avg - low) / openRiskPts
        peakR := math.max(nz(peakR, 0.0), favR)
        if i_beAtR > 0 and peakR >= i_beAtR
            rtBeArmed := true
            if not rtBeRetest
                if isLongPos and low <= avg
                    rtBeRetest := true
                if not isLongPos and high >= avg
                    rtBeRetest := true
        float newLock = na
        if i_beAtR > 0 and peakR >= i_beAtR
            newLock := 0.0
        if effTrailStartR > 0 and peakR >= effTrailStartR
            newLock := math.max(nz(newLock, peakR - effTrailGapR), peakR - effTrailGapR)
        if not na(newLock) and (na(lockR) or newLock > lockR)
            lockR := newLock
            float stopPx = isLongPos ? avg + lockR * openRiskPts : avg - lockR * openRiskPts
            if isLongPos
                strategy.exit("L-X", from_entry = "Long", stop = stopPx, limit = avg + f_effRr() * openRiskPts)
            else
                strategy.exit("S-X", from_entry = "Short", stop = stopPx, limit = avg - f_effRr() * openRiskPts)

// Closed-trade give-back + BE retest audit (real fills)
var int closedSeen = 0
var float lastOpenRisk = na
var float lastPeakR = na
var float frzEnt = na
var float frzStop = na
var float frzTp = na
var int frzLeft = na
var int frzDir = 0

if not flat and not na(openRiskPts)
    lastOpenRisk := openRiskPts
    lastPeakR := nz(peakR, 0.0)

if strategy.closedtrades > closedSeen
    closedSeen := strategy.closedtrades
    int ci = strategy.closedtrades - 1
    float profit = strategy.closedtrades.profit(ci)
    float sz = strategy.closedtrades.size(ci)
    float riskUsd = nz(lastOpenRisk, openRiskPts) * f_pointVal() * sz
    float exitR = riskUsd > 0 ? profit / riskUsd : 0.0
    if f_isGiveBack(nz(lastPeakR, 0.0), exitR)
        sessionGiveBacks += 1
    if f_isBeScratchExit(nz(lastPeakR, 0.0), exitR) and not na(rtEntry) and not na(rtOrigStop) and not na(rtTp) and rtDir != 0
        beScratchRt += 1
        f_cfSpawn(rtDir, rtEntry, rtOrigStop, rtTp, nz(lastOpenRisk, openRiskPts), false)
    else if exitR >= f_effRr() * 0.85 and rtBeRetest
        beRetestWinRt += 1
    if i_showPend and i_freezeTrades and not na(frzEnt) and not na(frzLeft)
        int xExit = strategy.closedtrades.exit_bar_index(ci)
        int xR = math.max(xExit, frzLeft + 4)
        bool won = profit > 0
        color eC = color.new(color.white, 30)
        color sC = color.new(color.red, 30)
        color tC = won ? color.new(color.teal, 30) : color.new(color.gray, 40)
        line.new(frzLeft, frzEnt, xR, frzEnt, color = eC, width = 1)
        line.new(frzLeft, frzStop, xR, frzStop, color = sC, width = 1)
        line.new(frzLeft, frzTp, xR, frzTp, color = tC, width = 1)
        string tag = (frzDir == 1 ? "LONG" : "SHORT") + (won ? " WIN" : " LOSS")
        label.new(xR, frzEnt, tag + "\n" + str.tostring(frzEnt, format.mintick), style = label.style_label_left, color = color.new(color.black, 40), textcolor = eC, size = size.tiny)
        frzEnt := na
        frzStop := na
        frzTp := na
        frzLeft := na
        frzDir := 0

// Session flat
if nyHhmm >= i_flatTime and not i_manualOnly
    strategy.cancel_all()
    suOrd := false
    suDir := 0
    if not flat
        strategy.close_all(comment = "Session flat")
else if nyHhmm >= i_flatTime and i_manualOnly
    manualReady := false
    manualState := "Flat 15:55"
    suDir := 0

// ─── Position boxes: TradingView long/short-position style ───────────────────
bool justOpened = strategy.position_size != 0 and strategy.position_size[1] == 0
bool inPos = strategy.position_size != 0

var line  posLnEntry = na
var line  posLnStop = na
var line  posLnTp = na
var box   posBxRisk = na
var box   posBxReward = na
var float posStopLv = na

if i_showPos and justOpened
    float avg = strategy.position_avg_price
    posStopLv := pendStop
    frzEnt := avg
    frzStop := pendStop
    frzTp := pendTp
    frzLeft := bar_index
    frzDir := strategy.position_size > 0 ? 1 : -1
    posLnEntry := line.new(bar_index, avg, bar_index, avg, color = color.new(color.white, 20), width = 2)
    posLnStop := line.new(bar_index, pendStop, bar_index, pendStop, color = color.new(color.red, 0), width = 2)
    posLnTp := line.new(bar_index, pendTp, bar_index, pendTp, color = color.new(color.lime, 0), width = 2)
    posBxRisk := box.new(bar_index, math.max(avg, pendStop), bar_index, math.min(avg, pendStop), border_color = color.new(color.red, 65), bgcolor = color.new(color.red, 85))
    posBxReward := box.new(bar_index, math.max(avg, pendTp), bar_index, math.min(avg, pendTp), border_color = color.new(color.green, 65), bgcolor = color.new(color.green, 85))
    bool isLong = strategy.position_size > 0
    float stopPts = math.abs(avg - pendStop)
    string txt = (isLong ? "LONG " : "SHORT ") + str.tostring(math.abs(strategy.position_size), "#") + " " + f_instrTag() + " · stop " + str.tostring(stopPts, "#.##") + " pts · $" + str.tostring(math.abs(strategy.position_size) * stopPts * f_pointVal(), "#") + " risk"
    label.new(bar_index, avg, txt, style = isLong ? label.style_label_lower_left : label.style_label_upper_left, color = color.new(color.black, 30), textcolor = isLong ? color.lime : color.red, size = size.small)

if inPos and not na(posLnEntry)
    line.set_x2(posLnEntry, bar_index)
    line.set_x2(posLnStop, bar_index)
    line.set_x2(posLnTp, bar_index)
    box.set_right(posBxRisk, bar_index)
    box.set_right(posBxReward, bar_index)
    // Reflect the stop ratchet (BE / trail) on the drawing
    float avgPx = strategy.position_avg_price
    float liveStop = not na(lockR) and not na(openRiskPts) ? (strategy.position_size > 0 ? avgPx + lockR * openRiskPts : avgPx - lockR * openRiskPts) : posStopLv
    if liveStop != posStopLv
        posStopLv := liveStop
        line.set_y1(posLnStop, posStopLv)
        line.set_y2(posLnStop, posStopLv)
        line.set_color(posLnStop, color.new(color.yellow, 0))
        box.set_top(posBxRisk, math.max(avgPx, posStopLv))
        box.set_bottom(posBxRisk, math.min(avgPx, posStopLv))

if not inPos and not na(posLnEntry) and strategy.position_size[1] != 0
    posLnEntry := na
    posLnStop := na
    posLnTp := na
    posBxRisk := na
    posBxReward := na

// ─── On-chart trade plan (LIMIT · STOP · TP) ─────────────────────────────────
// Anchored on setup bar — not a corner HUD. Bias is yours; chart = geometry only.
var line  planLnE = na
var line  planLnS = na
var line  planLnT = na
var label planLbE = na
var label planLbS = na
var label planLbT = na
var box   planBxRisk = na
var box   planBxRew = na
var int   planLeft = na

f_planRight(int left) =>
    math.max(bar_index + 4, left + 16)

f_trigState() =>
    isTrigger ? (suTapped ? "CISD watch" : "CISD tap") : not suLeft ? "WAIT leave" : manualReady ? "GO" : "WAIT approach"

bool planLive = i_showPend and suDir != 0 and not na(suEntry) and not na(pendStop) and not na(pendTp) and not na(suBar)
bool isShadowPlan = i_manualOnly and not f_isLiveArm()

if planLive
    int xR = f_planRight(suBar)
    bool newPlan = na(planLeft) or planLeft != suBar
    color eCol = isShadowPlan ? color.new(color.orange, 0) : c_limit
    color sCol = isShadowPlan ? color.new(color.orange, 20) : c_stop
    color tCol = isShadowPlan ? color.new(color.gray, 10) : c_tp
    color rBg = color.new(sCol, 86)
    color wBg = color.new(tCol, 88)
    string side = suDir == -1 ? "SHORT" : "LONG"
    string trig = f_trigState()
    string limTxt = side + " · " + trig + "\nLIMIT " + str.tostring(suEntry, format.mintick)
    if i_showTriggers and suSweepTag != "—"
        limTxt += "\n" + suSweepTag
    if i_manualOnly and i_msGrade
        int msN = (msPoi ? 1 : 0) + (msH4 ? 1 : 0) + (msCisd ? 1 : 0) + (msIfvg1 ? 1 : 0) + (msIfvg5 ? 1 : 0)
        limTxt += "\nMS " + str.tostring(msN) + "/5"
    if newPlan
        planLeft := suBar
        planLnE := line.new(suBar, suEntry, xR, suEntry, color = eCol, width = 2, style = line.style_solid)
        planLnS := line.new(suBar, pendStop, xR, pendStop, color = sCol, width = 2, style = line.style_solid)
        planLnT := line.new(suBar, pendTp, xR, pendTp, color = tCol, width = 2, style = line.style_solid)
        planLbE := label.new(xR, suEntry, limTxt, style = label.style_label_left, color = color.new(color.black, 15), textcolor = eCol, size = size.small)
        planLbS := label.new(xR, pendStop, "STOP " + str.tostring(pendStop, format.mintick), style = label.style_label_left, color = color.new(color.black, 15), textcolor = sCol, size = size.small)
        planLbT := label.new(xR, pendTp, "TP " + str.tostring(pendTp, format.mintick), style = label.style_label_left, color = color.new(color.black, 15), textcolor = tCol, size = size.small)
        planBxRisk := box.new(suBar, math.max(suEntry, pendStop), xR, math.min(suEntry, pendStop), border_color = color.new(sCol, 60), bgcolor = rBg, border_width = 1)
        planBxRew := box.new(suBar, math.max(suEntry, pendTp), xR, math.min(suEntry, pendTp), border_color = color.new(tCol, 60), bgcolor = wBg, border_width = 1)
    else
        line.set_x2(planLnE, xR)
        line.set_x2(planLnS, xR)
        line.set_x2(planLnT, xR)
        line.set_y1(planLnE, suEntry)
        line.set_y2(planLnE, suEntry)
        line.set_y1(planLnS, pendStop)
        line.set_y2(planLnS, pendStop)
        line.set_y1(planLnT, pendTp)
        line.set_y2(planLnT, pendTp)
        box.set_right(planBxRisk, xR)
        box.set_right(planBxRew, xR)
        box.set_top(planBxRisk, math.max(suEntry, pendStop))
        box.set_bottom(planBxRisk, math.min(suEntry, pendStop))
        box.set_top(planBxRew, math.max(suEntry, pendTp))
        box.set_bottom(planBxRew, math.min(suEntry, pendTp))
        label.set_x(planLbE, xR)
        label.set_y(planLbE, suEntry)
        label.set_x(planLbS, xR)
        label.set_y(planLbS, pendStop)
        label.set_x(planLbT, xR)
        label.set_y(planLbT, pendTp)
        label.set_text(planLbE, limTxt)
else if not na(planLnE) and suDir == 0
    planLnE := na
    planLnS := na
    planLnT := na
    planLbE := na
    planLbS := na
    planLbT := na
    planBxRisk := na
    planBxRew := na
    planLeft := na

// Leave / GO markers on the candle (non-bias entry timing)
bool justLeft = suDir != 0 and suLeft and not suLeft[1] and i_leaveR > 0
bool justGo = manualReady and not manualReady[1]
if i_showTriggers and barstate.isconfirmed and justLeft
    label.new(bar_index, suDir == -1 ? low : high, "LEAVE", style = suDir == -1 ? label.style_label_up : label.style_label_down, color = color.new(c_leave, 15), textcolor = color.black, size = size.small)
if i_showTriggers and barstate.isconfirmed and justGo
    label.new(bar_index, suDir == -1 ? high : low, "GO", style = suDir == -1 ? label.style_label_down : label.style_label_up, color = color.new(c_go, 10), textcolor = color.black, size = size.small)

// ─── Visuals (on-chart only — RB zone + session wash) ────────────────────────
bool showClassicLvls = i_showLvls and not i_liveClean
bool showExtraLines = i_extraLvls
bool showDiagTables = i_showTable and not i_liveClean

bgcolor(nyHhmm == 1000 ? color.new(c_win10, 88) : na, title = "10:00 key open")
bgcolor(inWindow ? color.new(c_winSess, 96) : na, title = "Entry window")

// Extended rejection-block zone + dotted CE · watermark "RB" (not a solid tag)
var box bxRb = na
var line lnRbCe = na
var line lnRbWs = na
var label lblRbMark = na
var label lblRbMeta = na
var int rbLeft = na
var float rbTop = na
var float rbBot = na
var float rbCeLv = na
var float rbWsLv = na

if i_showSig and barstate.isconfirmed and (rbBear or rbBull) and suDir != 0 and not na(suBar) and suBar == bar_index
    float ws = nz(suWickStart, rbBear ? rbWsBear : rbWsBull)
    float ex = nz(suExtreme, rbBear ? rbExtBear : rbExtBull)
    float ceNow = nz(suCe, (ex + ws) * 0.5)
    color bd = rbBear ? c_rbShortBd : c_rbLongBd
    color bg = color.new(rbBear ? c_rbShortBg : c_rbLongBg, i_rbFillTrans)
    color markC = color.new(bd, i_rbMarkTrans)
    int xR0 = bar_index + i_rbExtend
    float midY = (ex + ws) * 0.5
    bxRb := box.new(bar_index, math.max(ex, ws), xR0, math.min(ex, ws), border_color = bd, bgcolor = bg, border_width = 2)
    // Watermark in the box (transparent bg · translucent text · no solid pill)
    lblRbMark := label.new(bar_index + int(i_rbExtend * 0.35), midY, i_manualOnly ? "MS" : "RB", style = label.style_label_center, color = color.new(color.black, 100), textcolor = markC, size = size.large)
    if i_showTriggers
        string sw = suSweepTag
        float h4p = nz(suH4Pts, rbBear ? h4UpperWick : h4LowerWick)
        string meta = (sw != "—" ? sw + " · " : "") + "4H " + str.tostring(h4p, "#.#")
        lblRbMeta := label.new(bar_index, midY, meta, style = label.style_label_left, color = color.new(color.black, 100), textcolor = color.new(bd, 25), size = size.tiny)
    rbLeft := bar_index
    rbTop := math.max(ex, ws)
    rbBot := math.min(ex, ws)
    rbCeLv := ceNow
    rbWsLv := ws
    if i_showCe
        lnRbCe := line.new(bar_index, ceNow, xR0, ceNow, color = color.new(c_ce, 20), width = 1, style = line.style_dotted)
        lnRbWs := line.new(bar_index, ws, xR0, ws, color = color.new(c_wickSt, 35), width = 1, style = line.style_dashed)

if i_showSig and suDir != 0 and not na(rbLeft) and not na(suBar) and rbLeft == suBar and not na(rbTop)
    int xLive = math.max(bar_index + 2, suBar + i_rbExtend)
    if not na(bxRb)
        box.set_right(bxRb, xLive)
    if not na(lblRbMark)
        label.set_x(lblRbMark, rbLeft + int(math.max(2, (xLive - rbLeft) * 0.35)))
        label.set_y(lblRbMark, (rbTop + rbBot) * 0.5)
    if i_showCe and not na(lnRbCe)
        line.set_x2(lnRbCe, xLive)
        if not na(suCe)
            line.set_y1(lnRbCe, suCe)
            line.set_y2(lnRbCe, suCe)
    if i_showCe and not na(lnRbWs) and not na(suWickStart)
        line.set_x2(lnRbWs, xLive)
        line.set_y1(lnRbWs, suWickStart)
        line.set_y2(lnRbWs, suWickStart)
else if suDir == 0 and not na(bxRb) and not na(rbLeft) and bar_index > rbLeft + i_rbExtend
    bxRb := na
    lnRbCe := na
    lnRbWs := na
    lblRbMark := na
    lblRbMeta := na

// ─── Morningstar confluence grade (Manual · eyes only — never arms) ──────────
f_msNear(float px) =>
    not na(px) and not na(suCe) and (math.abs(px - suCe) <= i_msBuf or math.abs(px - nz(suExtreme, suCe)) <= i_msBuf or math.abs(px - nz(suWickStart, suCe)) <= i_msBuf)

bool msShow = i_manualOnly and i_msGrade
if msShow and suDir != 0 and not na(suBar) and suBar == bar_index
    msPoi := suDir == -1 ? poiShort != "—" : poiLong != "—"
    msH4 := suDir == -1 ? h4OkBear : h4OkBull
    msCisd := false
    msIfvg1 := false
    msIfvg5 := false
    msMarkedCisd := false
    msMarkedIfvg1 := false
    msMarkedIfvg5 := false
    lblMsGrade := na

if msShow and suDir != 0 and not na(suBar) and bar_index >= suBar
    // Refresh POI / 4H if they improve (usually set on arm)
    if suDir == -1
        if poiShort != "—"
            msPoi := true
        if h4OkBear
            msH4 := true
        if ms1CisdBear and f_msNear(ms1Close)
            msCisd := true
        if ms1IfvgBear and f_msNear(ms1Close)
            msIfvg1 := true
        if ms5IfvgBear and f_msNear(ms5Close)
            msIfvg5 := true
    else
        if poiLong != "—"
            msPoi := true
        if h4OkBull
            msH4 := true
        if ms1CisdBull and f_msNear(ms1Close)
            msCisd := true
        if ms1IfvgBull and f_msNear(ms1Close)
            msIfvg1 := true
        if ms5IfvgBull and f_msNear(ms5Close)
            msIfvg5 := true

    int msHits = (msPoi ? 1 : 0) + (msH4 ? 1 : 0) + (msCisd ? 1 : 0) + (msIfvg1 ? 1 : 0) + (msIfvg5 ? 1 : 0)
    int msPct = msHits * 20
    string msBits = (msPoi ? "POI" : "poi") + " · " + (msH4 ? "4H" : "4h") + " · " + (msCisd ? "CISD" : "cisd") + " · " + (msIfvg1 ? "iFVG1" : "ifvg1") + " · " + (msIfvg5 ? "iFVG5" : "ifvg5")
    string msTxt = "Morningstar " + str.tostring(msHits) + "/5 · " + str.tostring(msPct) + "%\n" + msBits
    float msY = suDir == -1 ? nz(suExtreme, high) + i_msBuf : nz(suExtreme, low) - i_msBuf
    color msCol = msHits >= 4 ? color.new(#a3e635, 0) : msHits == 3 ? color.new(#facc15, 0) : color.new(#94a3b8, 0)
    if na(lblMsGrade)
        lblMsGrade := label.new(bar_index, msY, msTxt, style = suDir == -1 ? label.style_label_down : label.style_label_up, color = color.new(color.black, 20), textcolor = msCol, size = size.small)
    else
        label.set_x(lblMsGrade, bar_index)
        label.set_y(lblMsGrade, msY)
        label.set_text(lblMsGrade, msTxt)
        label.set_textcolor(lblMsGrade, msCol)

    if i_msMarks and barstate.isconfirmed
        if msCisd and not msMarkedCisd
            label.new(bar_index, close, "1m CISD", style = label.style_label_left, color = color.new(color.black, 70), textcolor = color.new(#22d3ee, 0), size = size.tiny)
            msMarkedCisd := true
        if msIfvg1 and not msMarkedIfvg1
            label.new(bar_index, close, "1m IFVG", style = label.style_label_left, color = color.new(color.black, 70), textcolor = color.new(#c084fc, 0), size = size.tiny)
            msMarkedIfvg1 := true
        if msIfvg5 and not msMarkedIfvg5
            label.new(bar_index, close, "5m IFVG", style = label.style_label_left, color = color.new(color.black, 70), textcolor = color.new(#f472b6, 0), size = size.tiny)
            msMarkedIfvg5 := true
else if suDir == 0 and not na(lblMsGrade)
    lblMsGrade := na

// Optional journal: bias-blocked raw RB (off by default)
bool biasBlkBear = i_showBlockedBias and rbBearRaw and h4OkBear and sweepOkShort and (not i_koConfl or f_nearKo(rbExtBear)) and not biasOkShort
bool biasBlkBull = i_showBlockedBias and rbBullRaw and h4OkBull and sweepOkLong and (not i_koConfl or f_nearKo(rbExtBull)) and not biasOkLong
if barstate.isconfirmed and biasBlkBear
    box.new(bar_index, rbExtBear, bar_index + i_rbExtend, rbWsBear, border_color = color.new(color.gray, 50), bgcolor = color.new(color.gray, 92), border_width = 1)
if barstate.isconfirmed and biasBlkBull
    box.new(bar_index, rbWsBull, bar_index + i_rbExtend, rbExtBull, border_color = color.new(color.gray, 50), bgcolor = color.new(color.gray, 92), border_width = 1)

plotshape(i_showSoup and sweptAbove and inWindow, "Sweep above", shape.triangledown, location.abovebar, color.orange, size = size.tiny)
plotshape(i_showSoup and sweptBelow and inWindow, "Sweep below", shape.triangleup, location.belowbar, color.aqua, size = size.tiny)

// PDH / PDL — line from the wick of the candle that made prior day H/L
var line lnPdh = na
var line lnPdl = na
var label lblPdh = na
var label lblPdl = na

float usePdh = not na(pdhLvl) ? pdhLvl : prevDayHigh
float usePdl = not na(pdlLvl) ? pdlLvl : prevDayLow

if i_showPdhPdl and newDay and not na(pdhOriginBar) and not na(usePdh)
    lnPdh := line.new(pdhOriginBar, usePdh, bar_index, usePdh, color = c_pdh, width = 2, style = line.style_solid, extend = extend.none)
    lblPdh := label.new(bar_index, usePdh, "PDH", style = label.style_label_left, color = color.new(color.black, 100), textcolor = color.new(c_pdh, 10), size = size.tiny)
if i_showPdhPdl and newDay and not na(pdlOriginBar) and not na(usePdl)
    lnPdl := line.new(pdlOriginBar, usePdl, bar_index, usePdl, color = c_pdl, width = 2, style = line.style_solid, extend = extend.none)
    lblPdl := label.new(bar_index, usePdl, "PDL", style = label.style_label_left, color = color.new(color.black, 100), textcolor = color.new(c_pdl, 10), size = size.tiny)

if i_showPdhPdl and not na(lnPdh) and not na(usePdh)
    line.set_x2(lnPdh, bar_index)
    line.set_y1(lnPdh, usePdh)
    line.set_y2(lnPdh, usePdh)
    line.set_color(lnPdh, c_pdh)
    if not na(lblPdh)
        label.set_x(lblPdh, bar_index)
        label.set_y(lblPdh, usePdh)
if i_showPdhPdl and not na(lnPdl) and not na(usePdl)
    line.set_x2(lnPdl, bar_index)
    line.set_y1(lnPdl, usePdl)
    line.set_y2(lnPdl, usePdl)
    line.set_color(lnPdl, c_pdl)
    if not na(lblPdl)
        label.set_x(lblPdl, bar_index)
        label.set_y(lblPdl, usePdl)

plot(showClassicLvls ? prevDayHigh : na, "PDH", color.new(c_pdh, 60), style = plot.style_linebr)
plot(showClassicLvls ? prevDayLow : na, "PDL", color.new(c_pdl, 60), style = plot.style_linebr)
plot(showExtraLines and nyHhmm >= 930 ? pmHigh : na, "PM High", color.new(color.orange, 60), style = plot.style_linebr)
plot(showExtraLines and nyHhmm >= 930 ? pmLow : na, "PM Low", color.new(color.aqua, 60), style = plot.style_linebr)
plot(showExtraLines ? ko1800 : na, "18:00 open", color.new(color.green, 45), style = plot.style_linebr)
plot(showExtraLines ? ko0000 : na, "Midnight open", color.new(color.yellow, 45), style = plot.style_linebr)
plot(showClassicLvls ? ko1000 : na, "10:00 open", color.new(color.fuchsia, 45), style = plot.style_linebr)
plot(showExtraLines and i_useAmOpens ? ko0830 : na, "8:30 open", color.new(color.silver, 60), style = plot.style_linebr)
plot(showExtraLines and i_useAmOpens ? ko0900 : na, "9:00 open", color.new(color.silver, 70), style = plot.style_linebr)
plot(showExtraLines and i_useAmOpens ? ko0930 : na, "9:30 open", color.new(color.silver, 65), style = plot.style_linebr)

// ─── Diagnostic funnel table (Lab only) ──────────────────────────────────────
f_row(table t, int r, string k, string v) =>
    table.cell(t, 0, r, k, text_color = color.new(color.lime, 20), text_size = size.small, text_halign = text.align_left)
    table.cell(t, 1, r, v, text_color = color.white, text_size = size.small, text_halign = text.align_right)

f_rowCol(table t, int r, string k, string v, color vc) =>
    table.cell(t, 0, r, k, text_color = color.new(color.lime, 20), text_size = size.small, text_halign = text.align_left)
    table.cell(t, 1, r, v, text_color = vc, text_size = size.small, text_halign = text.align_right)

var table diag = table.new(position.top_right, 2, 18, bgcolor = color.new(color.black, 15), border_width = 1, border_color = color.new(color.gray, 70))
if showDiagTables and barstate.islast
    int gbRoll = f_gbRolling() + sessionGiveBacks
    bool suggestTrail = not i_trailRegime and gbRoll >= i_regimeThreshold
    string trailLbl = i_trailRegime ? "ON (2.0 / 1.5)" : "OFF (BE-only)"
    color trailCol = i_trailRegime ? color.new(color.yellow, 0) : color.white
    string gbLbl = str.tostring(gbRoll) + " / " + str.tostring(i_regimeLookback) + "s"
    string regimeLbl = i_trailRegime ? "Trail active" : suggestTrail ? "Consider trail" : "BE-only OK"
    color regimeCol = i_trailRegime ? color.new(color.yellow, 0) : suggestTrail ? color.new(color.orange, 0) : color.new(color.lime, 20)
    string modeLbl = i_manualOnly ? "MANUAL (no orders)" : "AUTO strategy"
    color modeCol = i_manualOnly ? color.new(color.yellow, 0) : color.new(color.lime, 20)
    float effRr = f_effRr()
    string evalLbl = i_evalMaxWinUsd > 0 ? str.tostring(effRr, "#.##") + "R cap $" + str.tostring(i_evalMaxWinUsd, "#") : "off (full " + str.tostring(i_rr, "#.#") + "R)"
    color evalCol = i_evalMaxWinUsd > 0 ? color.new(color.yellow, 0) : color.white
    string julOctLbl = not i_skipJulOct ? "OFF (trade all)" : not monthOk ? "STAND_DOWN Jul/Oct" : "ON · month ok"
    color julOctCol = not i_skipJulOct ? color.white : not monthOk ? color.new(color.orange, 0) : color.new(color.lime, 20)
    f_rowCol(diag, 0, "PRB gate_v0 FUNNEL", modeLbl, modeCol)
    f_row(diag, 1, "Days in history", str.tostring(cntDays))
    f_row(diag, 2, "RB candles (raw)", str.tostring(cntRbRaw))
    f_row(diag, 3, "RB + sweep + 4H + KO", str.tostring(cntRbCtx))
    f_row(diag, 4, "Blocked (bias)", str.tostring(cntBiasBlk))
    f_row(diag, 5, "Skipped (stop bounds)", str.tostring(cntSkipStop))
    f_row(diag, 6, "Orders placed", str.tostring(cntOrders))
    f_row(diag, 7, "Guard pauses", str.tostring(cntGuard))
    f_row(diag, 8, "Trades filled", str.tostring(totalTrades))
    string drawLbl = autoBiasOn ? (dayDraw == -1 ? "Auto ↓ short" : dayDraw == 1 ? "Auto ↑ long" : "Auto — neutral") : i_biasMode
    f_row(diag, 9, "Bias", drawLbl)
    string tvPv = i_instrMode == "Auto (chart symbol)" ? " · tv=" + str.tostring(syminfo.pointvalue, "#.##") : ""
    string sizeLbl = f_instrTag() + " · max " + str.tostring(f_effMaxContracts()) + " · $" + str.tostring(f_pointVal(), "#") + "/pt" + tvPv
    f_row(diag, 10, "Sizing", sizeLbl)
    f_rowCol(diag, 11, "Trail toggle", trailLbl, trailCol)
    f_row(diag, 12, "Give-backs", gbLbl)
    f_rowCol(diag, 13, "Regime", regimeLbl, regimeCol)
    f_rowCol(diag, 14, "Eval win cap", evalLbl, evalCol)
    f_rowCol(diag, 15, "Jul/Oct gate", julOctLbl, julOctCol)
    f_rowCol(diag, 16, "Manual state", manualState, manualReady ? color.new(color.yellow, 0) : color.white)
    f_row(diag, 17, "Log → Vault F2", i_manualOnly ? "Journal bias+take" : "—")
else if barstate.islast
    table.clear(diag, 0, 0, 1, 17)

alertcondition(i_manualOnly and manualReady and i_manualAlerts and monthOk and mondayOk, title = "PRB · ARMED (Manual ON)", message = "PRB gate_v0 ARMED — {{ticker}} {{interval}} {{time}}\n1) Checklist bias / confluence\n2) Copy LIMIT · STOP · TP from boxes\n3) Coach qty from stop pts\nManual ON — you click. Jul/Oct SHADOW is journal-only (no alert).")

// ─── Missed-trade autopsy table (bottom right) ───────────────────────────────
var string[] ghNames = array.from("", "Before window (9:30→start)", "Monday", "Slot used (1/day, in pos)", "4H wick too small", "No liquidity sweep", "No confirming close", "Stop out of bounds", "Daily P&L lock", "Not near key open", "Bias filter", "After window (end→15:00)", "July/October stand-down")

f_ghRow(table t, int r, string c0, string c1, string c2, string c3, color tc) =>
    table.cell(t, 0, r, c0, text_color = tc, text_size = size.small, text_halign = text.align_left)
    table.cell(t, 1, r, c1, text_color = tc, text_size = size.small, text_halign = text.align_right)
    table.cell(t, 2, r, c2, text_color = tc, text_size = size.small, text_halign = text.align_right)
    table.cell(t, 3, r, c3, text_color = tc, text_size = size.small, text_halign = text.align_right)

var table ghT = table.new(position.bottom_right, 4, 15, bgcolor = color.new(color.black, 15), border_width = 1, border_color = color.new(color.gray, 70))
if i_ghost and showDiagTables and barstate.islast
    f_ghRow(ghT, 0, "MISSED (failed 1 filter)", "n", "W/L/scr", "net R", color.new(color.orange, 10))
    int totN = 0
    int totW = 0
    int totL = 0
    int totS = 0
    float totR = 0.0
    for rs = 1 to 12
        int n = array.get(ghCount, rs)
        int w = array.get(ghWins, rs)
        int l = array.get(ghLoss, rs)
        int sc = array.get(ghScr, rs)
        float nr = array.get(ghNetR, rs)
        totN += n
        totW += w
        totL += l
        totS += sc
        totR += nr
        color rowCol = n == 0 ? color.new(color.gray, 55) : nr > 0 ? color.new(color.lime, 15) : color.white
        f_ghRow(ghT, rs, array.get(ghNames, rs), str.tostring(n), str.tostring(w) + "/" + str.tostring(l) + "/" + str.tostring(sc), str.tostring(nr, "#.#"), rowCol)
    f_ghRow(ghT, 13, "TOTAL", str.tostring(totN), str.tostring(totW) + "/" + str.tostring(totL) + "/" + str.tostring(totS), str.tostring(totR, "#.#"), color.new(color.orange, 10))
else if barstate.islast
    table.clear(ghT, 0, 0, 3, 14)

var table beT = table.new(position.bottom_center, 4, 4, bgcolor = color.new(color.black, 15), border_width = 1, border_color = color.new(color.gray, 70))
if i_ghost and showDiagTables and barstate.islast
    int beScrTot = beScratchGh + beScratchRt
    int beMissTot = beMissedGh + beMissedRt
    int beRtWinTot = beRetestWinGh + beRetestWinRt
    color missCol = beMissTot > 0 ? color.new(color.orange, 0) : color.new(color.gray, 55)
    f_ghRow(beT, 0, "BE +1R retest", "scratch", "missed 5R", "retest→win", color.new(color.yellow, 10))
    f_ghRow(beT, 1, "Ghosts", str.tostring(beScratchGh), str.tostring(beMissedGh), str.tostring(beRetestWinGh), color.white)
    f_ghRow(beT, 2, "Real fills", str.tostring(beScratchRt), str.tostring(beMissedRt), str.tostring(beRetestWinRt), color.white)
    f_ghRow(beT, 3, "TOTAL", str.tostring(beScrTot), str.tostring(beMissTot), str.tostring(beRtWinTot), missCol)
else if barstate.islast
    table.clear(beT, 0, 0, 3, 3)
