//@version=6
// Morningstar lean — Manual Path B study
// DO NOT edit pine/Powell_Rejection_Block_v1.pine (locked Lab).
// Working fat backup: pine/_archive_Powell_Rejection_Block_gate_v0_working_before_slim_2026-07-16.pine
//
// KEEP: Path B dual sleeve · NWOG · PDH/PDL · Day IL · yellow 10:00 · plans
// Dual9: Day IL = THIS session's dealing-range low (fib LO), not multi-day ITL.
//   Powell arms from sticky 1m/5m RB projection boxes @ KO (archive model).
strategy(
     title                   = "Morningstar Dual (PRB gate_v0)",
     shorttitle              = "MS Dual9",
     overlay                 = true,
     pyramiding              = 0,
     process_orders_on_close = true,
     calc_on_every_tick      = true,
     max_bars_back           = 5000,
     initial_capital         = 50000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     commission_type         = strategy.commission.cash_per_contract,
     commission_value        = 0.62,
     slippage                = 1,
     margin_long             = 0,
     margin_short            = 0,
     max_lines_count         = 180,
     max_boxes_count         = 100,
     max_labels_count        = 120)

// ─── Inputs (ALL input.* must stay contiguous — no other code between them) ───
i_winEnd      = input.int(1300, "Last arm (HHMM)", minval = 0, maxval = 2359, group = "Session")
i_flatTime    = input.int(1555, "Session end label (HHMM)", minval = 0, maxval = 2359, group = "Session")
i_oneTradeDay = input.bool(false, "Max 1 setup per day (off when studying both sleeves)", group = "Session")
i_skipMonday  = input.bool(true, "Skip Mondays (SHADOW)", group = "Session")
i_skipJulOct  = input.bool(false, "Skip July & October (SHADOW)", group = "Session")
i_biasMode    = input.string("Long & Short", "Direction filter", options = ["Long & Short", "Long only", "Short only"], group = "Session")

grpPb = "Path B"
i_pathB = input.bool(true, "Enable Path B", group = grpPb)
// KO-leave = price LEFT the 10:00 key open, then RB@KO (NOT "skip this trade").
// KO-retest = later pullback to KO after a run (Powell-style) — any clock time.
i_pathBSleeve = input.string("KO-leave + KO-retest", "Which setups to show", options = ["KO-leave + KO-retest", "KO-leave only", "KO-retest only"], group = grpPb, tooltip = "KO-leave = RB after price left 10:00 open. KO-retest = pullback RB at KO after a run. Neither means 'skip the trade'.")
i_pathBAlign = input.float(50.0, "RB / KO proximity (pts)", minval = 2.0, step = 1.0, group = grpPb)
i_leaveWinMin = input.int(45, "KO-leave window (min after left KO)", minval = 10, maxval = 120, group = grpPb)
i_pathBMinFib = input.float(40.0, "KO-retest: min fib leg (pts)", minval = 5.0, step = 5.0, group = grpPb)
i_pathBAwayPts = input.float(25.0, "KO-retest: min away from KO (pts)", minval = 5.0, step = 5.0, group = grpPb)
i_pathBReqOte = input.bool(true, "KO-retest: require KO in fib OTE", group = grpPb, tooltip = "OFF if you use Daily ITL confluence instead.")
i_retestMinRisk = input.float(10.0, "Powell: min stop size (pts)", minval = 2.0, step = 0.5, group = grpPb)
i_leaveMinRisk = input.float(10.0, "KO-leave: min stop size (pts)", minval = 2.0, step = 0.5, group = grpPb)
i_leavePrefer5 = input.bool(true, "KO-leave: prefer soft 5m RB (else 1m)", group = grpPb)
i_powellUse1 = input.bool(true, "Powell: ARM from 1m RB projection box", group = grpPb, tooltip = "Archive control — 1m RB@KO latches a projecting box, then arms ENTRY/STOP/TP.")
i_powellUse5 = input.bool(true, "Powell: ARM from 5m RB projection box", group = grpPb, tooltip = "Also latch/arm from soft 5m RB@KO (same projection-box model).")
i_showDil = input.bool(true, "Show Day IL (this session)", group = grpPb, tooltip = "THIS calendar day's Path B dealing-range low (fib LO for longs). Not a multi-day ICT ITL.")
i_retestNearDil = input.bool(true, "Powell: RB should tag Day IL or KO-in-OTE", group = grpPb)
i_dilAlign = input.float(40.0, "Day IL proximity (pts)", minval = 2.0, step = 1.0, group = grpPb)
i_retestMinAfterLeave = input.int(20, "Powell: min minutes after leave", minval = 5, maxval = 180, group = grpPb)
i_latchBars = input.int(90, "RB latch lifetime (chart bars)", minval = 10, maxval = 300, group = grpPb, tooltip = "How long a 1m/5m projection box stays armed-ready before it expires.")
i_projMin = input.int(45, "Projection box length (minutes)", minval = 10, maxval = 180, group = grpPb)
i_minWick1 = input.float(4.0, "Min 1m RB wick (pts)", minval = 1.0, step = 0.5, group = grpPb)
i_minWick5 = input.float(6.0, "Min 5m RB wick (pts)", minval = 2.0, step = 0.5, group = grpPb)
i_localLen = input.int(12, "Formal 5m extreme lookback", minval = 4, maxval = 50, group = grpPb)
i_confClose = input.bool(true, "RB needs confirming close", group = grpPb)
i_pathBShowFib = input.bool(true, "Show fib LO / HI anchors only", group = grpPb)
i_pathBShowState = input.bool(true, "Show Path B status tag", group = grpPb)

i_showNwog = input.bool(true, "Show NWOG (Fri→Sun 18:00)", group = "Levels")
i_nwogMinPts = input.float(5.0, "Min NWOG size (pts)", minval = 0.5, step = 0.5, group = "Levels")
i_showPdhPdl = input.bool(true, "Show PDH / PDL", group = "Levels")
i_showPend = input.bool(true, "Show ENTRY / STOP / TP", group = "Levels")
i_showFillKpi = input.bool(true, "Show fill / outcome KPI", group = "Levels")
i_showSig = input.bool(true, "Show armed RB box", group = "Levels")
i_rbExtend = input.int(24, "RB box extend (bars)", minval = 4, maxval = 80, group = "Levels")
i_rbNoFill = input.bool(true, "RB box: border only", group = "Levels")

i_maxStopPts = input.float(40.0, "Max stop (pts)", minval = 2.0, step = 1.0, group = "Risk")
i_minStopPts = input.float(3.0, "Min stop (pts)", minval = 0.0, step = 0.5, group = "Risk")
i_stopBufPts = input.float(2.0, "Stop buffer (pts)", minval = 0.0, step = 0.25, group = "Risk")
i_rr = input.float(5.0, "Target (R)", minval = 1.0, step = 0.25, group = "Risk")

c_bear = input.color(#ef4444, "Bearish", group = "Colors")
c_bull = input.color(#7dd3fc, "Bullish", group = "Colors")
c_ce = input.color(#e2e8f0, "CE", group = "Colors")
c_limit = input.color(#f8fafc, "ENTRY", group = "Colors")
c_stop = input.color(#f87171, "STOP", group = "Colors")
c_tp = input.color(#34d399, "TP", group = "Colors")
c_pdh = input.color(#22c55e, "PDH", group = "Colors")
c_pdl = input.color(#ef4444, "PDL", group = "Colors")
c_win10 = input.color(#eab308, "10:00 wash", group = "Colors")

// Derived flags (after ALL inputs)
bool wantLeave = i_pathBSleeve == "KO-leave + KO-retest" or i_pathBSleeve == "KO-leave only"
bool wantRetest = i_pathBSleeve == "KO-leave + KO-retest" or i_pathBSleeve == "KO-retest only"
bool biasOkShort = i_biasMode != "Long only"
bool biasOkLong = i_biasMode != "Short only"

// ─── Time ────────────────────────────────────────────────────────────────────
int nyHhmm = hour(time, "America/New_York") * 100 + minute(time, "America/New_York")
int nyMonth = month(time, "America/New_York")
int nyDow = dayofweek(time, "America/New_York")
int nyYmd = year(time, "America/New_York") * 10000 + nyMonth * 100 + dayofmonth(time, "America/New_York")
// CME daily bars roll ~18:00 ET — do NOT wipe Path B / plans on that. Calendar midnight only.
bool newCalDay = ta.change(nyYmd) != 0
// Session day (exchange "D") — PDH/PDL / day high-low only
bool newSessDay = ta.change(time("D", "America/New_York")) != 0
bool canPlace = nyHhmm < i_winEnd
bool mondayOk = not i_skipMonday or nyDow != dayofweek.monday
bool monthOk = not i_skipJulOct or (nyMonth != 7 and nyMonth != 10)
bool dayAllowed = mondayOk and monthOk

// ─── Levels ──────────────────────────────────────────────────────────────────
float prevDayHigh = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
float prevDayLow = request.security(syminfo.tickerid, "D", low[1], lookahead = barmerge.lookahead_on)

var float curDayHigh = na
var float curDayLow = na
var int curDayHighBar = na
var int curDayLowBar = na
var float pdhLvl = na
var float pdlLvl = na
var int pdhOriginBar = na
var int pdlOriginBar = na
var float ko1000 = na
var float nwogFriClose = na
var int nwogGapTime = na

if newSessDay
    pdhLvl := curDayHigh
    pdlLvl := curDayLow
    pdhOriginBar := curDayHighBar
    pdlOriginBar := curDayLowBar
    curDayHigh := high
    curDayLow := low
    curDayHighBar := bar_index
    curDayLowBar := bar_index
else
    if na(curDayHigh) or high >= curDayHigh
        curDayHigh := high
        curDayHighBar := bar_index
    if na(curDayLow) or low <= curDayLow
        curDayLow := low
        curDayLowBar := bar_index

// 10:00 KO is a calendar RTH print — clear only at NY midnight, never at 18:00 session roll
if newCalDay
    ko1000 := na
bool ko1000Print = nyHhmm >= 1000 and nyHhmm[1] < 1000
bool ko1000Fallback = nyHhmm >= 1000 and na(ko1000)
if ko1000Print or ko1000Fallback
    ko1000 := open

bool isFri = nyDow == dayofweek.friday
bool isSun = nyDow == dayofweek.sunday
bool isMon = nyDow == dayofweek.monday
if isFri
    nwogFriClose := close
bool nwogSunOpenBar = isSun and nyHhmm >= 1800 and nyHhmm[1] < 1800
bool nwogMonFallback = isMon and nyHhmm >= 930 and nyHhmm[1] < 930

// ─── RB packs ────────────────────────────────────────────────────────────────
// Formal pack (local extreme) — 5m/15m marks
f_htfPack(float minW) =>
    float o1 = open[1]
    float h1 = high[1]
    float l1 = low[1]
    float c1 = close[1]
    float uw = h1 - math.max(o1, c1)
    float lw = math.min(o1, c1) - l1
    bool locH = h1 >= ta.highest(high, i_localLen)[1]
    bool locL = l1 <= ta.lowest(low, i_localLen)[1]
    bool bear = locH and uw >= minW and (not i_confClose or c1 < o1)
    bool bull = locL and lw >= minW and (not i_confClose or c1 > o1)
    [bear, bull, h1, l1, math.max(o1, c1), math.min(o1, c1)]

// Path B 1m arm pack — wick rejection only (NO local-extreme).
// KO retests often are not the 12-bar low/high; requiring locL/locH killed the 11:15 entry.
f_pb1Pack(float minW) =>
    float o1 = open[1]
    float h1 = high[1]
    float l1 = low[1]
    float c1 = close[1]
    float uw = h1 - math.max(o1, c1)
    float lw = math.min(o1, c1) - l1
    bool bear = uw >= minW and (not i_confClose or c1 < o1)
    bool bull = lw >= minW and (not i_confClose or c1 > o1)
    [bear, bull, h1, l1, math.max(o1, c1), math.min(o1, c1)]

// Soft packs (wick only) arm leave/retest. Formal 5m pack is eyes / optional quality.
[b1s, u1s, h1s, l1s, wsB1s, wsU1s] = request.security(syminfo.tickerid, "1", f_pb1Pack(i_minWick1), barmerge.gaps_off, barmerge.lookahead_off)
[b5soft, u5soft, h5s, l5s, wsB5s, wsU5s] = request.security(syminfo.tickerid, "5", f_pb1Pack(i_minWick5), barmerge.gaps_off, barmerge.lookahead_off)
[b5form, u5form, h5f, l5f, wsB5f, wsU5f] = request.security(syminfo.tickerid, "5", f_htfPack(i_minWick5), barmerge.gaps_off, barmerge.lookahead_off)
int t1sec = request.security(syminfo.tickerid, "1", time, barmerge.gaps_off, barmerge.lookahead_off)
int t5sec = request.security(syminfo.tickerid, "5", time, barmerge.gaps_off, barmerge.lookahead_off)
bool new1Bar = ta.change(t1sec) != 0
bool new5Bar = ta.change(t5sec) != 0

bool on1m = timeframe.period == "1"
bool on5m = timeframe.period == "5"
[b1c, u1c, h1c, l1c, wsB1c, wsU1c] = f_pb1Pack(i_minWick1)
bool b1 = on1m ? b1c : b1s
bool u1 = on1m ? u1c : u1s
float h1 = on1m ? h1c : h1s
float l1 = on1m ? l1c : l1s
float wsB1 = on1m ? wsB1c : wsB1s
float wsU1 = on1m ? wsU1c : wsU1s
bool trig1 = barstate.isconfirmed and (on1m or new1Bar)
bool trig5 = barstate.isconfirmed and (on5m or new5Bar)
// Soft 5m for arming; formal aliases for MARK eyes
bool b5 = b5soft
bool u5 = u5soft
float h5 = h5s
float l5 = l5s
float wsB5 = wsB5s
float wsU5 = wsU5s

// ─── Plan math ───────────────────────────────────────────────────────────────
f_plan(float wickStart, float ce, float extreme, bool isShort) =>
    float stopPx = isShort ? extreme + i_stopBufPts : extreme - i_stopBufPts
    float riskWs = math.abs(stopPx - wickStart)
    float riskCe = math.abs(stopPx - ce)
    // Prefer wick-start; fall back to CE; last resort CE with stop capped at max
    float entryPx = riskWs >= i_minStopPts and riskWs <= i_maxStopPts ? wickStart : riskCe >= i_minStopPts and riskCe <= i_maxStopPts ? ce : na
    float stopOut = na(entryPx) ? na : stopPx
    if na(entryPx) and riskCe > i_maxStopPts and riskCe > 0
        entryPx := ce
        stopOut := isShort ? ce + i_maxStopPts : ce - i_maxStopPts
    [entryPx, stopOut]

f_shadowArmLabel() =>
    not monthOk ? "SHADOW Jul/Oct" : not mondayOk ? "SHADOW Mon" : "ARMED — you click"

f_nearKo(float a, float b) =>
    not na(a) and not na(b) and math.abs(a - b) <= i_pathBAlign

// True if KO sits in/near the RB wick band (not only exact extreme touch)
f_nearKoBand(float hi, float lo, float ko) =>
    not na(hi) and not na(lo) and not na(ko) and lo <= ko + i_pathBAlign and hi >= ko - i_pathBAlign

