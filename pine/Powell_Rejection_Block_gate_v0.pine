    oLbS := na
    oLbT := na
    oBxRisk := na
    oBxRew := na
    oBxRb := na
    if not na(pbLnFib0)
        line.delete(pbLnFib0)
    if not na(pbLnFib1)
        line.delete(pbLnFib1)
    if not na(pbLnFibLeg)
