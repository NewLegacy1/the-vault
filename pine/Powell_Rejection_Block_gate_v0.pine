    pbLatchEx := na
    pbLatchDir := 0
    pbLatchTime := na
    pbLatchTag := "—"
    dilPx := na
    if not na(pbProjBox)
        box.delete(pbProjBox)
    if not na(pbProjCe)
        line.delete(pbProjCe)
    if not na(pbProjLbl)
        label.delete(pbProjLbl)
    pbProjBox := na
    pbProjCe := na
    pbProjLbl := na
    utWs := na
    utCe := na
    utEx := na
    utDir := 0
    utTime := na
    utTag := "—"
    utLive := false
    utFreed := false
    if not na(utBox)
        box.delete(utBox)
    if not na(utCeLn)
        line.delete(utCeLn)
    if not na(utLbl)
        label.delete(utLbl)
    utBox := na
    utCeLn := na
    utLbl := na

// Day IL / Day IH — RTH only. Snapshot the exact bar that prints the low.
bool rthDil = nyHhmm >= 930 and nyHhmm < i_flatTime
float pivLo = ta.pivotlow(low, i_dilPivot, i_dilPivot)
float pivHi = ta.pivothigh(high, i_dilPivot, i_dilPivot)
bool madeNewDil = false
bool madeNewDih = false
bool dilSweepFinal = false
if rthDil
    // New session low → snapshot THIS bar only (never a later tag of the same low)
    if na(dilRaw) or low < dilRaw
        madeNewDil := true
        dilRaw := low
        dilRawTime := time
        dilSweepO := open
        dilSweepH := high
        dilSweepL := low
        dilSweepC := close
        dilSweepT := time
    if na(dihRaw) or high > dihRaw
        madeNewDih := true
        dihRaw := high
        dihRawTime := time
    // Finalize OHLC only on the print bar itself (dilSweepT == time). Later bars that
    // merely wick back to Day IL must NOT overwrite wick-start.
    if barstate.isconfirmed and not na(dilSweepT) and dilSweepT == time
        dilSweepO := open
        dilSweepH := high
        dilSweepL := low
        dilSweepC := close
        dilSweepFinal := true
    // Lock Day IL from absolute session low
    if not na(dilRaw) and high >= dilRaw + i_dilBounce
        if na(dilPx) or dilRaw < dilPx
            dilPx := dilRaw
            dilTag := "Day IL"
    if not na(dihRaw) and low <= dihRaw - i_dilBounce
        if na(dihPx) or dihRaw > dihPx
            dihPx := dihRaw
    if na(dilPx) and not na(pivLo)
        dilPx := pivLo
        dilTag := "Day IL"
    if na(dihPx) and not na(pivHi)
        dihPx := pivHi

// Soft / formal RB quality (leave sleeve / optional) — Day-IL pool does NOT use these
float body1 = math.max(math.abs(wsB1 - wsU1), syminfo.mintick)
float lw1 = wsU1 - l1
float uw1 = h1 - wsB1
float body5 = math.max(math.abs(wsB5 - wsU5), syminfo.mintick)
float lw5 = wsU5 - l5
float uw5 = h5 - wsB5
float minW1s = i_powellSoft ? math.max(2.0, i_minWick1 * 0.5) : i_minWick1
float minW5s = i_powellSoft ? math.max(3.0, i_minWick5 * 0.5) : i_minWick5
float bodMult = i_powellSoft ? 0.55 : i_rbWickBody
bool softU1 = not na(l1) and lw1 >= minW1s and lw1 >= body1 * bodMult and lw1 >= uw1
bool softB1 = not na(h1) and uw1 >= minW1s and uw1 >= body1 * bodMult and uw1 >= lw1
bool softU5 = not na(l5) and lw5 >= minW5s and lw5 >= body5 * bodMult and lw5 >= uw5
bool softB5 = not na(h5) and uw5 >= minW5s and uw5 >= body5 * bodMult and uw5 >= lw5
bool powU1 = u1 or (i_powellSoft and softU1)
bool powB1 = b1 or (i_powellSoft and softB1)
bool powU5 = u5 or (i_powellSoft and softU5)
bool powB5 = b5 or (i_powellSoft and softB5)

// Day-IL untapped RB — print-bar snapshot only. Wick-start = min(O,C) of sweep candle.
f_utWickStart(float o, float c, float lo) =>
    float ws = math.min(o, c)
    // If body closed at the low, use top of body (teaching wick-start above extreme)
    if ws <= lo + syminfo.mintick
        ws := math.max(o, c)
    ws

bool utDoStore = false
float utNewWs = na
float utNewCe = na
float utNewEx = na
int utNewDir = 0
int utNewT = na
string utNewTag = "—"
// Pool on the confirmed bar that prints a NEW session low (before Path B / after)
if i_pathB and rthDil and not oArmed and barstate.isconfirmed and i_powellUse5 and madeNewDil and not na(dilSweepL)
    float sws = f_utWickStart(dilSweepO, dilSweepC, dilSweepL)
    float sex = dilSweepL
    bool deeper = not utLive or sex < utEx - syminfo.mintick
    if deeper or not utLive
        utDoStore := true
        utNewWs := sws
        utNewCe := (sex + sws) * 0.5
        utNewEx := sex
        utNewDir := 1
        utNewT := dilSweepT
        utNewTag := "5m RB·DayIL"
if utDoStore and not na(utNewWs) and not na(utNewT)
    if not na(utBox)
        box.delete(utBox)
    if not na(utCeLn)
        line.delete(utCeLn)
    if not na(utLbl)
        label.delete(utLbl)
    utWs := utNewWs
    utCe := utNewCe
    utEx := utNewEx
    utDir := utNewDir
    utTime := utNewT
    utTag := utNewTag
    utLive := true
    utFreed := false
    int utXR = utNewT + math.max(i_projMin, 120) * 60 * 1000
    color utCol = utNewDir == 1 ? c_bull : c_bear
    utBox := box.new(utNewT, math.max(utNewEx, utNewWs), utXR, math.min(utNewEx, utNewWs), xloc = xloc.bar_time, border_color = utCol, bgcolor = i_rbNoFill ? color.new(utCol, 100) : color.new(utCol, 88), border_width = 2)
    utCeLn := line.new(utNewT, utNewCe, utXR, utNewCe, xloc = xloc.bar_time, color = c_ce, width = 1, style = line.style_dotted)
    utLbl := label.new(utNewT, math.max(utNewEx, utNewWs), utNewTag + " · sweep wick", xloc = xloc.bar_time, style = label.style_label_down, color = #0f172a, textcolor = utCol, size = size.small)

// Keep pool glued to Day IL print extreme
if utLive and not na(dilRaw) and utDir == 1 and not oArmed
    if math.abs(utEx - dilRaw) > syminfo.mintick * 4
        utLive := false
        if not na(utBox)
            box.delete(utBox)
        if not na(utCeLn)
            line.delete(utCeLn)
        if not na(utLbl)
            label.delete(utLbl)
        utBox := na
        utCeLn := na
        utLbl := na

// Untapped lifecycle: free → stay valid → early tap kills → break kills
bool powellGateOpen = pbLeft and pbAway >= i_pathBAwayPts and not na(pbLeaveTime) and (time - pbLeaveTime) >= i_retestMinAfterLeave * 60 * 1000 and (time - pbLeaveTime) > i_leaveWinMin * 60 * 1000
if utLive and not oArmed and not na(utTime) and time > utTime
    if utDir == 1
        if not utFreed and close >= utWs + i_utFreePts
            utFreed := true
        if low < utEx
            utLive := false
            if not na(utBox)
                box.delete(utBox)
            if not na(utCeLn)
                line.delete(utCeLn)
            if not na(utLbl)
                label.delete(utLbl)
            utBox := na
            utCeLn := na
            utLbl := na
        else if utFreed and low <= utWs and not powellGateOpen
            utLive := false
            if not na(utBox)
                box.delete(utBox)
            if not na(utCeLn)
                line.delete(utCeLn)
            if not na(utLbl)
                label.delete(utLbl)
            utBox := na
            utCeLn := na
            utLbl := na
    if utDir == -1 and utLive
        if not utFreed and close <= utWs - i_utFreePts
            utFreed := true
        if high > utEx
            utLive := false
            if not na(utBox)
                box.delete(utBox)
            if not na(utCeLn)
                line.delete(utCeLn)
            if not na(utLbl)
                label.delete(utLbl)
            utBox := na
            utCeLn := na
            utLbl := na
        else if utFreed and high >= utWs and not powellGateOpen
            utLive := false
            if not na(utBox)
                box.delete(utBox)
            if not na(utCeLn)
                line.delete(utCeLn)
            if not na(utLbl)
                label.delete(utLbl)
            utBox := na
            utCeLn := na
            utLbl := na

// Keep untapped box projected forward while live
if utLive and not na(utBox) and not na(utTime)
    int utRight = time + 20 * 60 * 1000
    box.set_right(utBox, utRight)
    if not na(utCeLn)
        line.set_x2(utCeLn, utRight)
    if not na(utLbl)
        label.set_xy(utLbl, utTime, math.max(utEx, utWs))
        label.set_text(utLbl, utTag + (utFreed ? " · waiting return" : " · freeing"))

// ─── Path B ──────────────────────────────────────────────────────────────────
// Leave: soft RB@KO. Powell: return into pre-10:00 untapped RB @ Day IL (wick-start entry).
bool pbOn = i_pathB and not na(ko1000) and nyHhmm >= 1000 and (nyHhmm < i_winEnd or pbLeft or eArmed or oArmed)
bool nearDil = false
bool hasAway = false
bool inLeaveWin = false
bool longEnoughAfterLeave = false
bool pbStopFail = false
int leaveDir = 0
float leaveWs = na
float leaveCe = na
float leaveEx = na
string leaveTf = "5RB"
int retestDir = 0
float retestWs = na
float retestCe = na
float retestEx = na
string retestTf = "1RB"

if pbOn
    if na(pbHi) or high >= pbHi
        pbHi := high
        pbHiBar := bar_index
    if na(pbLo) or low <= pbLo
        pbLo := low
        pbLoBar := bar_index
    if high > ko1000
        pbPierceAbove := true
        pbManip := true
    if low < ko1000
        pbPierceBelow := true
        pbManip := true
    if pbManip and not pbLeft and barstate.isconfirmed and canPlace
        if pbPierceAbove and close < ko1000
            pbLeft := true
            pbDir := -1
            pbLeaveBar := bar_index
            pbLeaveTime := time
            pbAway := 0.0
            pbAwayPeakBar := na
            pbAwayPeakTime := na
            pbReturned := false
            pbReturnedDil := false
            pbFibHi := pbHi
            pbFibLo := pbLo
            pbFibLoBar := pbLoBar
            pbFibHiBar := pbHiBar
        else if pbPierceBelow and close > ko1000
            pbLeft := true
            pbDir := 1
            pbLeaveBar := bar_index
            pbLeaveTime := time
            pbAway := 0.0
            pbAwayPeakBar := na
            pbAwayPeakTime := na
            pbReturned := false
            pbReturnedDil := false
            pbFibHi := pbHi
            pbFibLo := pbLo
            pbFibLoBar := pbLoBar
            pbFibHiBar := pbHiBar
    if pbLeft
        if pbDir == 1 and high >= pbFibHi
            pbFibHi := high
            pbFibHiBar := bar_index
        if pbDir == -1 and low <= pbFibLo
            pbFibLo := low
            pbFibLoBar := bar_index
        if not na(pbLeaveBar) and bar_index > pbLeaveBar
            float awayNow = pbDir == 1 ? high - ko1000 : pbDir == -1 ? ko1000 - low : 0.0
            if awayNow > pbAway
                pbAway := awayNow
                pbAwayPeakBar := bar_index
                pbAwayPeakTime := time
            float retPad = i_pathBAlign
            if pbAway >= i_pathBAwayPts and not na(pbAwayPeakTime) and time > pbAwayPeakTime
                if pbDir == 1 and low <= ko1000 + retPad
                    pbReturned := true
                if pbDir == -1 and high >= ko1000 - retPad
                    pbReturned := true

    hasAway := pbAway >= i_pathBAwayPts
    inLeaveWin := not na(pbLeaveTime) and (time - pbLeaveTime) <= i_leaveWinMin * 60 * 1000

    // Active day level for Powell: Day IL (longs) / Day IH (shorts) — never fib
    float dayLvl = pbDir == -1 ? dihPx : dilPx
    nearDil := not na(dayLvl)

    bool nearKo5B = f_nearKo(h5, ko1000) or f_nearKo(wsB5, ko1000) or f_nearKoBand(h5, wsB5, ko1000)
    bool nearKo5U = f_nearKo(l5, ko1000) or f_nearKo(wsU5, ko1000) or f_nearKoBand(wsU5, l5, ko1000)
    bool nearKo1B = f_nearKo(h1, ko1000) or f_nearKo(wsB1, ko1000) or f_nearKoBand(h1, wsB1, ko1000)
    bool nearKo1U = f_nearKo(l1, ko1000) or f_nearKo(wsU1, ko1000) or f_nearKoBand(wsU1, l1, ko1000)

    // Soft RB for leave sleeve (immediate) — still @ KO / fib-0 geometry
    if pbLeft and barstate.isconfirmed
        if pbDir == 1
            if i_leavePrefer5 and trig5 and u5 and nearKo5U
                leaveDir := 1
                leaveWs := wsU5
                leaveEx := l5
                leaveCe := (l5 + wsU5) * 0.5
                leaveTf := "5RB"
            else if trig1 and u1 and nearKo1U
                leaveDir := 1
                leaveWs := wsU1
                leaveEx := l1
                leaveCe := (l1 + wsU1) * 0.5
                leaveTf := "1RB"
        if pbDir == -1
            if i_leavePrefer5 and trig5 and b5 and nearKo5B
                leaveDir := -1
                leaveWs := wsB5
                leaveEx := h5
                leaveCe := (h5 + wsB5) * 0.5
                leaveTf := "5RB"
            else if trig1 and b1 and nearKo1B
                leaveDir := -1
                leaveWs := wsB1
                leaveEx := h1
                leaveCe := (h1 + wsB1) * 0.5
                leaveTf := "1RB"

    // Return into Day IL / untapped RB after the away-run
    if pbLeft and not na(pbAwayPeakBar) and bar_index >= pbAwayPeakBar and pbAway >= i_pathBAwayPts
        if utLive and utDir == 1 and low <= utWs
            pbReturnedDil := true
        if utLive and utDir == -1 and high >= utWs
            pbReturnedDil := true
        if nearDil and pbDir == 1 and low <= dayLvl + i_dilAlign
            pbReturnedDil := true
        if nearDil and pbDir == -1 and high >= dayLvl - i_dilAlign
            pbReturnedDil := true

    longEnoughAfterLeave := not na(pbLeaveTime) and (time - pbLeaveTime) >= i_retestMinAfterLeave * 60 * 1000
    bool powellWindow = pbLeft and hasAway and not inLeaveWin and longEnoughAfterLeave and barstate.isconfirmed

    // Powell latch = the pre-pooled untapped RB (formed as early as 09:30) — NOT a new post-10:00 RB
    if powellWindow and not oArmed and utLive and utFreed
        bool utTouch = utDir == 1 ? low <= utWs and low >= utEx - i_dilAlign : high >= utWs and high <= utEx + i_dilAlign
        bool utDirOk = utDir == pbDir or pbDir == 0 or (pbDir == 1 and utDir == 1) or (pbDir == -1 and utDir == -1)
        bool utDilOk = not i_retestNearDil or na(dayLvl) or f_nearDil(utEx, dayLvl) or f_nearDilBand(math.max(utEx, utWs), math.min(utEx, utWs), dayLvl)
        if utTouch and utDirOk and utDilOk
            pbLatchWs := utWs
            pbLatchEx := utEx
            pbLatchCe := utCe
            pbLatchDir := utDir
            pbLatchTime := utTime
            pbLatchTag := utTag + " · return"
            if not na(pbProjBox)
                box.delete(pbProjBox)
            if not na(pbProjCe)
                line.delete(pbProjCe)
            if not na(pbProjLbl)
                label.delete(pbProjLbl)
            // Re-use untapped box as the armed projection reference
            pbProjBox := utBox
            pbProjCe := utCeLn
            pbProjLbl := utLbl
            utBox := na
            utCeLn := na
            utLbl := na

    // Live values from untapped-return latch for arming (entry = wick start)
    retestDir := pbLatchDir
    retestWs := pbLatchWs
    retestCe := pbLatchCe
    retestEx := pbLatchEx
    retestTf := str.contains(pbLatchTag, "5m") ? "5RB" : "1RB"

    bool leaveBiasOk = (leaveDir == -1 and biasOkShort) or (leaveDir == 1 and biasOkLong)
    bool retestBiasOk = (retestDir == -1 and biasOkShort) or (retestDir == 1 and biasOkLong)
    bool singleSlotLock = i_oneTradeDay and i_pathBSleeve != "KO-leave + KO-retest" and (eArmed or oArmed)
    bool leaveTick = leaveTf == "5RB" ? trig5 : trig1
    bool rbNearDil = not na(dayLvl) and not na(retestEx) and (f_nearDil(retestEx, dayLvl) or f_nearDil(retestWs, dayLvl) or f_nearDilBand(math.max(retestEx, retestWs), math.min(retestEx, retestWs), dayLvl))
    bool retestConfl = not i_retestNearDil or rbNearDil or str.contains(pbLatchTag, "DayIL") or str.contains(pbLatchTag, "DayIH")

    // KO-leave — soft RB@KO soon after leave (min risk kills 6pt junk; 1m fallback if 5m too small)
    if wantLeave and not eArmed and canPlace and not singleSlotLock and leaveBiasOk and leaveDir != 0 and leaveTick and inLeaveWin and not pbReturned
        float useWs = leaveWs
        float useCe = leaveCe
        float useEx = leaveEx
        int useDir = leaveDir
        string useTf = leaveTf
        [ePlan0, sPlan0] = f_plan(useWs, useCe, useEx, useDir == -1)
        float entryPx = ePlan0
        float stopPx = sPlan0
        float riskPts0 = na(entryPx) ? na : math.abs(stopPx - entryPx)
        if (na(entryPx) or riskPts0 < i_leaveMinRisk) and trig1 and pbDir == 1 and u1 and nearKo1U
            useWs := wsU1
            useCe := (l1 + wsU1) * 0.5
            useEx := l1
            useDir := 1
            useTf := "1RB"
            [ePlan1, sPlan1] = f_plan(useWs, useCe, useEx, false)
            entryPx := ePlan1
            stopPx := sPlan1
            riskPts0 := na(entryPx) ? na : math.abs(stopPx - entryPx)
        if (na(entryPx) or riskPts0 < i_leaveMinRisk) and trig1 and pbDir == -1 and b1 and nearKo1B
            useWs := wsB1
            useCe := (h1 + wsB1) * 0.5
            useEx := h1
            useDir := -1
            useTf := "1RB"
            [ePlan2, sPlan2] = f_plan(useWs, useCe, useEx, true)
            entryPx := ePlan2
            stopPx := sPlan2
            riskPts0 := na(entryPx) ? na : math.abs(stopPx - entryPx)
        if na(entryPx) or riskPts0 < i_leaveMinRisk
            pbStopFail := true
        else
            eArmed := true
            eDir := useDir
            eTime := time
            eWs := useWs
            eCe := useCe
            eEx := useEx
            eEntry := entryPx
            eStop := stopPx
            eTp := useDir == 1 ? entryPx + i_rr * riskPts0 : entryPx - i_rr * riskPts0
            eTag := "leave · " + useTf
            eFill := 1
            eEndTime := na
            eKpi := "live"
            manualReady := true

    // Powell — arm from sticky 1m/5m projection-box latch @ Day IL
    bool retestReady = hasAway and pbReturnedDil and not inLeaveWin and longEnoughAfterLeave and retestConfl and pbLatchDir != 0 and not na(pbLatchWs)
    if wantRetest and not oArmed and canPlace and not singleSlotLock and retestBiasOk and retestReady and barstate.isconfirmed
        [entryPx2, stopPx2] = f_plan(retestWs, retestCe, retestEx, retestDir == -1)
        float riskPts1 = na(entryPx2) ? na : math.abs(stopPx2 - entryPx2)
        bool retestSizeOk = not na(riskPts1) and riskPts1 >= i_retestMinRisk
        if na(entryPx2) or not retestSizeOk
            pbStopFail := true
        else
            oArmed := true
            oDir := retestDir
            oTime := not na(pbLatchTime) ? pbLatchTime : time
            oEndTime := na
            oWs := retestWs
            oCe := retestCe
            oEx := retestEx
            oEntry := entryPx2
            oStop := stopPx2
            oTp := retestDir == 1 ? entryPx2 + i_rr * riskPts1 : entryPx2 - i_rr * riskPts1
            oTag := "Powell · " + retestTf + " · untapped DayIL"
            // consume untapped pool — trade taken on first return
            utLive := false
            utFreed := false
            oFill := 1
            oKpi := "live"
            manualReady := true
            // consume latch so it doesn't re-fire
            pbLatchDir := 0
            pbLatchWs := na
            pbLatchTag := "—"

// Status
if not i_pathB
    pbState := "Path B off"
else if nyHhmm < 1000 or na(ko1000)
    pbState := utLive ? "B pre-10 · " + utTag + (utFreed ? " untapped" : " freeing") : "B before 10:00 · scan RB"
else if not pbManip
    pbState := utLive ? "B wait manip · " + utTag : "B wait manip"
else if not pbLeft
    pbState := canPlace ? (utLive ? "B wait leave · untapped ready" : "B wait leave") : "B no leave (arm window ended)"
else
    string ePart = eArmed ? "leave✓" : wantLeave ? (pbReturned or not inLeaveWin ? "leave missed" : "leave wait RB") : ""
    string oGate = not longEnoughAfterLeave ? "Powell wait time" : not utLive ? "Powell no untapped RB" : not utFreed ? "Powell RB not freed" : pbLatchDir == 0 ? "Powell wait return→RB" : "Powell latch ready"
    string oPart = oArmed ? "Powell✓" : wantRetest ? (inLeaveWin ? "Powell wait leave-win" : not hasAway ? "Powell wait away" : not pbReturnedDil ? "Powell wait return→RB" : oGate) : ""
    if eArmed or oArmed
        pbState := ePart + (eArmed and wantRetest ? " · " : "") + oPart
        if eArmed
            pbState := pbState + " · " + eKpi
        if oArmed
            pbState := pbState + (eArmed ? " | " : " · ") + oKpi
    else if pbStopFail
        pbState := "B stop size fail"
    else
        pbState := ePart + (str.length(ePart) > 0 and str.length(oPart) > 0 ? " · " : "") + oPart
        if not na(dilPx)
            pbState := pbState + " · " + dilTag + " " + str.tostring(dilPx, "#.#")
        if utLive
            pbState := pbState + " · " + utTag

if i_pathBShowState
    if na(pbStateLbl)
        pbStateLbl := label.new(bar_index, high, pbState, style = label.style_label_down, color = color.new(#0f172a, 20), textcolor = color.white, size = size.small)
    else
        label.set_xy(pbStateLbl, bar_index, high)
        label.set_text(pbStateLbl, pbState)

// Fill KPI — freeze boxes when TP/STOP trades (even if limit never re-tapped)
f_updFill(int st, int armTime, int dir, float entry, float stop, float tp) =>
    int out = st
    if st < 3 and not na(armTime) and time > armTime
        bool hitEntry = dir == 1 ? low <= entry : high >= entry
        bool hitStop = dir == 1 ? low <= stop : high >= stop
        bool hitTp = dir == 1 ? high >= tp : low <= tp
        if st == 1 and (hitEntry or hitStop or hitTp)
            out := 2
        if out == 2 or st == 2
            if hitStop
                out := 4
            else if hitTp
                out := 3
        if out == 1 and nyHhmm >= i_flatTime
            out := 5
        if out == 2 and nyHhmm >= i_flatTime
            out := 5
    string kpi = out == 1 ? "live" : out == 2 ? "filled" : out == 3 ? "WIN" : out == 4 ? "LOSS" : out == 5 ? "no fill" : "—"
    [out, kpi]

// Simulate fills; lock end time once resolved so boxes never chase the live edge
if eArmed and barstate.isconfirmed
    int ePrev = eFill
    [eFillTmp, eKpiTmp] = f_updFill(eFill, eTime, eDir, eEntry, eStop, eTp)
    eFill := eFillTmp
    eKpi := eKpiTmp
    if eFill >= 3 and (na(eEndTime) or ePrev < 3)
        eEndTime := time
if oArmed and barstate.isconfirmed
    int oPrev = oFill
    [oFillTmp, oKpiTmp] = f_updFill(oFill, oTime, oDir, oEntry, oStop, oTp)
    oFill := oFillTmp
    oKpi := oKpiTmp
    if oFill >= 3 and (na(oEndTime) or oPrev < 3)
        oEndTime := time

if eArmed or oArmed
    manualReady := true

// ─── Fib anchors only (LO + HI) — you place the fib tool ─────────────────────
bool pbFibReady = i_pathBShowFib and pbLeft and not na(pbFibHi) and not na(pbFibLo) and pbFibHi > pbFibLo
float pbFibPlotLo = pbFibReady ? pbFibLo : na
float pbFibPlotHi = pbFibReady ? pbFibHi : na
if pbFibReady
    float rng = pbFibHi - pbFibLo
    int x0 = na(pbFibLoBar) ? math.max(0, bar_index - 8) : pbFibLoBar
    int x1 = na(pbFibHiBar) ? bar_index : pbFibHiBar
    int xL = math.min(x0, x1)
    int xR = math.max(bar_index + 8, math.max(x0, x1) + 6)
    float tick = math.max(rng * 0.015, syminfo.mintick * 8)
    float midY = (pbFibHi + pbFibLo) * 0.5
    if na(pbLnFib0) or na(pbLbl0)
        if not na(pbLnFib0)
            line.delete(pbLnFib0)
        if not na(pbLnFib1)
            line.delete(pbLnFib1)
        if not na(pbLnFibLeg)
            line.delete(pbLnFibLeg)
        if not na(pbLnFib0Tick)
            line.delete(pbLnFib0Tick)
        if not na(pbLnFib1Tick)
            line.delete(pbLnFib1Tick)
        if not na(pbLbl)
            label.delete(pbLbl)
        if not na(pbLbl0)
            label.delete(pbLbl0)
        if not na(pbLbl1)
            label.delete(pbLbl1)
        pbLnFib0 := line.new(xL, pbFibLo, xR, pbFibLo, color = #f59e0b, width = 1)
        pbLnFib1 := line.new(xL, pbFibHi, xR, pbFibHi, color = #fbbf24, width = 1)
        pbLnFibLeg := line.new(x0, pbFibLo, x1, pbFibHi, color = #f59e0b, width = 1, style = line.style_dashed)
        pbLnFib0Tick := line.new(x0, pbFibLo - tick, x0, pbFibLo + tick, color = #f59e0b, width = 2)
        pbLnFib1Tick := line.new(x1, pbFibHi - tick, x1, pbFibHi + tick, color = #fbbf24, width = 2)
        pbLbl0 := label.new(x0, pbFibLo, "0", style = label.style_label_up, color = #b45309, textcolor = color.white, size = size.tiny)
        pbLbl1 := label.new(x1, pbFibHi, "1", style = label.style_label_down, color = #b45309, textcolor = color.white, size = size.tiny)
        pbLbl := label.new(xR, midY, "fib", style = label.style_label_left, color = #78350f, textcolor = #fde68a, size = size.tiny)
    else
        line.set_xy1(pbLnFib0, xL, pbFibLo)
        line.set_xy2(pbLnFib0, xR, pbFibLo)
        line.set_xy1(pbLnFib1, xL, pbFibHi)
        line.set_xy2(pbLnFib1, xR, pbFibHi)
        line.set_xy1(pbLnFibLeg, x0, pbFibLo)
        line.set_xy2(pbLnFibLeg, x1, pbFibHi)
        line.set_xy1(pbLnFib0Tick, x0, pbFibLo - tick)
        line.set_xy2(pbLnFib0Tick, x0, pbFibLo + tick)
        line.set_xy1(pbLnFib1Tick, x1, pbFibHi - tick)
        line.set_xy2(pbLnFib1Tick, x1, pbFibHi + tick)
        label.set_xy(pbLbl0, x0, pbFibLo)
        label.set_xy(pbLbl1, x1, pbFibHi)
        label.set_xy(pbLbl, xR, midY)

// ─── Dual trade plans — slim labels; STOP/TP pts only on line icons; freeze at end ─
bool isShadow = not dayAllowed
int maxLiveMs = 45 * 60 * 1000

if i_showPend and eArmed and not na(eEntry) and not na(eStop) and not na(eTp) and not na(eTime)
    bool eDone = eFill == 3 or eFill == 4 or eFill == 5
    if eDone and na(eEndTime)
        eEndTime := time
    int eLiveCap = eTime + maxLiveMs
    int eXR = eDone and not na(eEndTime) ? math.max(eEndTime, eTime + 60 * 1000) : math.min(time, eLiveCap)
    color eECol = isShadow ? #fb923c : #fbbf24
    color eSCol = isShadow ? #fb923c : c_stop
    color eTCol = isShadow ? #94a3b8 : c_tp
    float eRisk = math.abs(eEntry - eStop)
    float eRew = math.abs(eTp - eEntry)
    float eRR = eRisk > 0 ? eRew / eRisk : 0.0
    // Main tag: side · sleeve · 1:R · outcome (STOP/TP pts stay on line icons)
    string eTxt = (eDir == 1 ? "LONG" : "SHORT") + " · " + eTag + " · 1:" + str.tostring(eRR, "#.#") + (isShadow ? " · SHADOW" : "") + (i_showFillKpi ? "\n" + eKpi : "")
    if na(ePlanLeft) or ePlanLeft != eTime
        ePlanLeft := eTime
        if not na(eLnE)
            line.delete(eLnE)
            line.delete(eLnS)
            line.delete(eLnT)
            label.delete(eLbE)
            label.delete(eLbS)
            label.delete(eLbT)
            box.delete(eBxRisk)
            box.delete(eBxRew)
        eLnE := line.new(eTime, eEntry, eXR, eEntry, xloc = xloc.bar_time, color = eECol, width = 2)
        eLnS := line.new(eTime, eStop, eXR, eStop, xloc = xloc.bar_time, color = eSCol, width = 2)
        eLnT := line.new(eTime, eTp, eXR, eTp, xloc = xloc.bar_time, color = eTCol, width = 2)
        eLbE := label.new(eXR, eEntry, eTxt, xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = eECol, size = size.normal)
        eLbS := label.new(eXR, eStop, "−" + str.tostring(eRisk, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = eSCol, size = size.small)
        eLbT := label.new(eXR, eTp, "+" + str.tostring(eRew, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = eTCol, size = size.small)
        eBxRisk := box.new(eTime, math.max(eEntry, eStop), eXR, math.min(eEntry, eStop), xloc = xloc.bar_time, border_color = color.new(eSCol, 70), bgcolor = color.new(eSCol, 92), border_width = 1)
        eBxRew := box.new(eTime, math.max(eEntry, eTp), eXR, math.min(eEntry, eTp), xloc = xloc.bar_time, border_color = color.new(eTCol, 70), bgcolor = color.new(eTCol, 94), border_width = 1)
    else if not eDone
        line.set_xy2(eLnE, eXR, eEntry)
        line.set_xy2(eLnS, eXR, eStop)
        line.set_xy2(eLnT, eXR, eTp)
        label.set_xy(eLbE, eXR, eEntry)
        label.set_xy(eLbS, eXR, eStop)
        label.set_xy(eLbT, eXR, eTp)
        label.set_text(eLbE, eTxt)
        box.set_right(eBxRisk, eXR)
        box.set_right(eBxRew, eXR)
    else
        // Frozen — only refresh text/color, never extend right edge
        label.set_text(eLbE, eTxt)
        if not na(eEndTime)
            line.set_xy2(eLnE, eXR, eEntry)
            line.set_xy2(eLnS, eXR, eStop)
            line.set_xy2(eLnT, eXR, eTp)
            label.set_xy(eLbE, eXR, eEntry)
            label.set_xy(eLbS, eXR, eStop)
            label.set_xy(eLbT, eXR, eTp)
            box.set_right(eBxRisk, eXR)
            box.set_right(eBxRew, eXR)
    if i_showSig and not na(eWs) and not na(eEx)
        int eRbR = eDone and not na(eEndTime) ? math.max(eEndTime, eTime + 60 * 1000) : math.min(time, eTime + 15 * 60 * 1000)
        if na(eBxRb)
            eBxRb := box.new(eTime, math.max(eEx, eWs), eRbR, math.min(eEx, eWs), xloc = xloc.bar_time, border_color = #f59e0b, bgcolor = color.new(#f59e0b, 94), border_width = 1)
            if not na(eCe)
                eLnCe := line.new(eTime, eCe, eRbR, eCe, xloc = xloc.bar_time, color = c_ce, width = 1, style = line.style_dotted)
        else if not eDone
            box.set_right(eBxRb, eRbR)
            if not na(eLnCe)
                line.set_xy2(eLnCe, eRbR, eCe)

if i_showPend and oArmed and not na(oEntry) and not na(oStop) and not na(oTp) and not na(oTime)
    bool oDone = oFill == 3 or oFill == 4 or oFill == 5
    if oDone and na(oEndTime)
        oEndTime := time
    int oLiveCap = oTime + maxLiveMs
    int oXR = oDone and not na(oEndTime) ? math.max(oEndTime, oTime + 60 * 1000) : math.min(time, oLiveCap)
    color oECol = isShadow ? #fb923c : c_limit
    color oSCol = isShadow ? #fb923c : c_stop
    color oTCol = isShadow ? #94a3b8 : c_tp
    float oRisk = math.abs(oEntry - oStop)
    float oRew = math.abs(oTp - oEntry)
    float oRR = oRisk > 0 ? oRew / oRisk : 0.0
    string oTxt = (oDir == 1 ? "LONG" : "SHORT") + " · " + oTag + " · 1:" + str.tostring(oRR, "#.#") + (isShadow ? " · SHADOW" : "") + (i_showFillKpi ? "\n" + oKpi : "")
    if na(oPlanLeft) or oPlanLeft != oTime
        oPlanLeft := oTime
        if not na(oLnE)
            line.delete(oLnE)
            line.delete(oLnS)
            line.delete(oLnT)
            label.delete(oLbE)
            label.delete(oLbS)
            label.delete(oLbT)
            box.delete(oBxRisk)
            box.delete(oBxRew)
        oLnE := line.new(oTime, oEntry, oXR, oEntry, xloc = xloc.bar_time, color = oECol, width = 2)
        oLnS := line.new(oTime, oStop, oXR, oStop, xloc = xloc.bar_time, color = oSCol, width = 2)
        oLnT := line.new(oTime, oTp, oXR, oTp, xloc = xloc.bar_time, color = oTCol, width = 2)
        oLbE := label.new(oXR, oEntry, oTxt, xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = oECol, size = size.normal)
        oLbS := label.new(oXR, oStop, "−" + str.tostring(oRisk, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = oSCol, size = size.small)
        oLbT := label.new(oXR, oTp, "+" + str.tostring(oRew, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = oTCol, size = size.small)
        oBxRisk := box.new(oTime, math.max(oEntry, oStop), oXR, math.min(oEntry, oStop), xloc = xloc.bar_time, border_color = color.new(oSCol, 70), bgcolor = color.new(oSCol, 92), border_width = 1)
        oBxRew := box.new(oTime, math.max(oEntry, oTp), oXR, math.min(oEntry, oTp), xloc = xloc.bar_time, border_color = color.new(oTCol, 70), bgcolor = color.new(oTCol, 94), border_width = 1)
    else if not oDone
        line.set_xy2(oLnE, oXR, oEntry)
        line.set_xy2(oLnS, oXR, oStop)
        line.set_xy2(oLnT, oXR, oTp)
        label.set_xy(oLbE, oXR, oEntry)
        label.set_xy(oLbS, oXR, oStop)
        label.set_xy(oLbT, oXR, oTp)
        label.set_text(oLbE, oTxt)
        box.set_right(oBxRisk, oXR)
        box.set_right(oBxRew, oXR)
    else
        label.set_text(oLbE, oTxt)
        if not na(oEndTime)
            line.set_xy2(oLnE, oXR, oEntry)
            line.set_xy2(oLnS, oXR, oStop)
            line.set_xy2(oLnT, oXR, oTp)
            label.set_xy(oLbE, oXR, oEntry)
            label.set_xy(oLbS, oXR, oStop)
            label.set_xy(oLbT, oXR, oTp)
            box.set_right(oBxRisk, oXR)
            box.set_right(oBxRew, oXR)
    if i_showSig and not na(oWs) and not na(oEx)
        int oRbR = oDone and not na(oEndTime) ? math.max(oEndTime, oTime + 60 * 1000) : math.min(time, oTime + 15 * 60 * 1000)
        if na(oBxRb)
            oBxRb := box.new(oTime, math.max(oEx, oWs), oRbR, math.min(oEx, oWs), xloc = xloc.bar_time, border_color = c_bull, bgcolor = color.new(c_bull, 94), border_width = 1)
            if not na(oCe)
                oLnCe := line.new(oTime, oCe, oRbR, oCe, xloc = xloc.bar_time, color = c_ce, width = 1, style = line.style_dotted)
        else if not oDone
            box.set_right(oBxRb, oRbR)
            if not na(oLnCe)
                line.set_xy2(oLnCe, oRbR, oCe)

// ─── PDH / PDL ───────────────────────────────────────────────────────────────
float usePdh = not na(pdhLvl) ? pdhLvl : prevDayHigh
float usePdl = not na(pdlLvl) ? pdlLvl : prevDayLow
if i_showPdhPdl and newSessDay
    if not na(lnPdh)
        line.delete(lnPdh)
        label.delete(lblPdh)
    if not na(lnPdl)
        line.delete(lnPdl)
        label.delete(lblPdl)
    lnPdh := na
    lnPdl := na
    lblPdh := na
    lblPdl := na
    if not na(pdhOriginBar) and not na(usePdh)
        lnPdh := line.new(pdhOriginBar, usePdh, bar_index, usePdh, color = c_pdh, width = 2)
        lblPdh := label.new(bar_index, usePdh, "PDH", style = label.style_label_left, color = c_pdh, textcolor = color.white, size = size.small)
    if not na(pdlOriginBar) and not na(usePdl)
        lnPdl := line.new(pdlOriginBar, usePdl, bar_index, usePdl, color = c_pdl, width = 2)
        lblPdl := label.new(bar_index, usePdl, "PDL", style = label.style_label_left, color = c_pdl, textcolor = color.white, size = size.small)
if i_showPdhPdl and nyHhmm < i_flatTime
    if not na(lnPdh)
        line.set_x2(lnPdh, bar_index)
        label.set_xy(lblPdh, bar_index, usePdh)
    if not na(lnPdl)
        line.set_x2(lnPdl, bar_index)
        label.set_xy(lblPdl, bar_index, usePdl)

// ─── NWOG (current week only) ────────────────────────────────────────────────
f_nwogClearAll() =>
    while array.size(nwogBoxA) > 0
        box.delete(array.shift(nwogBoxA))
        line.delete(array.shift(nwogCeA))
        label.delete(array.shift(nwogLblA))
        array.shift(nwogTopA)
        array.shift(nwogBotA)
        array.shift(nwogHitHiA)
        array.shift(nwogHitLoA)
        array.shift(nwogFilledA)

f_nwogPush(float top, float bot, string tag) =>
    f_nwogClearAll()
    float hi = math.max(top, bot)
    float lo = math.min(top, bot)
    float ce = (hi + lo) * 0.5
    array.push(nwogBoxA, box.new(bar_index, hi, bar_index + 4, lo, border_color = #a78bfa, bgcolor = color.new(#a78bfa, 88), border_width = 2))
    array.push(nwogCeA, line.new(bar_index, ce, bar_index + 4, ce, color = #c4b5fd, width = 1, style = line.style_dotted))
    array.push(nwogLblA, label.new(bar_index + 1, hi, tag, style = label.style_label_left, color = #5b21b6, textcolor = color.white, size = size.small))
    array.push(nwogTopA, hi)
    array.push(nwogBotA, lo)
    array.push(nwogHitHiA, false)
    array.push(nwogHitLoA, false)
    array.push(nwogFilledA, false)

if i_showNwog and nwogSunOpenBar and barstate.isconfirmed
    nwogGapTime := na
    f_nwogClearAll()
bool nwogGapOk = i_showNwog and barstate.isconfirmed and not na(nwogFriClose) and math.abs(open - nwogFriClose) >= i_nwogMinPts
if nwogGapOk and nwogSunOpenBar
    nwogGapTime := time
    f_nwogPush(open, nwogFriClose, "NWOG · CE · Sun 18:00")
else if nwogGapOk and nwogMonFallback and na(nwogGapTime)
    nwogGapTime := time
    f_nwogPush(open, nwogFriClose, "NWOG · CE · Mon open")

if i_showNwog and array.size(nwogBoxA) > 0
    for i = 0 to array.size(nwogBoxA) - 1
        float hi = array.get(nwogTopA, i)
        float lo = array.get(nwogBotA, i)
        bool hitHi = array.get(nwogHitHiA, i) or high >= hi
        bool hitLo = array.get(nwogHitLoA, i) or low <= lo
        array.set(nwogHitHiA, i, hitHi)
        array.set(nwogHitLoA, i, hitLo)
        bool filled = hitHi and hitLo
        array.set(nwogFilledA, i, filled)
        box bx = array.get(nwogBoxA, i)
        line ln = array.get(nwogCeA, i)
        label lb = array.get(nwogLblA, i)
        float ce = (hi + lo) * 0.5
        box.set_right(bx, bar_index + 2)
        line.set_x2(ln, bar_index + 2)
        line.set_y1(ln, ce)
        line.set_y2(ln, ce)
        label.set_xy(lb, bar_index + 1, hi)
        if filled
            box.set_border_color(bx, #64748b)
            box.set_bgcolor(bx, color.new(#64748b, 92))
            label.set_text(lb, "NWOG filled")
            label.set_color(lb, #475569)
        else
            label.set_color(lb, #5b21b6)

// Yellow 10:00 wash only (no magenta KO plot)
bgcolor(nyHhmm == 1000 ? color.new(c_win10, 88) : na, title = "10:00")

plot(pbFibPlotLo, "FIB LO (0)", color.new(#f59e0b, 0), linewidth = 1, style = plot.style_linebr)
plot(pbFibPlotHi, "FIB HI (1)", color.new(#fbbf24, 0), linewidth = 1, style = plot.style_linebr)
// Day IL as plot (survives max_lines purge — was why the level vanished)
plot(i_showDil and not na(dilPx) ? dilPx : na, "Day IL", color.new(#c084fc, 0), linewidth = 2, style = plot.style_linebr)

// Day IL price tag on last bar only (recreate — avoid stale line/label ids)
if barstate.islast
    if not na(dilLbl)
        label.delete(dilLbl)
        dilLbl := na
    if i_showDil and not na(dilPx)
        dilLbl := label.new(bar_index + 2, dilPx, dilTag + "  " + str.tostring(dilPx, "#.#"), xloc = xloc.bar_index, style = label.style_label_left, color = #6b21a8, textcolor = color.white, size = size.normal)

// Permanent version stamp — if you don't see Dual15, the new paste is not on the chart
var label verStamp = na
if barstate.islast
    if na(verStamp)
        verStamp := label.new(bar_index, high, "MS Dual15 · print-bar snapshot", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left, color = color.new(#0f172a, 10), textcolor = #fde68a, size = size.small)
    else
        label.set_xy(verStamp, bar_index, high)
        label.set_text(verStamp, "MS Dual15 · print-bar snapshot")

alertcondition(manualReady and dayAllowed, title = "Morningstar ARMED", message = "Morningstar ARMED — {{ticker}} {{interval}}\nleave and/or Powell plan on chart")
