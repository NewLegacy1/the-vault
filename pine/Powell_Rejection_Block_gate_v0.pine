    pbLbl1 := na
    pbStateLbl := na
    while array.size(pbMark5BoxA) > 0
        box.delete(array.shift(pbMark5BoxA))
        label.delete(array.shift(pbMark5LblA))

// ─── Daily ITL (ICT: confirmed daily STL with higher STLs on both sides) ─────
if newDStl and not na(dStlPx)
    array.push(dStlPxA, dStlPx)
    array.push(dStlTA, dStlT)
    while array.size(dStlPxA) > 8
        array.shift(dStlPxA)
        array.shift(dStlTA)
    int nStl = array.size(dStlPxA)
    if nStl >= 3
        float a = array.get(dStlPxA, nStl - 3)
        float b = array.get(dStlPxA, nStl - 2)
        float c = array.get(dStlPxA, nStl - 1)
        if b < a and b < c
            dilPx := b
            dilTime := array.get(dStlTA, nStl - 2)

// ─── Path B (chart-state restore — Dual7) ────────────────────────────────────
// Leave: soft 5m RB@KO in leave window. Retest: 1m RB@KO after away→return
// (Powell control) with fib-OTE and/or Daily ITL confluence.
bool pbOn = i_pathB and not na(ko1000) and nyHhmm >= 1000 and (nyHhmm < i_winEnd or pbLeft or eArmed or oArmed)
float pbOteLo = na
float pbOteHi = na
bool koInBand = false
bool nearDil = false
bool fibLegOk = false
bool hasAway = false
bool inLeaveWin = false
bool pbStopFail = false
int leaveDir = 0
float leaveWs = na
float leaveCe = na
float leaveEx = na
string leaveTf = "5RB"
int retestDir = 0
float retestWs = na
float retestCe = na
float retestEx = na
string retestTf = "1RB"

if pbOn
    if na(pbHi) or high >= pbHi
        pbHi := high
        pbHiBar := bar_index
    if na(pbLo) or low <= pbLo
        pbLo := low
        pbLoBar := bar_index
    if high > ko1000
        pbPierceAbove := true
        pbManip := true
    if low < ko1000
        pbPierceBelow := true
        pbManip := true
    if pbManip and not pbLeft and barstate.isconfirmed and canPlace
        if pbPierceAbove and close < ko1000
            pbLeft := true
            pbDir := -1
            pbLeaveBar := bar_index
            pbLeaveTime := time
            pbAway := 0.0
            pbAwayPeakBar := na
            pbAwayPeakTime := na
            pbReturned := false
            pbFibHi := pbHi
            pbFibLo := pbLo
            pbFibLoBar := pbLoBar
            pbFibHiBar := pbHiBar
            pbFibLoTime := time
            pbFibHiTime := time
        else if pbPierceBelow and close > ko1000
            pbLeft := true
            pbDir := 1
            pbLeaveBar := bar_index
            pbLeaveTime := time
            pbAway := 0.0
            pbAwayPeakBar := na
            pbAwayPeakTime := na
            pbReturned := false
            pbFibHi := pbHi
            pbFibLo := pbLo
            pbFibLoBar := pbLoBar
            pbFibHiBar := pbHiBar
            pbFibLoTime := time
            pbFibHiTime := time
    if pbLeft
        if pbDir == 1 and high >= pbFibHi
            pbFibHi := high
            pbFibHiBar := bar_index
            pbFibHiTime := time
        if pbDir == -1 and low <= pbFibLo
            pbFibLo := low
            pbFibLoBar := bar_index
            pbFibLoTime := time
        if not na(pbLeaveBar) and bar_index > pbLeaveBar
            float awayNow = pbDir == 1 ? high - ko1000 : pbDir == -1 ? ko1000 - low : 0.0
            if awayNow > pbAway
                pbAway := awayNow
                pbAwayPeakBar := bar_index
                pbAwayPeakTime := time
            float retPad = i_pathBAlign
            if pbAway >= i_pathBAwayPts and not na(pbAwayPeakTime) and time > pbAwayPeakTime
                if pbDir == 1 and low <= ko1000 + retPad
                    pbReturned := true
                if pbDir == -1 and high >= ko1000 - retPad
                    pbReturned := true

    float pbRange = not na(pbFibHi) and not na(pbFibLo) ? pbFibHi - pbFibLo : na
    fibLegOk := not na(pbRange) and pbRange >= i_pathBMinFib
    hasAway := pbAway >= i_pathBAwayPts
    inLeaveWin := not na(pbLeaveTime) and (time - pbLeaveTime) <= i_leaveWinMin * 60 * 1000
    if pbLeft and not na(pbRange) and pbRange > 0
        if pbDir == -1
            pbOteLo := pbFibLo + pbRange * 0.62
            pbOteHi := pbFibLo + pbRange * 0.79
        else
            pbOteLo := pbFibHi - pbRange * 0.79
            pbOteHi := pbFibHi - pbRange * 0.62
        koInBand := not na(pbOteLo) and ko1000 >= pbOteLo - i_pathBAlign and ko1000 <= pbOteHi + i_pathBAlign
    nearDil := not na(dilPx) and math.abs(ko1000 - dilPx) <= i_dilAlign

    bool nearKo5B = f_nearKo(h5, ko1000) or f_nearKo(wsB5, ko1000) or f_nearKoBand(h5, wsB5, ko1000)
    bool nearKo5U = f_nearKo(l5, ko1000) or f_nearKo(wsU5, ko1000) or f_nearKoBand(wsU5, l5, ko1000)
    bool nearKo1B = f_nearKo(h1, ko1000) or f_nearKo(wsB1, ko1000) or f_nearKoBand(h1, wsB1, ko1000)
    bool nearKo1U = f_nearKo(l1, ko1000) or f_nearKo(wsU1, ko1000) or f_nearKoBand(wsU1, l1, ko1000)

    // Soft RB latches @ KO
    if pbLeft and barstate.isconfirmed
        if pbDir == 1
            if i_leavePrefer5 and trig5 and u5 and nearKo5U
                leaveDir := 1
                leaveWs := wsU5
                leaveEx := l5
                leaveCe := (l5 + wsU5) * 0.5
                leaveTf := "5RB"
            else if trig1 and u1 and nearKo1U
                leaveDir := 1
                leaveWs := wsU1
                leaveEx := l1
                leaveCe := (l1 + wsU1) * 0.5
                leaveTf := "1RB"
            if i_retestPrefer1 and trig1 and u1 and nearKo1U
                retestDir := 1
                retestWs := wsU1
                retestEx := l1
                retestCe := (l1 + wsU1) * 0.5
                retestTf := "1RB"
            else if not i_retestPrefer1 and trig5 and u5 and nearKo5U
                retestDir := 1
                retestWs := wsU5
                retestEx := l5
                retestCe := (l5 + wsU5) * 0.5
                retestTf := "5RB"
        if pbDir == -1
            if i_leavePrefer5 and trig5 and b5 and nearKo5B
                leaveDir := -1
                leaveWs := wsB5
                leaveEx := h5
                leaveCe := (h5 + wsB5) * 0.5
                leaveTf := "5RB"
            else if trig1 and b1 and nearKo1B
                leaveDir := -1
                leaveWs := wsB1
                leaveEx := h1
                leaveCe := (h1 + wsB1) * 0.5
                leaveTf := "1RB"
            if i_retestPrefer1 and trig1 and b1 and nearKo1B
                retestDir := -1
                retestWs := wsB1
                retestEx := h1
                retestCe := (h1 + wsB1) * 0.5
                retestTf := "1RB"
            else if not i_retestPrefer1 and trig5 and b5 and nearKo5B
                retestDir := -1
                retestWs := wsB5
                retestEx := h5
                retestCe := (h5 + wsB5) * 0.5
                retestTf := "5RB"

    // MARK formal 5m (local extreme) — eyes only
    if i_pathBMark5 and pbLeft and trig5
        bool mark5Bear = pbDir == -1 and b5form and (f_nearKo(h5f, ko1000) or f_nearKo(wsB5f, ko1000) or f_nearKoBand(h5f, wsB5f, ko1000))
        bool mark5Bull = pbDir == 1 and u5form and (f_nearKo(l5f, ko1000) or f_nearKo(wsU5f, ko1000) or f_nearKoBand(wsU5f, l5f, ko1000))
        if mark5Bear or mark5Bull
            float mTop = mark5Bear ? h5f : wsU5f
            float mBot = mark5Bear ? wsB5f : l5f
            if not na(mTop) and not na(mBot) and not na(t5sec)
                color mCol = mark5Bear ? c_bear : c_bull
                int mRight = t5sec + 30 * 60 * 1000
                array.push(pbMark5BoxA, box.new(t5sec, math.max(mTop, mBot), mRight, math.min(mTop, mBot), xloc = xloc.bar_time, border_color = mCol, bgcolor = color.new(mCol, 92), border_width = 2))
                array.push(pbMark5LblA, label.new(t5sec, math.max(mTop, mBot), "5RB formal · eyes", xloc = xloc.bar_time, style = label.style_label_down, color = #334155, textcolor = color.white, size = size.tiny))
                while array.size(pbMark5BoxA) > 4
                    box.delete(array.shift(pbMark5BoxA))
                    label.delete(array.shift(pbMark5LblA))

    bool leaveBiasOk = (leaveDir == -1 and biasOkShort) or (leaveDir == 1 and biasOkLong)
    bool retestBiasOk = (retestDir == -1 and biasOkShort) or (retestDir == 1 and biasOkLong)
    bool singleSlotLock = i_oneTradeDay and i_pathBSleeve != "KO-leave + KO-retest" and (eArmed or oArmed)
    bool leaveTick = leaveTf == "5RB" ? trig5 : trig1
    bool retestTick = retestTf == "1RB" ? trig1 : trig5
    bool retestConfl = (not i_pathBReqOte or koInBand) or (i_retestNearDil and nearDil)
    bool rbNearDil = not na(dilPx) and not na(retestEx) and math.abs(retestEx - dilPx) <= i_dilAlign

    // KO-leave — soft RB@KO soon after leave (takeable; not "skip")
    if wantLeave and not eArmed and canPlace and not singleSlotLock and leaveBiasOk and leaveDir != 0 and leaveTick and inLeaveWin and not pbReturned
        [entryPx, stopPx] = f_plan(leaveWs, leaveCe, leaveEx, leaveDir == -1)
        if na(entryPx)
            pbStopFail := true
        else
            float riskPts0 = math.abs(stopPx - entryPx)
            eArmed := true
            eDir := leaveDir
            eBar := bar_index
            eTime := time
            eWs := leaveWs
            eCe := leaveCe
            eEx := leaveEx
            eEntry := entryPx
            eStop := stopPx
            eTp := leaveDir == 1 ? entryPx + i_rr * riskPts0 : entryPx - i_rr * riskPts0
            eTag := "KO-leave · PathB · " + leaveTf
            eFill := 1
            eEndBar := na
            eEndTime := na
            eKpi := "LIMIT live — waiting tap"
            suDir := eDir
            suBar := eBar
            suEntry := eEntry
            suStop := eStop
            pendStop := eStop
            pendTp := eTp
            suWickStart := eWs
            suCe := eCe
            suExtreme := eEx
            suPathB := true
            suLeft := true
            suSweepTag := eTag
            manualReady := true
            manualState := f_shadowArmLabel()

    // KO-retest — away→return→RB@KO; fib OTE and/or Daily ITL (Powell; any clock)
    bool retestReady = hasAway and pbReturned and not inLeaveWin and fibLegOk and retestConfl and not na(pbAwayPeakBar) and bar_index > pbAwayPeakBar
    if wantRetest and not oArmed and canPlace and not singleSlotLock and retestBiasOk and retestDir != 0 and retestTick and retestReady
        [entryPx2, stopPx2] = f_plan(retestWs, retestCe, retestEx, retestDir == -1)
        float riskPts1 = na(entryPx2) ? na : math.abs(stopPx2 - entryPx2)
        bool retestSizeOk = not na(riskPts1) and riskPts1 >= i_retestMinRisk
        string dilTag = rbNearDil or nearDil ? " · DIL" : ""
        if na(entryPx2) or not retestSizeOk
            pbStopFail := true
        else
            oArmed := true
            oDir := retestDir
            oBar := bar_index
            oTime := time
            oEndBar := na
            oEndTime := na
            oWs := retestWs
            oCe := retestCe
            oEx := retestEx
            oEntry := entryPx2
            oStop := stopPx2
            oTp := retestDir == 1 ? entryPx2 + i_rr * riskPts1 : entryPx2 - i_rr * riskPts1
            oTag := "KO-retest · PathB · " + retestTf + dilTag
            oFill := 1
            oKpi := "LIMIT live — waiting tap"
            suDir := oDir
            suBar := oBar
            suEntry := oEntry
            suStop := oStop
            pendStop := oStop
            pendTp := oTp
            suWickStart := oWs
            suCe := oCe
            suExtreme := oEx
            suPathB := true
            suLeft := true
            suSweepTag := oTag
            manualReady := true
            manualState := f_shadowArmLabel()

// Status
if not i_pathB
    pbState := "Path B off"
else if nyHhmm < 1000 or na(ko1000)
    pbState := "B before 10:00"
else if not pbManip
    pbState := "B wait manip"
else if not pbLeft
    pbState := canPlace ? "B wait leave" : "B no leave (arm window ended)"
else
    string ePart = eArmed ? "KO-leave✓" : wantLeave ? (pbReturned or not inLeaveWin ? "KO-leave missed" : "KO-leave wait soft RB") : ""
    string oGate = i_pathBReqOte and not koInBand and not (i_retestNearDil and nearDil) ? "retest wait OTE/DIL" : not fibLegOk ? "retest wait fib" : "retest wait RB@KO"
    string oPart = oArmed ? "KO-retest✓" : wantRetest ? (inLeaveWin ? "retest wait leave-win" : not hasAway ? "retest wait away" : not pbReturned ? "retest wait return" : oGate) : ""
    if eArmed or oArmed
        pbState := ePart + (eArmed and wantRetest ? " · " : "") + oPart
        if eArmed
            pbState := pbState + " · " + eKpi
        if oArmed
            pbState := pbState + (eArmed ? " | " : " · ") + oKpi
    else if pbStopFail
        pbState := "B stop size fail"
    else
        pbState := ePart + (str.length(ePart) > 0 and str.length(oPart) > 0 ? " · " : "") + oPart
        if not na(dilPx)
            pbState := pbState + " · DIL " + str.tostring(dilPx, "#.#")

if i_pathBShowState
    if na(pbStateLbl)
        pbStateLbl := label.new(bar_index, high, pbState, style = label.style_label_down, color = color.new(#0f172a, 20), textcolor = color.white, size = size.small)
    else
        label.set_xy(pbStateLbl, bar_index, high)
        label.set_text(pbStateLbl, pbState)

// Fill KPI helper (per sleeve) — armTime so 1m/5m charts share the same fill clock
f_updFill(int st, int armTime, int dir, float entry, float stop, float tp) =>
    int out = st
    if st < 3
        if st == 1 and not na(armTime) and time > armTime and (dir == 1 ? low <= entry : high >= entry)
            out := 2
        if out == 2
            bool hitStop = dir == 1 ? low <= stop : high >= stop
            bool hitTp = dir == 1 ? high >= tp : low <= tp
            if hitStop
                out := 4
            else if hitTp
                out := 3
        if out == 1 and nyHhmm >= i_flatTime
            out := 5
    string kpi = out == 1 ? "LIMIT live — waiting tap" : out == 2 ? (nyHhmm >= i_flatTime ? "FILLED · open at flat" : "FILLED · in trade") : out == 3 ? "WIN · TP" : out == 4 ? "LOSS · STOP" : out == 5 ? "NO FILL by flat" : "—"
    [out, kpi]

// Always simulate fills so plan boxes freeze at TP/STOP (never chase the live edge)
if eArmed and barstate.isconfirmed
    int ePrev = eFill
    [eFillTmp, eKpiTmp] = f_updFill(eFill, eTime, eDir, eEntry, eStop, eTp)
    eFill := eFillTmp
    eKpi := eKpiTmp
    if eFill >= 3 and na(eEndTime)
        eEndBar := bar_index
        eEndTime := time
    else if ePrev < 3 and (eFill == 3 or eFill == 4 or eFill == 5)
        eEndBar := bar_index
        eEndTime := time
if oArmed and barstate.isconfirmed
    int oPrev = oFill
    [oFillTmp, oKpiTmp] = f_updFill(oFill, oTime, oDir, oEntry, oStop, oTp)
    oFill := oFillTmp
    oKpi := oKpiTmp
    if oFill >= 3 and na(oEndTime)
        oEndBar := bar_index
        oEndTime := time
    else if oPrev < 3 and (oFill == 3 or oFill == 4 or oFill == 5)
        oEndBar := bar_index
        oEndTime := time

if eArmed or oArmed
    manualReady := true
    manualState := f_shadowArmLabel()
    if nyHhmm >= i_flatTime
        manualState := "Flat — plan(s) still up"

// ─── Fib anchors only (LO + HI) — you place the fib tool ─────────────────────
bool pbFibReady = i_pathBShowFib and pbLeft and not na(pbFibHi) and not na(pbFibLo) and pbFibHi > pbFibLo
float pbFibPlotLo = pbFibReady ? pbFibLo : na
float pbFibPlotHi = pbFibReady ? pbFibHi : na
if pbFibReady
    float rng = pbFibHi - pbFibLo
    int x0 = na(pbFibLoBar) ? math.max(0, bar_index - 8) : pbFibLoBar
    int x1 = na(pbFibHiBar) ? bar_index : pbFibHiBar
    int xL = math.min(x0, x1)
    int xR = math.max(bar_index + 8, math.max(x0, x1) + 6)
    float tick = math.max(rng * 0.05, syminfo.mintick * 20)
    float midY = (pbFibHi + pbFibLo) * 0.5
    if na(pbLnFib0) or na(pbLbl0)
        if not na(pbLnFib0)
            line.delete(pbLnFib0)
        if not na(pbLnFib1)
            line.delete(pbLnFib1)
        if not na(pbLnFibLeg)
            line.delete(pbLnFibLeg)
        if not na(pbLnFib0Tick)
            line.delete(pbLnFib0Tick)
        if not na(pbLnFib1Tick)
            line.delete(pbLnFib1Tick)
        if not na(pbLn62)
            line.delete(pbLn62)
        if not na(pbLn705)
            line.delete(pbLn705)
        if not na(pbLn79)
            line.delete(pbLn79)
        if not na(pbLbl)
            label.delete(pbLbl)
        if not na(pbLbl0)
            label.delete(pbLbl0)
        if not na(pbLbl1)
            label.delete(pbLbl1)
        pbLn62 := na
        pbLn705 := na
        pbLn79 := na
        pbLnFib0 := line.new(xL, pbFibLo, xR, pbFibLo, color = #f59e0b, width = 4)
        pbLnFib1 := line.new(xL, pbFibHi, xR, pbFibHi, color = #fbbf24, width = 4)
        pbLnFibLeg := line.new(x0, pbFibLo, x1, pbFibHi, color = #f59e0b, width = 3, style = line.style_dashed)
        pbLnFib0Tick := line.new(x0, pbFibLo - tick, x0, pbFibLo + tick, color = #f59e0b, width = 5)
        pbLnFib1Tick := line.new(x1, pbFibHi - tick, x1, pbFibHi + tick, color = #fbbf24, width = 5)
        pbLbl0 := label.new(x0, pbFibLo, "FIB LO (0)", style = label.style_label_up, color = #b45309, textcolor = color.white, size = size.large)
        pbLbl1 := label.new(x1, pbFibHi, "FIB HI (1)", style = label.style_label_down, color = #b45309, textcolor = color.white, size = size.large)
        pbLbl := label.new(xR, midY, "Put fib tool LO → HI", style = label.style_label_left, color = #78350f, textcolor = #fde68a, size = size.normal)
    else
        line.set_xy1(pbLnFib0, xL, pbFibLo)
        line.set_xy2(pbLnFib0, xR, pbFibLo)
        line.set_xy1(pbLnFib1, xL, pbFibHi)
        line.set_xy2(pbLnFib1, xR, pbFibHi)
        line.set_xy1(pbLnFibLeg, x0, pbFibLo)
        line.set_xy2(pbLnFibLeg, x1, pbFibHi)
        line.set_xy1(pbLnFib0Tick, x0, pbFibLo - tick)
        line.set_xy2(pbLnFib0Tick, x0, pbFibLo + tick)
        line.set_xy1(pbLnFib1Tick, x1, pbFibHi - tick)
        line.set_xy2(pbLnFib1Tick, x1, pbFibHi + tick)
        label.set_xy(pbLbl0, x0, pbFibLo)
        label.set_xy(pbLbl1, x1, pbFibHi)
        label.set_xy(pbLbl, xR, midY)

// ─── Dual trade plans — bar_time xloc so 1m/5m charts share geometry; freeze at TP/STOP ─
bool isShadow = not dayAllowed

if i_showPend and eArmed and not na(eEntry) and not na(eStop) and not na(eTp) and not na(eTime)
    bool eDone = eFill == 3 or eFill == 4 or eFill == 5
    if eDone and na(eEndTime)
        eEndBar := bar_index
        eEndTime := time
    int eXR = eDone ? math.max(eEndTime, eTime + 60 * 1000) : time + 10 * 60 * 1000
    color eECol = isShadow ? #fb923c : #fbbf24
    color eSCol = isShadow ? #fb923c : c_stop
    color eTCol = isShadow ? #94a3b8 : c_tp
    float eRisk = math.abs(eEntry - eStop)
    float eRew = math.abs(eTp - eEntry)
    float eRR = eRisk > 0 ? eRew / eRisk : 0.0
    string eTxt = (eDir == 1 ? "LONG" : "SHORT") + " · " + eTag + (isShadow ? " · SHADOW" : "") + "\n1:" + str.tostring(eRR, "#.#") + "  ·  risk " + str.tostring(eRisk, "#.#") + " pt" + (i_showFillKpi ? "\n" + eKpi : "")
    if na(ePlanLeft) or ePlanLeft != eTime
        ePlanLeft := eTime
        if not na(eLnE)
            line.delete(eLnE)
            line.delete(eLnS)
            line.delete(eLnT)
            label.delete(eLbE)
            label.delete(eLbS)
            label.delete(eLbT)
            box.delete(eBxRisk)
            box.delete(eBxRew)
        eLnE := line.new(eTime, eEntry, eXR, eEntry, xloc = xloc.bar_time, color = eECol, width = 2)
        eLnS := line.new(eTime, eStop, eXR, eStop, xloc = xloc.bar_time, color = eSCol, width = 2)
        eLnT := line.new(eTime, eTp, eXR, eTp, xloc = xloc.bar_time, color = eTCol, width = 2)
        eLbE := label.new(eXR, eEntry, eTxt, xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = eECol, size = size.small)
        eLbS := label.new(eXR, eStop, "STOP  ·  −" + str.tostring(eRisk, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = eSCol, size = size.small)
        eLbT := label.new(eXR, eTp, "TP  ·  +" + str.tostring(eRew, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = eTCol, size = size.small)
        eBxRisk := box.new(eTime, math.max(eEntry, eStop), eXR, math.min(eEntry, eStop), xloc = xloc.bar_time, border_color = color.new(eSCol, 70), bgcolor = color.new(eSCol, 92), border_width = 1)
        eBxRew := box.new(eTime, math.max(eEntry, eTp), eXR, math.min(eEntry, eTp), xloc = xloc.bar_time, border_color = color.new(eTCol, 70), bgcolor = color.new(eTCol, 94), border_width = 1)
    else
        line.set_xy2(eLnE, eXR, eEntry)
        line.set_xy2(eLnS, eXR, eStop)
        line.set_xy2(eLnT, eXR, eTp)
        label.set_xy(eLbE, eXR, eEntry)
        label.set_xy(eLbS, eXR, eStop)
        label.set_xy(eLbT, eXR, eTp)
        label.set_text(eLbE, eTxt)
        box.set_right(eBxRisk, eXR)
        box.set_right(eBxRew, eXR)
    if i_showFillKpi
        color eFCol = eFill == 3 ? c_tp : eFill == 4 ? c_stop : eFill == 5 ? #94a3b8 : #fde68a
        if na(eFillLbl)
            eFillLbl := label.new(eTime, eEntry, eKpi, xloc = xloc.bar_time, style = label.style_label_right, color = #0f172a, textcolor = eFCol, size = size.small)
        else
            label.set_xy(eFillLbl, eTime, eEntry)
            label.set_text(eFillLbl, eKpi)
            label.set_textcolor(eFillLbl, eFCol)
    if i_showSig and not na(eWs) and not na(eEx)
        int eRbR = eDone ? math.max(eEndTime, eTime + 60 * 1000) : time + 20 * 60 * 1000
        if na(eBxRb)
            eBxRb := box.new(eTime, math.max(eEx, eWs), eRbR, math.min(eEx, eWs), xloc = xloc.bar_time, border_color = #f59e0b, bgcolor = color.new(#f59e0b, 92), border_width = 2)
            eLblRb := label.new(eTime, math.max(eEx, eWs), eTag, xloc = xloc.bar_time, style = label.style_label_down, color = #78350f, textcolor = #fde68a, size = size.tiny)
            if not na(eCe)
                eLnCe := line.new(eTime, eCe, eRbR, eCe, xloc = xloc.bar_time, color = c_ce, width = 1, style = line.style_dotted)
                eLbCe := label.new(eTime + 60 * 1000, eCe, "CE", xloc = xloc.bar_time, style = label.style_label_left, color = color.new(#0f172a, 30), textcolor = c_ce, size = size.tiny)
        else
            box.set_right(eBxRb, eRbR)
            if not na(eLnCe)
                line.set_xy2(eLnCe, eRbR, eCe)
            if not na(eLbCe)
                label.set_xy(eLbCe, eTime + 60 * 1000, eCe)

if i_showPend and oArmed and not na(oEntry) and not na(oStop) and not na(oTp) and not na(oTime)
    bool oDone = oFill == 3 or oFill == 4 or oFill == 5
    if oDone and na(oEndTime)
        oEndBar := bar_index
        oEndTime := time
    int oXR = oDone ? math.max(oEndTime, oTime + 60 * 1000) : time + 10 * 60 * 1000
    color oECol = isShadow ? #fb923c : c_limit
    color oSCol = isShadow ? #fb923c : c_stop
    color oTCol = isShadow ? #94a3b8 : c_tp
    float oRisk = math.abs(oEntry - oStop)
    float oRew = math.abs(oTp - oEntry)
    float oRR = oRisk > 0 ? oRew / oRisk : 0.0
    string oTxt = (oDir == 1 ? "LONG" : "SHORT") + " · " + oTag + (isShadow ? " · SHADOW" : "") + "\n1:" + str.tostring(oRR, "#.#") + "  ·  risk " + str.tostring(oRisk, "#.#") + " pt" + (i_showFillKpi ? "\n" + oKpi : "")
    if na(oPlanLeft) or oPlanLeft != oTime
        oPlanLeft := oTime
        if not na(oLnE)
            line.delete(oLnE)
            line.delete(oLnS)
            line.delete(oLnT)
            label.delete(oLbE)
            label.delete(oLbS)
            label.delete(oLbT)
            box.delete(oBxRisk)
            box.delete(oBxRew)
        oLnE := line.new(oTime, oEntry, oXR, oEntry, xloc = xloc.bar_time, color = oECol, width = 2)
        oLnS := line.new(oTime, oStop, oXR, oStop, xloc = xloc.bar_time, color = oSCol, width = 2)
        oLnT := line.new(oTime, oTp, oXR, oTp, xloc = xloc.bar_time, color = oTCol, width = 2)
        oLbE := label.new(oXR, oEntry, oTxt, xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = oECol, size = size.small)
        oLbS := label.new(oXR, oStop, "STOP  ·  −" + str.tostring(oRisk, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = oSCol, size = size.small)
        oLbT := label.new(oXR, oTp, "TP  ·  +" + str.tostring(oRew, "#.#") + " pt", xloc = xloc.bar_time, style = label.style_label_left, color = #0f172a, textcolor = oTCol, size = size.small)
        oBxRisk := box.new(oTime, math.max(oEntry, oStop), oXR, math.min(oEntry, oStop), xloc = xloc.bar_time, border_color = color.new(oSCol, 70), bgcolor = color.new(oSCol, 92), border_width = 1)
        oBxRew := box.new(oTime, math.max(oEntry, oTp), oXR, math.min(oEntry, oTp), xloc = xloc.bar_time, border_color = color.new(oTCol, 70), bgcolor = color.new(oTCol, 94), border_width = 1)
    else
        line.set_xy2(oLnE, oXR, oEntry)
        line.set_xy2(oLnS, oXR, oStop)
        line.set_xy2(oLnT, oXR, oTp)
        label.set_xy(oLbE, oXR, oEntry)
        label.set_xy(oLbS, oXR, oStop)
        label.set_xy(oLbT, oXR, oTp)
        label.set_text(oLbE, oTxt)
        box.set_right(oBxRisk, oXR)
        box.set_right(oBxRew, oXR)
    if i_showFillKpi
        color oFCol = oFill == 3 ? c_tp : oFill == 4 ? c_stop : oFill == 5 ? #94a3b8 : #fde68a
        if na(oFillLbl)
            oFillLbl := label.new(oTime, oEntry, oKpi, xloc = xloc.bar_time, style = label.style_label_right, color = #0f172a, textcolor = oFCol, size = size.small)
        else
            label.set_xy(oFillLbl, oTime, oEntry)
            label.set_text(oFillLbl, oKpi)
            label.set_textcolor(oFillLbl, oFCol)
    if i_showSig and not na(oWs) and not na(oEx)
        int oRbR = oDone ? math.max(oEndTime, oTime + 60 * 1000) : time + 20 * 60 * 1000
        if na(oBxRb)
            oBxRb := box.new(oTime, math.max(oEx, oWs), oRbR, math.min(oEx, oWs), xloc = xloc.bar_time, border_color = c_bull, bgcolor = color.new(c_bull, 92), border_width = 2)
            oLblRb := label.new(oTime, math.max(oEx, oWs), oTag, xloc = xloc.bar_time, style = label.style_label_down, color = #0f172a, textcolor = c_bull, size = size.tiny)
            if not na(oCe)
                oLnCe := line.new(oTime, oCe, oRbR, oCe, xloc = xloc.bar_time, color = c_ce, width = 1, style = line.style_dotted)
                oLbCe := label.new(oTime + 60 * 1000, oCe, "CE", xloc = xloc.bar_time, style = label.style_label_left, color = color.new(#0f172a, 30), textcolor = c_ce, size = size.tiny)
        else
            box.set_right(oBxRb, oRbR)
            if not na(oLnCe)
                line.set_xy2(oLnCe, oRbR, oCe)
            if not na(oLbCe)
                label.set_xy(oLbCe, oTime + 60 * 1000, oCe)

// ─── PDH / PDL ───────────────────────────────────────────────────────────────
float usePdh = not na(pdhLvl) ? pdhLvl : prevDayHigh
float usePdl = not na(pdlLvl) ? pdlLvl : prevDayLow
if i_showPdhPdl and newSessDay
    if not na(lnPdh)
        line.delete(lnPdh)
        label.delete(lblPdh)
    if not na(lnPdl)
        line.delete(lnPdl)
        label.delete(lblPdl)
    lnPdh := na
    lnPdl := na
    lblPdh := na
    lblPdl := na
    if not na(pdhOriginBar) and not na(usePdh)
        lnPdh := line.new(pdhOriginBar, usePdh, bar_index, usePdh, color = c_pdh, width = 2)
        lblPdh := label.new(bar_index, usePdh, "PDH", style = label.style_label_left, color = c_pdh, textcolor = color.white, size = size.small)
    if not na(pdlOriginBar) and not na(usePdl)
        lnPdl := line.new(pdlOriginBar, usePdl, bar_index, usePdl, color = c_pdl, width = 2)
        lblPdl := label.new(bar_index, usePdl, "PDL", style = label.style_label_left, color = c_pdl, textcolor = color.white, size = size.small)
if i_showPdhPdl and nyHhmm < i_flatTime
    if not na(lnPdh)
        line.set_x2(lnPdh, bar_index)
        label.set_xy(lblPdh, bar_index, usePdh)
    if not na(lnPdl)
        line.set_x2(lnPdl, bar_index)
        label.set_xy(lblPdl, bar_index, usePdl)

// ─── NWOG (current week only) ────────────────────────────────────────────────
f_nwogClearAll() =>
    while array.size(nwogBoxA) > 0
        box.delete(array.shift(nwogBoxA))
        line.delete(array.shift(nwogCeA))
        label.delete(array.shift(nwogLblA))
        array.shift(nwogTopA)
        array.shift(nwogBotA)
        array.shift(nwogHitHiA)
        array.shift(nwogHitLoA)
        array.shift(nwogFilledA)

f_nwogPush(float top, float bot, string tag) =>
    f_nwogClearAll()
    float hi = math.max(top, bot)
    float lo = math.min(top, bot)
    float ce = (hi + lo) * 0.5
    array.push(nwogBoxA, box.new(bar_index, hi, bar_index + 4, lo, border_color = #a78bfa, bgcolor = color.new(#a78bfa, 88), border_width = 2))
    array.push(nwogCeA, line.new(bar_index, ce, bar_index + 4, ce, color = #c4b5fd, width = 1, style = line.style_dotted))
    array.push(nwogLblA, label.new(bar_index + 1, hi, tag, style = label.style_label_left, color = #5b21b6, textcolor = color.white, size = size.small))
    array.push(nwogTopA, hi)
    array.push(nwogBotA, lo)
    array.push(nwogHitHiA, false)
    array.push(nwogHitLoA, false)
    array.push(nwogFilledA, false)

if i_showNwog and nwogSunOpenBar and barstate.isconfirmed
    nwogGapTime := na
    f_nwogClearAll()
bool nwogGapOk = i_showNwog and barstate.isconfirmed and not na(nwogFriClose) and math.abs(open - nwogFriClose) >= i_nwogMinPts
if nwogGapOk and nwogSunOpenBar
    nwogGapTime := time
    f_nwogPush(open, nwogFriClose, "NWOG · CE · Sun 18:00")
else if nwogGapOk and nwogMonFallback and na(nwogGapTime)
    nwogGapTime := time
    f_nwogPush(open, nwogFriClose, "NWOG · CE · Mon open")

if i_showNwog and array.size(nwogBoxA) > 0
    for i = 0 to array.size(nwogBoxA) - 1
        float hi = array.get(nwogTopA, i)
        float lo = array.get(nwogBotA, i)
        bool hitHi = array.get(nwogHitHiA, i) or high >= hi
        bool hitLo = array.get(nwogHitLoA, i) or low <= lo
        array.set(nwogHitHiA, i, hitHi)
        array.set(nwogHitLoA, i, hitLo)
        bool filled = hitHi and hitLo
        array.set(nwogFilledA, i, filled)
        box bx = array.get(nwogBoxA, i)
        line ln = array.get(nwogCeA, i)
        label lb = array.get(nwogLblA, i)
        float ce = (hi + lo) * 0.5
        box.set_right(bx, bar_index + 2)
        line.set_x2(ln, bar_index + 2)
        line.set_y1(ln, ce)
        line.set_y2(ln, ce)
        label.set_xy(lb, bar_index + 1, hi)
        if filled
            box.set_border_color(bx, #64748b)
            box.set_bgcolor(bx, color.new(#64748b, 92))
            label.set_text(lb, "NWOG filled")
            label.set_color(lb, #475569)
        else
            label.set_color(lb, #5b21b6)

// Yellow 10:00 wash only (no magenta KO plot)
bgcolor(nyHhmm == 1000 ? color.new(c_win10, 88) : na, title = "10:00")

plot(pbFibPlotLo, "FIB LO (0)", color.new(#f59e0b, 0), linewidth = 3, style = plot.style_linebr)
plot(pbFibPlotHi, "FIB HI (1)", color.new(#fbbf24, 0), linewidth = 3, style = plot.style_linebr)

plotshape(eArmed and not na(eTime) and time == eTime, title = "KO-leave ARM", style = shape.labelup, location = location.belowbar, color = #b45309, textcolor = color.white, text = "KO-leave", size = size.tiny)
plotshape(oArmed and not na(oTime) and time == oTime, title = "KO-retest ARM", style = shape.labelup, location = location.belowbar, color = #0f172a, textcolor = color.white, text = "KO-retest", size = size.tiny)

// Daily ITL line
if i_showDil and not na(dilPx)
    if na(dilLn)
        dilLn := line.new(bar_index - 20, dilPx, bar_index + 8, dilPx, color = #a78bfa, width = 2, style = line.style_dashed)
        dilLbl := label.new(bar_index + 8, dilPx, "Daily ITL", style = label.style_label_left, color = #5b21b6, textcolor = color.white, size = size.small)
    else
        line.set_xy1(dilLn, bar_index - 40, dilPx)
        line.set_xy2(dilLn, bar_index + 8, dilPx)
        label.set_xy(dilLbl, bar_index + 8, dilPx)
else if not na(dilLn)
    line.delete(dilLn)
    label.delete(dilLbl)
    dilLn := na
    dilLbl := na

// Permanent version stamp — if you don't see Dual7, the new paste is not on the chart
var label verStamp = na
if barstate.islast
    if na(verStamp)
        verStamp := label.new(bar_index, high, "MS Dual7 · soft leave + 1m retest + Daily ITL", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left, color = color.new(#0f172a, 10), textcolor = #fde68a, size = size.small)
    else
        label.set_xy(verStamp, bar_index, high)
        label.set_text(verStamp, "MS Dual7 · soft leave + 1m retest + Daily ITL")

alertcondition(manualReady and dayAllowed, title = "Morningstar ARMED", message = "Morningstar ARMED — {{ticker}} {{interval}}\nKO-leave and/or KO-retest plan on chart")
