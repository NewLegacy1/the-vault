    f_clearPlan(oLnE, oLnS, oLnT, oLnCe, oLbE, oLbS, oLbT, oBxRisk, oBxRew, oFillLbl, oBxRb, oLblRb)
    if not na(eLbCe)
        label.delete(eLbCe)
    if not na(oLbCe)
        label.delete(oLbCe)
    eLbCe := na
    oLbCe := na
    eLnE := na
    eLnS := na
    eLnT := na
    eLnCe := na
    eLbE := na
    eLbS := na
    eLbT := na
    eBxRisk := na
    eBxRew := na
    eFillLbl := na
    eBxRb := na
    eLblRb := na
    oLnE := na
    oLnS := na
    oLnT := na
    oLnCe := na
