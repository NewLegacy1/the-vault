//@version=6
// Track B · B11 BB Reclaim MEASURE — Deep BT only (Lane F).
// Spec: strategies/strategy-dev/60-track-b/track-b-b11-bb-reclaim-v0.md
// Save CSV: vault-app/data/tv-exports/matrix/trackb-bbreclaim-mnq-5m.csv
// NOT session-VWAP z-fade (B4 killed). Pierce BB → reclaim inside + ADX chop + 1.0R.

strategy(
     title                   = "TrackB BBReclaim measure v0",
     shorttitle              = "BBReclaim measure",
     overlay                 = true,
     pyramiding              = 0,
     process_orders_on_close = true,
     calc_on_every_tick      = false,
     max_bars_back           = 5000,
     initial_capital         = 50000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     commission_type         = strategy.commission.cash_per_contract,
     commission_value        = 0.62,
     slippage                = 1,
     margin_long             = 0,
     margin_short            = 0,
     max_labels_count        = 50)

grpEvt = "Event (locked — do not sweep)"
i_bbLen    = input.int(20, "BB length", minval = 10, group = grpEvt)
i_bbMult   = input.float(2.0, "BB mult", minval = 1.0, step = 0.1, group = grpEvt)
i_adxLen   = input.int(14, "ADX length", minval = 5, group = grpEvt)
i_adxMax   = input.float(25.0, "ADX max (chop)", minval = 10.0, step = 1.0, group = grpEvt)
i_armFrom  = input.int(1005, "Arm from (HHMM)", group = grpEvt)
i_armTo    = input.int(1500, "Last entry (HHMM)", group = grpEvt)
i_flatTime = input.int(1555, "Flat by (HHMM)", group = grpEvt)
i_maxDay   = input.int(3, "Max trades / day", minval = 1, maxval = 10, group = grpEvt)

grpRisk = "Risk (Lane F — 1.0R)"
i_maxStop = input.float(30.0, "Max stop (pts)", group = grpRisk)
i_minStop = input.float(2.0, "Min stop (pts)", group = grpRisk)
i_rr      = input.float(1.0, "Target R", group = grpRisk)
i_riskUsd = input.float(100.0, "Risk USD", group = grpRisk)
i_maxCtr  = input.int(60, "Max contracts", group = grpRisk)
i_pvMode  = input.string("MNQ ($2/pt)", "Point value", options = ["MNQ ($2/pt)", "NQ ($20/pt)", "Auto"], group = grpRisk)

grpVis = "Visuals"
i_showMark  = input.bool(true, "Markers", group = grpVis)
i_showBB    = input.bool(true, "BB overlay", group = grpVis)
i_showDebug = input.bool(true, "Funnel table", group = grpVis)

f_pv() =>
    if i_pvMode == "MNQ ($2/pt)"
        2.0
    else if i_pvMode == "NQ ($20/pt)"
        20.0
    else
        float raw = syminfo.pointvalue
        string t = str.upper(syminfo.ticker)
        str.contains(t, "MNQ") ? 2.0 : (str.contains(t, "NQ") ? 20.0 : (raw > 0 ? raw : 2.0))

f_qty(float stopPts) =>
    float pv = f_pv()
    if stopPts < i_minStop or stopPts > i_maxStop
        0
    else
        int q = int(math.floor(i_riskUsd / (stopPts * pv)))
        math.max(0, math.min(q, i_maxCtr))

int nyHhmm = hour(time, "America/New_York") * 100 + minute(time, "America/New_York")
bool newDay = ta.change(time("D", "America/New_York")) != 0
bool canArm = nyHhmm >= i_armFrom and nyHhmm < i_armTo
bool flatNow = nyHhmm >= i_flatTime

[bbMid, bbUpper, bbLower] = ta.bb(close, i_bbLen, i_bbMult)
[diPlus, diMinus, adx] = ta.dmi(i_adxLen, i_adxLen)
bool chopOk = not na(adx) and not na(diPlus) and not na(diMinus) and adx < i_adxMax

bool pierceDown = not na(bbLower[1]) and close[1] < bbLower[1]
bool pierceUp = not na(bbUpper[1]) and close[1] > bbUpper[1]
bool reclaimLong = pierceDown and not na(bbLower) and close > bbLower
bool reclaimShort = pierceUp and not na(bbUpper) and close < bbUpper

// plot() must be global — hide via na when overlay off
plot(i_showBB ? bbMid : na, "BB mid", color = color.new(color.blue, 50))
plot(i_showBB ? bbUpper : na, "BB upper", color = color.new(color.orange, 70))
plot(i_showBB ? bbLower : na, "BB lower", color = color.new(color.orange, 70))

var int dayTrades = 0
var int cntDays = 0
var int cntChop = 0
var int cntSignal = 0
var int cntOrders = 0
bool enteredThisBar = false

if newDay
    dayTrades := 0
    cntDays += 1

if canArm and chopOk
    cntChop += 1

if flatNow and strategy.position_size != 0
    strategy.close_all(comment = "flat 15:55")

bool canTrade = canArm and chopOk and dayTrades < i_maxDay and strategy.position_size == 0

if canTrade and reclaimLong
    cntSignal += 1
    float extreme = math.min(low, low[1])
    float stopPts = close - extreme
    int q = f_qty(stopPts)
    if q > 0
        float stopL = close - stopPts
        float tpL = close + i_rr * stopPts
        strategy.entry("R_L", strategy.long, qty = q)
        strategy.exit("R_LX", from_entry = "R_L", stop = stopL, limit = tpL)
        dayTrades += 1
        cntOrders += 1
        enteredThisBar := true
        if i_showMark
            label.new(bar_index, low, "BB L", style = label.style_label_up, color = color.new(color.green, 0), textcolor = color.black, size = size.small)

if canTrade and reclaimShort and not enteredThisBar and dayTrades < i_maxDay and strategy.position_size == 0
    cntSignal += 1
    float extremeS = math.max(high, high[1])
    float stopPtsS = extremeS - close
    int qS = f_qty(stopPtsS)
    if qS > 0
        float stopS = close + stopPtsS
        float tpS = close - i_rr * stopPtsS
        strategy.entry("R_S", strategy.short, qty = qS)
        strategy.exit("R_SX", from_entry = "R_S", stop = stopS, limit = tpS)
        dayTrades += 1
        cntOrders += 1
        enteredThisBar := true
        if i_showMark
            label.new(bar_index, high, "BB S", style = label.style_label_down, color = color.new(color.red, 0), textcolor = color.black, size = size.small)

var table t = table.new(position.top_right, 2, 5, bgcolor = color.new(color.black, 20))
if i_showDebug and barstate.islast
    table.cell(t, 0, 0, "BBReclaim", text_color = color.white, text_size = size.small)
    table.cell(t, 1, 0, "Lane F 1.0R", text_color = color.gray, text_size = size.small)
    table.cell(t, 0, 1, "Days", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 1, str.tostring(cntDays), text_color = color.white, text_size = size.tiny)
    table.cell(t, 0, 2, "Chop bars", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 2, str.tostring(cntChop), text_color = color.white, text_size = size.tiny)
    table.cell(t, 0, 3, "Signals", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 3, str.tostring(cntSignal), text_color = color.white, text_size = size.tiny)
    table.cell(t, 0, 4, "Orders", text_color = color.gray, text_size = size.tiny)
    table.cell(t, 1, 4, str.tostring(cntOrders), text_color = color.lime, text_size = size.tiny)

alertcondition(enteredThisBar, title = "BBReclaim measure entry", message = "BBReclaim MEASURE — Stage-0 only · not promote.")
